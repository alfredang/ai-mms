# Environment secrets
.env

# Database dumps
*.sql
*.sql.gz
*.sql.gz.zip

# Site backups
*.zip
*.tar.gz

# Media cache (auto-generated thumbnails, regenerated by Magento)
/media/catalog/product/cache/
/media/tmp/
/media/captcha/

# Var directory (cache, sessions, logs, reports)
/var/*
!/var/.htaccess

# Composer vendor
/vendor/

# Docker volumes
mysql_data/
postgres_data/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Lock files
*.LCK

# Playwright/screenshots
.playwright-mcp/
localhost-*.png

# Backup files
*-bkp-*
*.bkp
*_backup_*
*_clone.*
*_Original/
*_OLD/
*_old/
*_BACKUP/

# PHP info / test / disabled files
info.php*
*.phpdisabled

# Magento downloader
/tertiarydownloader/

# Test directories
/test/
/testing/

# Backup local Mage overrides
/app/code/local/Mage_BACKUP/
/app/code/local/Mage/

# Environment-specific config (contains credentials)
/app/etc/local.xml

# Composer cache
/composer.lock

# SSL/hosting/cPanel files
.well-known/
.ftpquota
.user.ini
/cgi-bin/

# Legacy/hosting directories
/tertiarycourses.sg/
/malaysia/
/includes/
/shell/
/pdf/

# Sub-migrations with SQL filename exception (override *.sql rule)
!migrations/*.sql
