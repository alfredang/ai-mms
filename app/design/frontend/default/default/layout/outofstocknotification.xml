<?xml version="1.0"?>

<layout version="0.1.0">

    <default>

	    

    </default>

   <PRODUCT_TYPE_simple>
    <reference name="head">

	        <action method="addJs"><script>outofstocknotification/outofstocknotification.js</script></action>

	        <action method="addCss"><stylesheet>outofstocknotification/outofstocknotification.css</stylesheet></action>

	     </reference>

   		<update handle="product.info.simple"/>

        <reference name="product.info">

            <block type="outofstocknotification/view" name="view" as="view" />

