    <script type="text/javascript">
    //<![CDATA[
    var loginForm = new varienForm('loginForm');

    function togglePw() {
        var inp = document.getElementById('login');
        var open = document.getElementById('pw-eye-open');
        var closed = document.getElementById('pw-eye-closed');
        if (inp.type === 'password') {
            inp.type = 'text';
            open.style.display = 'none';
            closed.style.display = 'block';
        } else {
            inp.type = 'password';
            open.style.display = 'block';
            closed.style.display = 'none';
        }
    }

    function switchTab(tab) {
        var passwordForm = $('loginForm');
        var otpForm = $('otpForm');
        var tabOtp = $('tab-otp');
        var tabPassword = $('tab-password');

        if (tab === 'otp') {
            passwordForm.addClassName('hidden');
            otpForm.removeClassName('hidden');
            tabOtp.addClassName('active');
            tabPassword.removeClassName('active');
        } else {
            passwordForm.removeClassName('hidden');
            otpForm.addClassName('hidden');
            tabPassword.addClassName('active');
            tabOtp.removeClassName('active');
        }
    }

    function sendOtp() {
        var email = $('otp-email').value.trim();
        if (!email) { alert('Please enter your email address'); return; }

        var btn = $('btn-send-otp');
        btn.disabled = true;
        btn.innerHTML = 'Sending...';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?php echo $otpSendUrl ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onload = function() {
            btn.disabled = false;
            btn.innerHTML = 'Send OTP';
            try {
                var resp = JSON.parse(xhr.responseText);
                if (resp.success) {
                    $('otp-step-email').addClassName('hidden');
                    $('otp-step-verify').removeClassName('hidden');
                    $('otp-sent-text').innerHTML = 'OTP sent to ' + email;
                    var digits = document.querySelectorAll('.otp-digit');
                    if (digits[0]) digits[0].focus();
                } else {
                    alert(resp.message || 'Failed to send OTP');
                }
            } catch(e) { alert('Error sending OTP. Please try again.'); }
        };
        xhr.onerror = function() { btn.disabled = false; btn.innerHTML = 'Send OTP'; alert('Network error'); };
        xhr.send('email=' + encodeURIComponent(email) + '&form_key=<?php echo $formKey ?>');
    }

    function otpInput(el) {
        var val = el.value.replace(/[^0-9]/g, '');
        el.value = val;
        if (val && el.getAttribute('data-index') < 5) {
            var next = document.querySelectorAll('.otp-digit')[parseInt(el.getAttribute('data-index')) + 1];
            if (next) next.focus();
        }
    }

    function otpKeydown(e, el) {
        if (e.keyCode === 8 && !el.value && el.getAttribute('data-index') > 0) {
            var prev = document.querySelectorAll('.otp-digit')[parseInt(el.getAttribute('data-index')) - 1];
            if (prev) { prev.focus(); prev.value = ''; }
        }
    }

    function verifyOtp() {
        var digits = document.querySelectorAll('.otp-digit');
        var otp = '';
        for (var i = 0; i < digits.length; i++) otp += digits[i].value;
        if (otp.length < 6) { alert('Please enter the complete 6-digit OTP'); return; }

        var email = $('otp-email').value.trim();
        var btn = $('btn-verify-otp');
        btn.disabled = true;
        btn.innerHTML = 'Verifying...';

        var xhr = new XMLHttpRequest();
        xhr.open('POST', '<?php echo $otpVerifyUrl ?>');
        xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
        xhr.onload = function() {
            try {
                var resp = JSON.parse(xhr.responseText);
                if (resp.success && resp.redirect) {
                    window.location.href = resp.redirect;
                } else {
                    btn.disabled = false;
                    btn.innerHTML = 'Verify &amp; Login';
                    alert(resp.message || 'Verification failed');
                }
            } catch(e) { btn.disabled = false; btn.innerHTML = 'Verify &amp; Login'; alert('Error verifying OTP'); }
        };
        xhr.onerror = function() { btn.disabled = false; btn.innerHTML = 'Verify &amp; Login'; alert('Network error'); };
        xhr.send('email=' + encodeURIComponent(email) + '&otp=' + encodeURIComponent(otp) + '&form_key=<?php echo $formKey ?>');
    }
    //]]>
    </script>
