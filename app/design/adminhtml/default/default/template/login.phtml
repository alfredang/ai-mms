    function lpOpenModal(key) {
        var p = LP_POLICIES[key]; if (!p) return;
        document.getElementById('lp-modal-title').textContent = p.title;
        document.getElementById('lp-modal-body').innerHTML = p.html;
        // Per-policy footer override (e.g. Feedback uses Cancel + Send Feedback);
        // anything else falls back to a single Close button.
        document.getElementById('lp-modal-foot').innerHTML = p.foot ||
            '<button type="button" onclick="lpCloseModal()">Close</button>';
        document.getElementById('lp-modal-body').scrollTop = 0;
        document.getElementById('lp-modal').classList.add('is-open');
        document.body.style.overflow = 'hidden';
    }
    function lpCloseModal() {
        document.getElementById('lp-modal').classList.remove('is-open');
        document.body.style.overflow = '';
    }
    document.addEventListener('keydown', function(e){
        if (e.key === 'Escape') lpCloseModal();
    });
