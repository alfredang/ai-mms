<script type="text/javascript">
(function(){
    function applyRoleSidebar(role) {
        var map = {
            'Learner':     'sidebar-nav-learner',
            'Trainer':     'sidebar-nav-trainer',
            'Admin':       'sidebar-nav-admin-custom',
            'Marketing':   'sidebar-nav-marketing',
            'Super Admin': 'sidebar-nav-superadmin-custom',
            'Developer':   'sidebar-nav-developer'
        };
        var targetId = map[role] || 'sidebar-nav-admin';
        var ids = ['sidebar-nav-admin','sidebar-nav-admin-custom','sidebar-nav-superadmin-custom','sidebar-nav-marketing','sidebar-nav-learner','sidebar-nav-trainer','sidebar-nav-developer'];
        for (var i = 0; i < ids.length; i++) {
            var el = document.getElementById(ids[i]);
            if (el) el.style.display = (ids[i] === targetId) ? '' : 'none';
        }
    }
    var role = '<?php echo htmlspecialchars($_activeRoleLabel) ?>';
    if (document.readyState === 'loading') document.addEventListener('DOMContentLoaded', function(){ applyRoleSidebar(role); });
    else applyRoleSidebar(role);
    window.__applySidebarRole = applyRoleSidebar;
})();
function toggleToolGroup(btn) {
    var group = btn.parentElement;
    group.classList.toggle('open');
}
function setTrainerActiveNav(which) {
    var ids = { myclasses:'trainer-nav-myclasses', edtools:'trainer-nav-edtools', problemsolving:'trainer-nav-problemsolving', dataanalytics:'trainer-nav-dataanalytics', finance:'trainer-nav-finance', statistical:'trainer-nav-statistical', doe:'trainer-nav-doe', spc:'trainer-nav-spc', sustainability:'trainer-nav-sustainability', blockchain:'trainer-nav-blockchain', genai:'trainer-nav-genai', agentic:'trainer-nav-agentic', virtual:'trainer-nav-virtual', billing:'learner-nav-billing' };
    for (var key in ids) {
        var el = document.getElementById(ids[key]);
        if (el) el.classList.toggle('active', which === key);
    }
}
</script>
