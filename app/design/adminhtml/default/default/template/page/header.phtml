};
function renderHeaderNav(role) {
    var items = ROLE_NAV[role] || ROLE_NAV['Admin'];
    var html = '';
    for (var i = 0; i < items.length; i++) {
        html += '<a href="#" class="header-nav-item' + (i===0?' active':'') + '">' +
                '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">' + items[i].svg + '</svg>' +
                '<span>' + items[i].label + '</span></a>';
    }
    var nav = document.getElementById('header-nav');
    if (nav) nav.innerHTML = html;
}
function selectViewAs(btn) {
    var role = btn.getAttribute('data-role');
    document.getElementById('view-as-role').textContent = role;
    var options = document.querySelectorAll('.view-as-option');
    for (var i = 0; i < options.length; i++) options[i].classList.remove('active');
    btn.classList.add('active');
    document.getElementById('view-as').classList.remove('open');
    try { localStorage.setItem('adminViewAs', role); } catch(e) {}
    renderHeaderNav(role);
    if (typeof window.__applyDashboardRole === 'function') window.__applyDashboardRole(role);
    if (typeof window.__applySidebarRole === 'function') window.__applySidebarRole(role);
}
(function(){
    var role = 'Admin';
    try {
        var saved = localStorage.getItem('adminViewAs');
        if (saved) role = saved;
    } catch(e) {}
    var el = document.getElementById('view-as-role');
    if (el) el.textContent = role;
    var opts = document.querySelectorAll('.view-as-option');
    for (var i = 0; i < opts.length; i++) {
        opts[i].classList.toggle('active', opts[i].getAttribute('data-role') === role);
    }
    renderHeaderNav(role);
})();
</script>
