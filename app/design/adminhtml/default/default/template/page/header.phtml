<script type="text/javascript">
function switchRole(btn) {
    var roleCode = btn.getAttribute('data-role');
    var xhr = new XMLHttpRequest();
    xhr.open('POST', '<?php echo $switchUrl ?>');
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() {
        try {
            var resp = JSON.parse(xhr.responseText);
            if (resp.success && resp.redirect) {
                window.location.href = resp.redirect;
            }
        } catch(e) {
            window.location.reload();
        }
    };
    xhr.send('role_code=' + encodeURIComponent(roleCode) + '&form_key=<?php echo Mage::getSingleton('core/session')->getFormKey() ?>');
}
document.addEventListener('click', function(e) {
    var menu = document.getElementById('user-menu');
    if (menu && !menu.contains(e.target)) menu.classList.remove('open');
    var viewAs = document.getElementById('view-as');
    if (viewAs && !viewAs.contains(e.target)) viewAs.classList.remove('open');
});
(function(){
    var days = ['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];
    var months = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    function pad(n){ return n < 10 ? '0' + n : n; }
    function tick(){
        var now = new Date();
        var dateStr = days[now.getDay()] + ' ' + pad(now.getDate()) + ' ' + months[now.getMonth()];
        var h = now.getHours();
        var ampm = h >= 12 ? 'PM' : 'AM';
        h = h % 12;
        if (h === 0) h = 12;
        var timeStr = pad(h) + ':' + pad(now.getMinutes()) + ' ' + ampm;
        var d = document.getElementById('header-date');
        var t = document.getElementById('header-time');
        if (d) d.textContent = dateStr;
        if (t) t.textContent = timeStr;
    }
    tick();
    setInterval(tick, 1000);
})();
</script>
