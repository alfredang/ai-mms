    $_commitVersion = trim(file_get_contents($_commitVersionFile));
}
?>
<p class="legality">
    Powered by Tertiary Infotech Academy Pte Ltd &copy; <?php echo date('Y') ?>
    <?php if ($_commitVersion): ?>
    <span style="margin-left:12px;color:var(--t5);font-size:11px;">v <?php echo htmlspecialchars($_commitVersion) ?></span>
    <?php elseif ($_version): ?>
    <span style="margin-left:12px;color:var(--t5);font-size:11px;">v <?php echo htmlspecialchars($_version) ?></span>
    <?php endif; ?>
</p>
