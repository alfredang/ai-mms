    <script type="text/javascript">
    (function(){
        window.__attListUrl = <?php echo json_encode($_attListUrl) ?>;
        window.__attSaveUrl = <?php echo json_encode($_attSaveUrl) ?>;
        window.__attCourseId = <?php echo (int)$_selectedCourseId ?>;
        window.__attCurrentSession = null;
        window.__attLearners = [];
    })();
    window.attLoadSession = function(optionTypeId) {
        var panel = document.getElementById('attPanel');
        var summary = document.getElementById('attSummary');
        var list = document.getElementById('attList');
        if (!optionTypeId) { panel.style.display = 'none'; return; }
        window.__attCurrentSession = parseInt(optionTypeId, 10);
        panel.style.display = '';
        summary.textContent = 'Loading…';
        list.innerHTML = '';
        var url = window.__attListUrl + '?course_id=' + window.__attCourseId + '&option_type_id=' + optionTypeId;
        fetch(url, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { summary.textContent = d.message || 'Failed to load'; return; }
                window.__attLearners = d.learners || [];
                if (window.__attLearners.length === 0) {
                    summary.textContent = 'No enrolled learners found for this session.';
                    return;
                }
                attRender();
            })
            .catch(function(err){ summary.textContent = 'Network error: ' + err.message; });
    };
    // Inject once: forceful styles for attendance buttons/rows — overrides admin-area button CSS
    (function(){
        if (document.getElementById('att-styles')) return;
        var s = document.createElement('style');
        s.id = 'att-styles';
        s.textContent = ''
            + '.att-row{background:#0f172a;border:1px solid #334155;border-left-width:4px;border-left-color:#64748b;border-radius:8px;padding:12px 14px;display:flex;align-items:center;gap:12px;transition:background .15s,border-color .15s}'
            + '.att-row.att-status-present{background:rgba(16,185,129,.08);border-color:#10b981}'
            + '.att-row.att-status-absent{background:rgba(239,68,68,.08);border-color:#ef4444}'
            + '.att-badge{font-size:10px;font-weight:800;letter-spacing:.8px;padding:3px 9px;border-radius:999px;text-transform:uppercase;background:#334155;color:#94a3b8;flex-shrink:0}'
            + '.att-badge.att-badge-present{background:#10b981;color:#0f172a}'
            + '.att-badge.att-badge-absent{background:#ef4444;color:#fff}'
            + 'button.att-btn,button.att-btn:hover,button.att-btn:focus,button.att-btn:active{background:#334155 !important;background-image:none !important;color:#cbd5e1 !important;border:1px solid #475569 !important;border-radius:6px !important;padding:7px 14px !important;font-size:12px !important;font-weight:600 !important;cursor:pointer !important;text-align:center !important;transition:all .15s !important;box-shadow:none !important;text-shadow:none !important;text-transform:none !important;line-height:normal !important;height:auto !important;display:inline-flex !important;align-items:center !important;gap:5px !important;min-width:96px !important;justify-content:center !important}'
            + 'button.att-btn:hover{background:#475569 !important}'
            + 'button.att-btn.att-btn-present.att-on,button.att-btn.att-btn-present.att-on:hover,button.att-btn.att-btn-present.att-on:focus{background:#10b981 !important;border-color:#10b981 !important;color:#0f172a !important;box-shadow:0 0 0 2px rgba(16,185,129,.25) !important}'
            + 'button.att-btn.att-btn-absent.att-on,button.att-btn.att-btn-absent.att-on:hover,button.att-btn.att-btn-absent.att-on:focus{background:#ef4444 !important;border-color:#ef4444 !important;color:#fff !important;box-shadow:0 0 0 2px rgba(239,68,68,.25) !important}';
        document.head.appendChild(s);
    })();

    function attRender() {
        var list = document.getElementById('attList');
        var summary = document.getElementById('attSummary');
        list.innerHTML = '';
        var present = 0, absent = 0;
        window.__attLearners.forEach(function(l) {
            if (l.status === 'present') present++;
            else if (l.status === 'absent') absent++;
            var row = document.createElement('div');
            row.className = 'att-row' + (l.status === 'present' ? ' att-status-present' : (l.status === 'absent' ? ' att-status-absent' : ''));

            var badgeLabel = l.status === 'present' ? 'Present' : (l.status === 'absent' ? 'Absent' : 'Unmarked');
            var badgeClass = l.status === 'present' ? 'att-badge-present' : (l.status === 'absent' ? 'att-badge-absent' : '');
            var presentIcon = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12"/></svg>';
            var absentIcon  = '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>';

            row.innerHTML =
                '<span class="att-badge ' + badgeClass + '">' + badgeLabel + '</span>' +
                '<div style="flex:1;min-width:0;">' +
                    '<div style="color:#f1f5f9;font-size:13px;font-weight:600;">' + escapeHtml(l.name) + '</div>' +
                    '<div style="color:#94a3b8;font-size:11.5px;">' + escapeHtml(l.email) + '</div>' +
                '</div>' +
                '<div style="display:flex;gap:6px;">' +
                    '<button type="button" data-s="present" class="att-btn att-btn-present' + (l.status === 'present' ? ' att-on' : '') + '">' + presentIcon + ' Present</button>' +
                    '<button type="button" data-s="absent"  class="att-btn att-btn-absent'  + (l.status === 'absent'  ? ' att-on' : '') + '">' + absentIcon + ' Absent</button>' +
                '</div>';
            var cid = l.customer_id;
            row.querySelectorAll('button').forEach(function(b){
                b.addEventListener('click', function(){
                    var idx = window.__attLearners.findIndex(function(x){ return x.customer_id === cid; });
                    if (idx < 0) return;
                    var target = b.getAttribute('data-s');
                    // Clicking the already-active state clears it (back to unmarked)
                    window.__attLearners[idx].status = (window.__attLearners[idx].status === target) ? '' : target;
                    attRender();
                });
            });
            list.appendChild(row);
        });
        var total = window.__attLearners.length;
        var unmarked = total - present - absent;
        summary.innerHTML = '<strong style="color:#f1f5f9;">' + total + ' learner(s):</strong> '
            + '<span style="color:#10b981;font-weight:600;">' + present + ' present</span>, '
            + '<span style="color:#ef4444;font-weight:600;">' + absent + ' absent</span>'
            + (unmarked ? ', <span style="color:#94a3b8;">' + unmarked + ' unmarked</span>' : '');
    }
    function escapeHtml(s) { s = s || ''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    window.attSetAll = function(status) {
        window.__attLearners.forEach(function(l){ l.status = status; });
        attRender();
    };
    window.attSave = function() {
        var btn = document.getElementById('attSaveBtn');
        var rs  = document.getElementById('attResult');
        if (!window.__attCurrentSession) return;
        var payload = {};
        window.__attLearners.forEach(function(l){
            if (l.status === 'present' || l.status === 'absent') payload[l.customer_id] = l.status;
        });
        btn.disabled = true; btn.textContent = 'Saving…';
        rs.style.display = ''; rs.innerHTML = '<span style="color:#94a3b8;">Saving…</span>';
        var fd = new FormData();
        fd.append('course_id', window.__attCourseId);
        fd.append('option_type_id', window.__attCurrentSession);
        fd.append('attendance', JSON.stringify(payload));
        fetch(window.__attSaveUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                btn.disabled = false; btn.textContent = 'Save Attendance';
                if (d.success) rs.innerHTML = '<span style="color:#10b981;">Saved ' + d.updated + ' record(s).</span>';
                else rs.innerHTML = '<span style="color:#ef4444;">' + (d.message || 'Save failed') + '</span>';
            })
            .catch(function(err){
                btn.disabled = false; btn.textContent = 'Save Attendance';
                rs.innerHTML = '<span style="color:#ef4444;">Network error: ' + err.message + '</span>';
            });
    };
    </script>

