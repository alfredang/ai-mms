<script type="text/javascript">
(function(){
    var TPGVR_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/runLookup')) ?>;
    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    function fmtDate(iso){
        if (!iso) return '—';
        var p = String(iso).split('-');
        if (p.length === 3) return p[2] + '/' + p[1] + '/' + p[0];
        return iso;
    }
    window.tpgvrClear = function(){
        document.getElementById('tpgvr-id').value = '';
        document.getElementById('tpgvr-empty').style.display = '';
        var box = document.getElementById('tpgvr-results');
        box.style.display = 'none';
        box.innerHTML = '';
    };
    window.tpgvrView = function(){
        var id = document.getElementById('tpgvr-id').value.trim();
        if (!id) { alert('Enter a Course Run ID first.'); return; }
        var empty = document.getElementById('tpgvr-empty');
        var box   = document.getElementById('tpgvr-results');
        empty.style.display = 'none';
        box.style.display = 'block';
        box.innerHTML = '<div class="tpgvr-empty"><div class="tpgvr-empty-title">Loading…</div></div>';
        fetch(TPGVR_URL + '?run_id=' + encodeURIComponent(id), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) {
                    box.innerHTML = '<div class="tpgvr-empty"><div class="tpgvr-empty-title">Not found</div><div class="tpgvr-empty-desc">' + escapeHtml(d.message || 'No course run matched that ID.') + '</div></div>';
                    return;
                }
                var r = d.run || {};

                // ----- Hero -----
                var vacancyClass = 'tpgvr-vac-a';
                if (r.vacancy === 'L') vacancyClass = 'tpgvr-vac-l';
                if (r.vacancy === 'F') vacancyClass = 'tpgvr-vac-f';

                var html = '<div class="tpgvr-summary"><div class="tpgvr-summary-id">Course Run ID: <strong>' + escapeHtml(String(r.run_id)) + '</strong></div></div>'
                         + '<div class="tpgvr-hero">'
                         +   '<div class="tpgvr-hero-title">' + escapeHtml(r.course_name) + '</div>'
                         +   '<div class="tpgvr-hero-meta">'
                         +     '<div><strong>Reference Number:</strong> ' + escapeHtml(r.reference_number || r.course_code) + '</div>'
                         +     '<div><strong>Vacancy:</strong> <span class="tpgvr-pill ' + vacancyClass + '">' + escapeHtml(r.vacancy_label || 'Available') + '</span></div>'
                         +   '</div>'
                         + '</div>';

                // ----- FIELD / VALUE table (SSG fields) -----
                var rows = [
                    ['Course Run ID',              r.run_id],
                    ['Course Start Date',          fmtDate(r.start_date)],
                    ['Course End Date',            fmtDate(r.end_date)],
                    ['Mode of Training',           r.mode_of_training],
                    ['Venue',                      r.venue],
                    ['Registration Opening Date',  fmtDate(r.registration_open_date)],
                    ['Registration Closing Date',  fmtDate(r.registration_close_date)],
                    ['Course Admin Email',         r.course_admin_email],
                    ['Attendance Taken',           r.attendance_taken],
                    ['QR Code Link',               r.qr_code_link],
                    ['Organization UEN',           r.organization_uen],
                ];
                html += '<table class="tpgvr-detail-table"><thead><tr><th>Field</th><th>Value</th></tr></thead><tbody>';
                rows.forEach(function(row){
                    var v = row[1];
                    var cell;
                    if (row[0] === 'QR Code Link' && v) {
                        cell = '<a href="' + escapeHtml(v) + '" target="_blank" rel="noopener" class="tpgvr-link"><svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:4px"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>' + escapeHtml(v) + '</a>';
                    } else {
                        cell = escapeHtml(v || '—');
                    }
                    html += '<tr><td>' + escapeHtml(row[0]) + '</td><td>' + cell + '</td></tr>';
                });
                html += '</tbody></table>';

                // ----- Assigned Trainer (TPG) — list every trainer linked to the course -----
                var trainers = r.assigned_trainers || (r.assigned_trainer ? [r.assigned_trainer] : []);
                if (trainers.length) {
                    html += '<div class="tpgvr-trainer-card">'
                         +    '<div class="tpgvr-trainer-title">Assigned Trainer' + (trainers.length > 1 ? 's' : '') + ' (TPG)</div>';
                    trainers.forEach(function(t, i){
                        html += (i > 0 ? '<div class="tpgvr-trainer-divider"></div>' : '')
                             + '<div class="tpgvr-trainer-row">'
                             +   '<div class="tpgvr-trainer-cell"><div class="tpgvr-trainer-lbl">NAME</div><div class="tpgvr-trainer-val">' + escapeHtml(t.name) + '</div></div>'
                             +   '<div class="tpgvr-trainer-cell"><div class="tpgvr-trainer-lbl">ID NUMBER</div><div class="tpgvr-trainer-val">' + escapeHtml(t.id_number_masked) + '</div></div>'
                             +   '<div class="tpgvr-trainer-cell"><div class="tpgvr-trainer-lbl">EMAIL</div><div class="tpgvr-trainer-val">' + escapeHtml(t.email) + '</div></div>'
                             + '</div>';
                    });
                    html += '</div>';
                }

                // ----- Collapsible raw JSON + parsed views -----
                html += '<details class="tpgvr-collapse"><summary>▼ View Raw JSON Response</summary>'
                     +   '<pre class="tpgvr-json">' + escapeHtml(JSON.stringify(d, null, 2)) + '</pre>'
                     + '</details>'
                     + '<details class="tpgvr-collapse"><summary>▼ View Parsed Data</summary>'
                     +   '<pre class="tpgvr-json">' + escapeHtml(JSON.stringify(r, null, 2)) + '</pre>'
                     + '</details>';

                // ----- Action buttons -----
                html += '<div class="tpgvr-actions">'
                     +   '<button type="button" class="tpgvr-clear-btn" onclick="tpgvrClear()">Clear Results</button>'
                     +   '<button type="button" class="tpgvr-edit-btn" onclick="window.location.href=\'?tpg_page=edit_course_run\'">'
                     +     '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="vertical-align:-2px;margin-right:6px"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>'
                     +     'Edit Course Run'
                     +   '</button>'
                     + '</div>';

                // ----- LOCAL DETAILS section -----
                var classPillCls = (r.class_status === 'Confirmed') ? 'tpgvr-vac-a' : 'tpgvr-vac-l';
                var localList = r.local_trainers || (r.local_trainer ? [r.local_trainer] : []);
                var trainerStr = localList.length
                    ? localList.map(function(t){ return escapeHtml(t.name) + ' <span class="tpgvr-muted">(' + escapeHtml(t.email) + ')</span>'; }).join('<br>')
                    : '—';
                html += '<div class="tpgvr-local">'
                     +   '<div class="tpgvr-local-title">LOCAL DETAILS</div>'
                     +   '<div class="tpgvr-local-sub">From local <code>course_run</code> — may differ from SSG if sync is stale.</div>'
                     +   '<div class="tpgvr-local-row"><div>Class Status</div><div><span class="tpgvr-pill ' + classPillCls + '">' + escapeHtml(r.class_status) + '</span></div></div>'
                     +   '<div class="tpgvr-local-row"><div>Local Trainer</div><div>' + trainerStr + '</div></div>'
                     +   '<div class="tpgvr-local-row"><div>TPG Trainer (Local)</div><div>' + trainerStr + '</div></div>'
                     +   '<div class="tpgvr-local-row"><div>Digital Attendance ID</div><div><code class="tpgvr-code-pill">' + escapeHtml(r.digital_attendance_id) + '</code></div></div>'
                     + '</div>';

                box.innerHTML = html;
            })
            .catch(function(err){
                box.innerHTML = '<div class="tpgvr-empty"><div class="tpgvr-empty-title">Network error</div><div class="tpgvr-empty-desc">' + escapeHtml(err.message) + '</div></div>';
            });
    };
})();
</script>
<?php endif; ?>

