<script type="text/javascript">
(function(){
    var drop    = document.getElementById('bue-drop');
    var input   = document.getElementById('bue-file');
    var chosen  = document.getElementById('bue-file-chosen');
    var btn     = document.getElementById('bue-process');
    var msg     = document.getElementById('bue-msg');
    if (!drop) return;
    function showFile(name){
        chosen.style.display = 'block';
        chosen.textContent = 'Selected: ' + name;
        btn.disabled = false;
    }
    function rejectExt(name){
        var lower = (name || '').toLowerCase();
        return !(lower.endsWith('.xlsx') || lower.endsWith('.xls'));
    }
    function showMsg(t, k){ msg.textContent = t; msg.className = 'bue-msg ' + (k === 'err' ? 'err' : 'ok'); }
    drop.addEventListener('dragover',  function(e){ e.preventDefault(); drop.classList.add('dragover'); });
    drop.addEventListener('dragleave', function(){ drop.classList.remove('dragover'); });
    drop.addEventListener('drop',      function(e){
        e.preventDefault();
        drop.classList.remove('dragover');
        var f = e.dataTransfer && e.dataTransfer.files && e.dataTransfer.files[0];
        if (!f) return;
        if (rejectExt(f.name)) { showMsg('Only XLSX or XLS files are accepted.', 'err'); return; }
        // Assign dropped file to the hidden file input
        var dt = new DataTransfer();
        dt.items.add(f);
        input.files = dt.files;
        showFile(f.name);
        msg.className = 'bue-msg';
    });
    input.addEventListener('change', function(){
        var f = input.files && input.files[0];
        if (!f) return;
        if (rejectExt(f.name)) { input.value = ''; btn.disabled = true; showMsg('Only XLSX or XLS files are accepted.', 'err'); return; }
        showFile(f.name);
        msg.className = 'bue-msg';
    });
})();
</script>
