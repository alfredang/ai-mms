                    <?php
                    // Load the live category tree from the catalog. We pull all active
                    // categories with their level (for indent), name, parent_id, and
                    // product_count, then walk them in path order so children follow
                    // their parent. Pre-check the boxes for whichever categories the
                    // course is currently assigned to.
                    $_catTreeRows = array();
                    $_currentCatIds = array();
                    try {
                        $_catRead = Mage::getSingleton('core/resource')->getConnection('core_read');
                        $_catTreeRows = $_catRead->fetchAll(
                            "SELECT e.entity_id, e.level, e.path, e.parent_id,
                                    COALESCE(nameStore.value, nameDef.value, '') AS name,
                                    COALESCE(activeStore.value, activeDef.value, 1) AS is_active,
                                    (SELECT COUNT(*) FROM catalog_category_product cp WHERE cp.category_id = e.entity_id) AS product_count
                             FROM catalog_category_entity e
                             LEFT JOIN eav_attribute na   ON na.entity_type_id = e.entity_type_id AND na.attribute_code = 'name'
                             LEFT JOIN catalog_category_entity_varchar nameDef   ON nameDef.entity_id = e.entity_id   AND nameDef.attribute_id = na.attribute_id AND nameDef.store_id = 0
                             LEFT JOIN catalog_category_entity_varchar nameStore ON nameStore.entity_id = e.entity_id AND nameStore.attribute_id = na.attribute_id AND nameStore.store_id != 0
                             LEFT JOIN eav_attribute aa   ON aa.entity_type_id = e.entity_type_id AND aa.attribute_code = 'is_active'
                             LEFT JOIN catalog_category_entity_int activeDef    ON activeDef.entity_id = e.entity_id    AND activeDef.attribute_id = aa.attribute_id AND activeDef.store_id = 0
                             LEFT JOIN catalog_category_entity_int activeStore  ON activeStore.entity_id = e.entity_id  AND activeStore.attribute_id = aa.attribute_id AND activeStore.store_id != 0
                             WHERE e.level > 0
                             ORDER BY e.path ASC"
                        );
                        $_currentCatIds = array_map('intval', (array) $_editProd->getCategoryIds());
                    } catch (Exception $_catEx) { /* if tables not present, fall through to empty list */ }
                    ?>
                    <?php if (empty($_catTreeRows)): ?>
                    <div style="color:#64748b;font-size:13px;">No catalog categories found.</div>
                    <?php else: ?>
                    <input type="hidden" name="_categories_loaded" value="1" />
                    <div style="background:#0f172a;border:1px solid #334155;border-radius:8px;padding:14px 16px;max-height:520px;overflow-y:auto;">
                        <?php foreach ($_catTreeRows as $_cat):
                            $_lvl   = (int) $_cat['level'];
                            $_indent = max(0, ($_lvl - 1) * 18);
                            $_id    = (int) $_cat['entity_id'];
                            $_isOn  = in_array($_id, $_currentCatIds, true);
                            $_dim   = ((int)$_cat['is_active']) ? '' : 'opacity:.5;';
                        ?>
                        <label style="display:block;margin:4px 0 4px <?php echo $_indent ?>px;color:#cbd5e1;font-size:13.5px;cursor:pointer;<?php echo $_dim ?>">
                            <input type="checkbox" name="categories[]" value="<?php echo $_id ?>"<?php echo $_isOn ? ' checked' : '' ?> style="accent-color:#2563eb;margin-right:8px;" />
                            <?php echo htmlspecialchars($_cat['name']) ?:'(unnamed)' ?>
                            <span style="color:#64748b;">(<?php echo (int) $_cat['product_count'] ?>)</span>
                        </label>
                        <?php endforeach; ?>
                    </div>
                    <div style="margin-top:10px;color:#64748b;font-size:12px;">
                        <?php echo count($_catTreeRows) ?> categories &middot; this course is currently in <?php echo count($_currentCatIds) ?>
                    </div>
                    <?php endif; ?>
                </div>
            </div>
        </div>

