                                    if ($_r['payment'] === 'Paid') echo 'se-pill-ok';
                                    elseif ($_r['payment'] === 'Cancelled') echo 'se-pill-cancelled';
                                    else echo 'se-pill-pending';
                                ?>"><?php echo $_r['payment'] ?></span></td>
                                <td><?php echo $_r['enrol_date'] ?></td>
