<script type="text/javascript">
(function(){
    var TPGDR_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/deleteCourseRun')) ?>;
    var FORM_KEY  = '<?php echo Mage::getSingleton('core/session')->getFormKey() ?>';
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}
    window.tpgdrValidate = function(){
        var btn = document.getElementById('tpgdr-delete-btn');
        var ok = val('tpgdr-course-ref') !== '' && val('tpgdr-run-id') !== '';
        btn.disabled = !ok;
    };
    window.tpgdrClear = function(){
        document.getElementById('tpgdr-course-ref').value = '';
        document.getElementById('tpgdr-run-id').value = '';
        var box = document.getElementById('tpgdr-result');
        if (box) { box.textContent=''; box.style.display='none'; }
        tpgdrValidate();
    };
    window.tpgdrDelete = function(){
        var ref = val('tpgdr-course-ref');
        var run = val('tpgdr-run-id');
        if (!ref || !run) { alert('Both fields are required.'); return; }
        if (!confirm('Are you sure you want to delete course run ' + run + ' for ' + ref + '? This cannot be undone.')) return;

        var box = document.getElementById('tpgdr-result');
        box.style.display = 'block';
        box.textContent = 'Deleting…';

        var fd = new FormData();
        fd.append('form_key',  FORM_KEY);
        fd.append('course_ref', ref);
        fd.append('run_id',     run);
        fetch(TPGDR_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { box.textContent = 'Failed: ' + (d.message || 'unknown error'); return; }
                box.textContent = '✓ Course run deleted.\n\n' + JSON.stringify(d, null, 2);
                tpgdrClear();
                box.style.display = 'block';
                box.textContent = '✓ Course run ' + run + ' deleted from ' + ref + '.';
            })
            .catch(function(err){ box.textContent = 'Network error: ' + err.message; });
    };
})();
</script>
