// Helper: add country filter to order collection via billing address join
function dashAddCountryFilter($collection, $countryCode) {
    if (!$countryCode) return;
    $collection->getSelect()->join(
        array('soa' => Mage::getSingleton('core/resource')->getTableName('sales/order_address')),
        'main_table.entity_id = soa.parent_id AND soa.address_type = "billing"',
        array()
    );
    $collection->getSelect()->where('soa.country_id = ?', $countryCode);
}

// Helper for currency
$currencyCode = (string) Mage::app()->getStore()->getCurrentCurrencyCode();

// 1. KPI: Total Orders (lifetime)
$orderCollection = Mage::getResourceModel('reports/order_collection');
if ($storeId) $orderCollection->addFieldToFilter('store_id', $storeId);
$orderCollection->addFieldToFilter('state', array('nin' => array(
    Mage_Sales_Model_Order::STATE_CANCELED,
    Mage_Sales_Model_Order::STATE_NEW
)));
dashAddCountryFilter($orderCollection, $countryFilter);
$totalOrders = (int) $orderCollection->getSize();

// 2. KPI: Total Sales Revenue (lifetime)
$salesCollection = Mage::getResourceModel('reports/order_collection');
if ($storeId) $salesCollection->addFieldToFilter('store_id', $storeId);
$salesCollection->addFieldToFilter('state', array('nin' => array(
    Mage_Sales_Model_Order::STATE_CANCELED,
    Mage_Sales_Model_Order::STATE_NEW
)));
dashAddCountryFilter($salesCollection, $countryFilter);
$salesCollection->getSelect()->columns(array(
    'total_revenue' => new Zend_Db_Expr('SUM(main_table.base_grand_total)')
));
$row = $salesCollection->getFirstItem();
$totalRevenue = (float) $row->getData('total_revenue');

// 3. KPI: Total Courses (products)
$productCount = Mage::getModel('catalog/product')->getCollection()->getSize();

// 4. KPI: Orders this month
$monthStart = date('Y-m-01 00:00:00');
$monthOrderCollection = Mage::getResourceModel('reports/order_collection');
if ($storeId) $monthOrderCollection->addFieldToFilter('store_id', $storeId);
$monthOrderCollection->addFieldToFilter('state', array('nin' => array(
    Mage_Sales_Model_Order::STATE_CANCELED,
    Mage_Sales_Model_Order::STATE_NEW
)));
$monthOrderCollection->addFieldToFilter('created_at', array('gteq' => $monthStart));
dashAddCountryFilter($monthOrderCollection, $countryFilter);
$monthOrders = (int) $monthOrderCollection->getSize();

// 5. Chart: Sales by Month (last 12 months)
$salesByMonth = array();
for ($i = 11; $i >= 0; $i--) {
    $mStart = date('Y-m-01 00:00:00', strtotime("-$i months"));
    $mEnd = date('Y-m-t 23:59:59', strtotime("-$i months"));
    $mLabel = date('M Y', strtotime("-$i months"));
    $mColl = Mage::getResourceModel('reports/order_collection');
    if ($storeId) $mColl->addFieldToFilter('store_id', $storeId);
    $mColl->addFieldToFilter('state', array('nin' => array(
        Mage_Sales_Model_Order::STATE_CANCELED,
        Mage_Sales_Model_Order::STATE_NEW
    )));
    $mColl->addFieldToFilter('created_at', array('gteq' => $mStart));
    $mColl->addFieldToFilter('created_at', array('lteq' => $mEnd));
    dashAddCountryFilter($mColl, $countryFilter);
    $mColl->getSelect()->columns(array(
        'month_total' => new Zend_Db_Expr('SUM(main_table.base_grand_total)')
    ));
    $mRow = $mColl->getFirstItem();
    $salesByMonth[] = array(
        'label' => $mLabel,
        'value' => round((float) $mRow->getData('month_total'), 2)
    );
}

