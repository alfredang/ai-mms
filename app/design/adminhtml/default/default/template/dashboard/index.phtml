<script type="text/javascript">
(function(){
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}
    window.tpggcTab = function(name){
        document.getElementById('tpggc-tab-personalised').classList.toggle('active', name === 'personalised');
        document.getElementById('tpggc-tab-baseline').classList.toggle('active',     name === 'baseline');
        document.getElementById('tpggc-personalised').style.display = (name === 'personalised') ? '' : 'none';
        document.getElementById('tpggc-baseline').style.display     = (name === 'baseline')     ? '' : 'none';
        var box = document.getElementById('tpggc-result');
        if (box) { box.textContent = ''; box.style.display = 'none'; }
    };
    window.tpggcSponsoredChange = function(){
        var isSponsored = (document.getElementById('tpggc-sponsored').value === 'Yes');
        var spUen = document.getElementById('tpggc-sp-uen');
        if (spUen) spUen.placeholder = isSponsored ? 'Required' : 'Optional';
    };
    window.tpggcCalcPersonalised = function(){
        if (!val('tpggc-course-ref')) { alert('Course Ref Code is required.'); return; }
        var payload = {
            grantCalculators: { individual: {
                uen:                val('tpggc-uen'),
                courseRefCode:      val('tpggc-course-ref'),
                trainee: {
                    id:               val('tpggc-nric'),
                    idType:           val('tpggc-nric-type'),
                    dateOfBirth:      val('tpggc-dob'),
                },
                isSme:                val('tpggc-sme') === 'Yes',
                isSponsored:          val('tpggc-sponsored') === 'Yes',
                sponsoringEmployerUen: val('tpggc-sp-uen'),
            } }
        };
        // Simple grant heuristic for demo: 70% SC, 50% PR, 90% SME-sponsored (rough numbers)
        var basePct = (val('tpggc-nric-type') === 'SC') ? 70 : (val('tpggc-nric-type') === 'PR' ? 50 : 0);
        if (val('tpggc-sme') === 'Yes' && val('tpggc-sponsored') === 'Yes') basePct = 90;
        var box = document.getElementById('tpggc-result');
        box.style.display = 'block';
        box.textContent = 'Estimated Grant: ' + basePct + '% of course fee\n\n'
                        + 'Request payload (preview):\n' + JSON.stringify(payload, null, 2);
    };
    window.tpggcCalcBaseline = function(){
        if (!val('tpggc-bl-course-ref')) { alert('Course Ref Code is required.'); return; }
        var payload = {
            grantCalculators: { baseline: {
                courseRefCode: val('tpggc-bl-course-ref'),
                idType:        val('tpggc-bl-nric-type'),
            } }
        };
        var basePct = (val('tpggc-bl-nric-type') === 'SC') ? 70 : (val('tpggc-bl-nric-type') === 'PR' ? 50 : 30);
        var box = document.getElementById('tpggc-result');
        box.style.display = 'block';
        box.textContent = 'Baseline Grant: ' + basePct + '% of course fee\n\n'
                        + 'Request payload (preview):\n' + JSON.stringify(payload, null, 2);
    };
})();
</script>
<?php endif; ?>

