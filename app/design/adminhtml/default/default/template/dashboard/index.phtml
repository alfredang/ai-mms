<script type="text/javascript">
(function(){
    var TPGAS_LOOKUP_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/runLookup')) ?>;
    window.__tpgadStartDate = null;
    window.__tpgadEndDate   = null;
    window.__tpgadSessions  = [];

    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    function fmtDate(iso){ if(!iso) return '—'; var p=String(iso).split('-'); return p.length===3 ? p[2]+'/'+p[1]+'/'+p[0] : iso; }

    function autoGenerateSessions(start, end){
        // Build morning + afternoon sessions for each day in the range, plus a final assessment.
        var sessions = [];
        if (!start || !end) return sessions;
        var startTs = Date.parse(start), endTs = Date.parse(end);
        if (isNaN(startTs) || isNaN(endTs)) return sessions;
        var d = new Date(startTs);
        var endD = new Date(endTs);
        while (d <= endD) {
            var iso = d.toISOString().slice(0,10);
            sessions.push({ date: iso, start: '09:15', end: '13:15', mode: '1' });
            sessions.push({ date: iso, start: '14:00', end: '18:00', mode: '1' });
            d.setDate(d.getDate() + 1);
        }
        // Final assessment slot on last day (mode 8)
        if (sessions.length) {
            var lastIso = sessions[sessions.length-1].date;
            sessions.push({ date: lastIso, start: '16:00', end: '18:00', mode: '8' });
        }
        return sessions;
    }

    function modeOptions(selected){
        var opts = [
            ['1','1 - Classroom Facilitated Training'],
            ['2','2 - Synchronous e-Learning'],
            ['3','3 - Asynchronous e-Learning'],
            ['4','4 - Blended Learning'],
            ['8','8 - Assessment'],
        ];
        return opts.map(function(o){ return '<option value="'+o[0]+'"'+(String(selected)===o[0]?' selected':'')+'>'+o[1]+'</option>'; }).join('');
    }

    function fmt12(t){ // "09:15" -> "09:15 am"
        if (!t) return '';
        var p = t.split(':'); if (p.length<2) return t;
        var h = parseInt(p[0],10), m = p[1];
        var ampm = h >= 12 ? 'pm' : 'am';
        var h12 = h % 12 || 12;
        return (h12<10?'0':'') + h12 + ':' + m + ' ' + ampm;
    }

    function renderSessions(){
        var box = document.getElementById('tpgad-sessions');
        var html = '';
        window.__tpgadSessions.forEach(function(s, i){
            html += '<div class="tpgad-session-card">'
                 +    '<div class="tpgad-session-head">'
                 +      '<div class="tpgad-session-num">Session ' + (i+1) + '</div>'
                 +      '<div class="tpgad-session-tools">'
                 +        '<span class="tpgad-day-pill">☀️ Day</span>'
                 +        '<a class="tpgad-remove" onclick="tpgadRemove(' + i + ')">Remove</a>'
                 +      '</div>'
                 +    '</div>'
                 +    '<div class="tpgad-grid-3" style="margin-bottom:18px">'
                 +      '<div class="tpgad-field"><label class="tpgad-label"><span class="tpgad-req">*</span> Date</label>'
                 +        '<input type="date" class="tpgad-input" data-field="date" data-idx="' + i + '" value="' + escapeHtml(s.date) + '" /></div>'
                 +      '<div class="tpgad-field"><label class="tpgad-label"><span class="tpgad-req">*</span> Start Time</label>'
                 +        '<input type="time" class="tpgad-input" data-field="start" data-idx="' + i + '" value="' + escapeHtml(s.start) + '" /></div>'
                 +      '<div class="tpgad-field"><label class="tpgad-label"><span class="tpgad-req">*</span> End Time</label>'
                 +        '<input type="time" class="tpgad-input" data-field="end" data-idx="' + i + '" value="' + escapeHtml(s.end) + '" /></div>'
                 +    '</div>'
                 +    '<div class="tpgad-field">'
                 +      '<label class="tpgad-label">Mode of Training</label>'
                 +      '<select class="tpgad-select" data-field="mode" data-idx="' + i + '">' + modeOptions(s.mode) + '</select>'
                 +    '</div>'
                 +  '</div>';
        });
        box.innerHTML = html;

        // Bind inputs to update the model
        box.querySelectorAll('[data-field]').forEach(function(el){
            el.addEventListener('change', function(){
                var idx = parseInt(this.getAttribute('data-idx'), 10);
                var key = this.getAttribute('data-field');
                if (!isNaN(idx) && window.__tpgadSessions[idx]) {
                    window.__tpgadSessions[idx][key] = this.value;
                }
            });
        });

        document.getElementById('tpgad-count-display').textContent = window.__tpgadSessions.length;
        document.getElementById('tpgad-add-btn').textContent = 'Add ' + window.__tpgadSessions.length + ' Sessions';
    }

    window.tpgadCountChange = function(delta){
        if (delta > 0) {
            // duplicate last session as a starting point
            var last = window.__tpgadSessions[window.__tpgadSessions.length-1] || { date: window.__tpgadStartDate, start:'09:15', end:'13:15', mode:'1' };
            window.__tpgadSessions.push({ date: last.date, start: last.start, end: last.end, mode: last.mode });
        } else if (window.__tpgadSessions.length > 1) {
            window.__tpgadSessions.pop();
        }
        renderSessions();
    };
    window.tpgadRemove = function(idx){
        if (window.__tpgadSessions.length <= 1) return;
        window.__tpgadSessions.splice(idx, 1);
        renderSessions();
    };
    window.tpgadCancel = function(){
        document.getElementById('tpgad-form').style.display = 'none';
        document.getElementById('tpgad-banner').style.display = 'none';
        document.getElementById('tpgas-run-id').value = '';
        window.__tpgadSessions = [];
    };
    window.tpgadSubmit = function(){
        if (!window.__tpgadSessions.length) { alert('No sessions to add.'); return; }
        // Backend integration pending — surface the JSON payload that would be sent to SSG.
        alert('Ready to add ' + window.__tpgadSessions.length + ' session(s):\n\n' + JSON.stringify(window.__tpgadSessions, null, 2));
    };

    window.tpgasFetch = function(){
        var input  = document.getElementById('tpgas-run-id');
        var box    = document.getElementById('tpgas-result');
        var banner = document.getElementById('tpgad-banner');
        var form   = document.getElementById('tpgad-form');
        var runId  = input.value.trim();
        if (!runId) { alert('Enter a Course Run ID first.'); input.focus(); return; }
        box.style.display = 'block';
        box.textContent = 'Fetching run ' + runId + '…';
        form.style.display = 'none';
        banner.style.display = 'none';
        fetch(TPGAS_LOOKUP_URL + '?run_id=' + encodeURIComponent(runId), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { box.textContent = d.message || 'Course Run not found.'; return; }
                var r = d.run || {};
                box.style.display = 'none';
                banner.style.display = 'block';
                banner.innerHTML = '✓ Data loaded for <strong>' + escapeHtml(r.course_name) + '</strong>';

                document.getElementById('tpgad-course-code').value = r.course_code || '';
                document.getElementById('tpgad-course-name').value = r.course_name || '';
                document.getElementById('tpgad-start-date').value  = fmtDate(r.start_date);
                document.getElementById('tpgad-end-date').value    = fmtDate(r.end_date);

                window.__tpgadStartDate = r.start_date;
                window.__tpgadEndDate   = r.end_date;
                window.__tpgadSessions  = autoGenerateSessions(r.start_date, r.end_date);
                if (!window.__tpgadSessions.length) {
                    // No dates known — seed with a single placeholder session
                    var today = new Date().toISOString().slice(0,10);
                    window.__tpgadSessions = [{ date: today, start: '09:15', end: '13:15', mode: '1' }];
                }
                renderSessions();
                form.style.display = 'block';
                window.scrollTo({ top: form.offsetTop - 80, behavior: 'smooth' });
            })
            .catch(function(err){ box.textContent = 'Network error: ' + err.message; });
    };
})();
</script>
