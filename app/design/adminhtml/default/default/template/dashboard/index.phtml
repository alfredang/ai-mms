<script type="text/javascript">
//<![CDATA[
// Fix Prototype.js / Chart.js conflict: restore native Array methods
// Prototype.js overrides Array.prototype.map/filter/reduce which breaks Chart.js
(function(){
    var iframe = document.createElement('iframe');
    iframe.style.display = 'none';
    document.body.appendChild(iframe);
    var nativeArr = iframe.contentWindow.Array.prototype;
    Array.prototype.map = nativeArr.map;
    Array.prototype.filter = nativeArr.filter;
    Array.prototype.reduce = nativeArr.reduce;
    if (nativeArr.find) Array.prototype.find = nativeArr.find;
    if (nativeArr.findIndex) Array.prototype.findIndex = nativeArr.findIndex;
    if (nativeArr.includes) Array.prototype.includes = nativeArr.includes;
    document.body.removeChild(iframe);
})();
//]]>
</script>
<script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js"></script>
<script type="text/javascript">
//<![CDATA[
document.observe('dom:loaded', function() {

    var chartColors = {
        blue: '#60a5fa',
