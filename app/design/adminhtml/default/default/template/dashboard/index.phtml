<script type="text/javascript">
(function(){
    function val(id){var el=document.getElementById(id);return el?el.value:'';}
    window.tpgelUpdatePreview = function(){
        var body = {
            enrolment: {
                trainingPartner: {
                    code: val('tpgel-tp-code'),
                    uen: val('tpgel-tp-uen')
                },
                course: {
                    referenceNumber: val('tpgel-course-ref'),
                    run: { id: val('tpgel-run-id') }
                },
                trainee: {
                    id: val('tpgel-learner-nric'),
                    idType: { type: val('tpgel-learner-idtype') || 'NRIC' },
                    fullName: val('tpgel-learner-name'),
                    dateOfBirth: val('tpgel-learner-dob'),
                    emailAddress: val('tpgel-learner-email'),
                    contactNumber: { countryCode: val('tpgel-learner-country-code') || '+65', phoneNumber: val('tpgel-learner-phone') },
                    enrolmentDate: new Date().toISOString().slice(0,10),
                    sponsorshipType: val('tpgel-sponsorship') || 'INDIVIDUAL',
                    fees: { discountAmount: 0, collectionStatus: 'Pending Payment' }
                }
            }
        };
        var pre = document.getElementById('tpgel-preview');
        if (pre) pre.textContent = JSON.stringify(body, null, 2);
    };
    window.tpgelOnCourseChange = function(){
        var sel = document.getElementById('tpgel-course-select');
        var opt = sel.options[sel.selectedIndex];
        document.getElementById('tpgel-course-ref').value = opt.value || '';
        document.getElementById('tpgel-course-eid').value = opt.getAttribute('data-eid') || '';
        var eid = opt.getAttribute('data-eid') || '';
        var runSel = document.getElementById('tpgel-run-select');
        for (var i=0; i<runSel.options.length; i++){
            var o = runSel.options[i];
            if (!o.value){ o.style.display=''; continue; }
            o.style.display = (!eid || o.getAttribute('data-eid') === eid) ? '' : 'none';
        }
        runSel.value = '';
        document.getElementById('tpgel-run-id').value = '';
        tpgelUpdatePreview();
    };
    window.tpgelClearForm = function(){
        document.getElementById('tpgel-form').reset();
        document.getElementById('tpgel-course-eid').value = '';
        var rs = document.getElementById('tpgel-learner-results');
        if (rs) { rs.innerHTML=''; rs.style.display='none'; }
        tpgelBackToSearch();
        tpgelOnCourseChange();
        tpgelUpdatePreview();
    };

    window.tpgelShowNewLearner = function(){
        var sv = document.getElementById('tpgel-search-view');
        var lb = document.getElementById('tpgel-learner-block');
        // Carry the search query into the Trainee Information form so the user
        // doesn't have to retype it. If it looks like an email, populate the
        // Email field; otherwise treat it as a full name.
        var q = (document.getElementById('tpgel-learner-search') || {}).value || '';
        q = q.trim();
        if (q) {
            var emailEl = document.getElementById('tpgel-learner-email');
            var nameEl  = document.getElementById('tpgel-learner-name');
            if (q.indexOf('@') !== -1) {
                if (emailEl && !emailEl.value) emailEl.value = q;
            } else {
                if (nameEl && !nameEl.value) nameEl.value = q;
            }
        }
        if (sv) sv.style.display = 'none';
        if (lb) lb.style.display = 'block';
        tpgelUpdatePreview();
    };
    window.tpgelBackToSearch = function(){
        var sv = document.getElementById('tpgel-search-view');
        var lb = document.getElementById('tpgel-learner-block');
        if (sv) sv.style.display = '';
        if (lb) lb.style.display = 'none';
    };

    // Debounced AJAX search for existing learners
    var TPGEL_SEARCH_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/searchLearners')) ?>;
    var tpgelDebounce = null;
    window.tpgelSelectLearner = function(payload){
        // payload: { email, fullname, id_type, nric, date_of_birth, country_code, phone_number, sponsorship_type }
        // Populate every Trainee Information field from stored learner_profile
        // data so admins don't retype previously-entered particulars.
        function set(id, v){ var el = document.getElementById(id); if (el) el.value = (v !== undefined && v !== null) ? v : ''; }
        set('tpgel-learner-email',         payload.email);
        set('tpgel-learner-name',          payload.fullname);
        set('tpgel-learner-idtype',        payload.id_type || 'NRIC');
        set('tpgel-learner-nric',          payload.nric);
        set('tpgel-learner-dob',           payload.date_of_birth);
        set('tpgel-learner-country-code',  payload.country_code || '+65');
        set('tpgel-learner-phone',         payload.phone_number);
        set('tpgel-sponsorship',           payload.sponsorship_type || 'INDIVIDUAL');

        var search = document.getElementById('tpgel-learner-search');
        if (search) search.value = payload.email || '';
        var rs = document.getElementById('tpgel-learner-results');
        if (rs) { rs.innerHTML=''; rs.style.display='none'; }
        var sv = document.getElementById('tpgel-search-view');
        var lb = document.getElementById('tpgel-learner-block');
        if (sv) sv.style.display = 'none';
        if (lb) lb.style.display = 'block';
        tpgelUpdatePreview();
    };
    function renderResults(results){
        var box = document.getElementById('tpgel-learner-results');
        if (!box) return;
        if (!results || !results.length){
            box.innerHTML = '<div class="tpgel-empty">No matching learners found.</div>';
            box.style.display = 'block';
            return;
        }
        // Stash full payloads so the Select button doesn't have to round-trip
        // through attribute strings (handles quotes/commas/apostrophes safely).
        window.__tpgelLastResults = results;
        var html = '';
        for (var i=0; i<results.length; i++){
            var r = results[i];
            var name = (r.fullname || r.email.split('@')[0]);
            var email = String(r.email);
            var nameEsc = name.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            var emailEsc = email.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
            html += '<div class="tpgel-result">'
                 +  '<div class="tpgel-result-info">'
                 +    '<div class="tpgel-result-name">' + nameEsc + '</div>'
                 +    '<div class="tpgel-result-email">' + emailEsc + '</div>'
                 +  '</div>'
                 +  '<button type="button" class="tpgel-result-btn" onclick="tpgelSelectLearner(window.__tpgelLastResults[' + i + '])">Select</button>'
                 +  '</div>';
        }
        box.innerHTML = html;
        box.style.display = 'block';
    }
    var searchInput = document.getElementById('tpgel-learner-search');
    if (searchInput){
        searchInput.addEventListener('input', function(){
            clearTimeout(tpgelDebounce);
            var q = this.value.trim();
            if (q.length < 2){
                var rs = document.getElementById('tpgel-learner-results');
                if (rs) { rs.innerHTML=''; rs.style.display='none'; }
                return;
            }
            tpgelDebounce = setTimeout(function(){
                fetch(TPGEL_SEARCH_URL + (TPGEL_SEARCH_URL.indexOf('?')>=0?'&':'?') + 'q=' + encodeURIComponent(q), { credentials: 'same-origin' })
                    .then(function(r){ return r.json(); })
                    .then(function(d){ renderResults(d.results || []); })
                    .catch(function(){ renderResults([]); });
            }, 220);
        });
    }

    tpgelUpdatePreview();
})();
</script>
<?php endif; ?>

