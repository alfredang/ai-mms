    new Chart(document.getElementById('salesByMonthChart').getContext('2d'), {
        type: 'bar',
        data: {
            labels: salesLabels,
            datasets: [{
                label: 'Revenue',
                data: salesValues,
                backgroundColor: chartColors.blue,
                borderColor: chartColors.blueDark,
                borderWidth: 1,
                barPercentage: 0.7
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            scales: {
                xAxes: [{
