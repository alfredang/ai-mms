<script type="text/javascript">
(function(){
    var TPGSE_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/searchAssessments')) ?>;
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}
    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    window.tpgseClear = function(){
        ['tpgse-run-id','tpgse-course-ref','tpgse-enrol-ref','tpgse-trainee-id'].forEach(function(id){
            var el = document.getElementById(id); if (el) el.value = '';
        });
        document.getElementById('tpgse-empty').style.display = '';
        var r = document.getElementById('tpgse-results'); r.style.display = 'none'; r.innerHTML = '';
    };
    window.tpgseSearch = function(){
        var run = val('tpgse-run-id');
        var ref = val('tpgse-course-ref');
        if (!run) { alert('Course Run ID is required.'); return; }
        if (!ref) { alert('Course Reference Number is required.'); return; }

        var empty = document.getElementById('tpgse-empty');
        var box   = document.getElementById('tpgse-results');
        empty.style.display = 'none';
        box.style.display = 'block';
        box.innerHTML = '<div class="tpgse-empty">Searching…</div>';

        var qs = 'run_id=' + encodeURIComponent(run)
               + '&course_ref=' + encodeURIComponent(ref)
               + '&enrol_ref=' + encodeURIComponent(val('tpgse-enrol-ref'))
               + '&trainee_id=' + encodeURIComponent(val('tpgse-trainee-id'));
        fetch(TPGSE_URL + '?' + qs, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) {
                    box.innerHTML = '<div class="tpgse-empty"><div class="tpgse-empty-title">No results</div><div class="tpgse-empty-desc">' + escapeHtml(d.message || 'No assessments matched.') + '</div></div>';
                    return;
                }
                if (!d.results || !d.results.length) {
                    box.innerHTML = '<div class="tpgse-empty"><div class="tpgse-empty-title">No assessments found</div><div class="tpgse-empty-desc">No records matched your search criteria.</div></div>';
                    return;
                }
                var html = '<div class="tpgse-table-wrap"><table class="tpgse-table"><thead><tr>'
                         + '<th>No.</th><th>Trainee Name</th><th>Email</th><th>Status</th><th>Last Marked</th>'
                         + '</tr></thead><tbody>';
                d.results.forEach(function(r, i){
                    html += '<tr>'
                         +    '<td>' + (i+1) + '</td>'
                         +    '<td>' + escapeHtml(r.name||'') + '</td>'
                         +    '<td>' + escapeHtml(r.email||'') + '</td>'
                         +    '<td>' + escapeHtml(r.status||'') + '</td>'
                         +    '<td>' + escapeHtml(r.updated_at||'—') + '</td>'
                         +  '</tr>';
                });
                html += '</tbody></table></div>';
                box.innerHTML = html;
            })
            .catch(function(err){
                box.innerHTML = '<div class="tpgse-empty"><div class="tpgse-empty-title">Network error</div><div class="tpgse-empty-desc">' + escapeHtml(err.message) + '</div></div>';
            });
    };
})();
</script>
<?php endif; ?>

