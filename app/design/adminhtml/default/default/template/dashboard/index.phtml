<script type="text/javascript">
(function(){
    var TPGCS_LIST_URL   = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/runSessionsLookup')) ?>;
    var TPGCS_DELETE_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/deleteCourseRun')) ?>;
    var TPGCS_FORM_KEY   = '<?php echo Mage::getSingleton('core/session')->getFormKey() ?>';
    function tpgcsEscape(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    function tpgcsFmtDate(iso){ if(!iso) return '—'; var p=String(iso).split('-'); return p.length===3 ? p[2]+'/'+p[1]+'/'+p[0] : iso; }
    function tpgcsFmtTime(t){ return t || '—'; }

    window.tpgcsFetch = function(){
        var input = document.getElementById('tpgcs-run-id');
        var box   = document.getElementById('tpgcs-result');
        var runId = input.value.trim();
        if (!runId) { alert('Enter a Course Run ID first.'); input.focus(); return; }
        box.style.display = 'block';
        box.style.whiteSpace = 'normal';
        box.style.fontFamily = 'inherit';
        box.style.padding = '0';
        box.style.background = 'transparent';
        box.style.border = 'none';
        box.innerHTML = '<div style="padding:18px;color:#94a3b8;font-size:14px;">Fetching sessions for run ' + tpgcsEscape(runId) + '…</div>';
        fetch(TPGCS_LIST_URL + '?run_id=' + encodeURIComponent(runId), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) {
                    box.innerHTML = '<div style="padding:18px;color:#f87171;font-size:14px;">' + tpgcsEscape(d.message || 'Course Run not found.') + '</div>';
                    return;
                }
                tpgcsRender(d.run);
            })
            .catch(function(err){
                box.innerHTML = '<div style="padding:18px;color:#f87171;font-size:14px;">Network error: ' + tpgcsEscape(err.message) + '</div>';
            });
    };

    window.tpgcsDeleteOne = function(optionTypeId, courseRef){
        if (!confirm('Delete session ' + optionTypeId + ' from ' + courseRef + '? This cannot be undone.')) return;
        var fd = new FormData();
        fd.append('form_key',  TPGCS_FORM_KEY);
        fd.append('course_ref', courseRef);
        fd.append('run_id',     optionTypeId);
        fetch(TPGCS_DELETE_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { alert(d.message || 'Delete failed'); return; }
                tpgcsFetch();
            })
            .catch(function(err){ alert('Network error: ' + err.message); });
    };
    window.tpgcsDeleteAll = function(courseRef, sessions){
        if (!confirm('Delete ALL ' + sessions.length + ' active sessions for ' + courseRef + '? This cannot be undone.')) return;
        var promises = sessions.map(function(s){
            var fd = new FormData();
            fd.append('form_key',  TPGCS_FORM_KEY);
            fd.append('course_ref', courseRef);
            fd.append('run_id',     s.option_type_id);
            return fetch(TPGCS_DELETE_URL, { method: 'POST', body: fd, credentials: 'same-origin' });
        });
        Promise.all(promises).then(function(){ tpgcsFetch(); });
    };

    function tpgcsRender(r){
        if (!r) return;
        var box = document.getElementById('tpgcs-result');
        var ses = r.sessions || [];

        var html = '<div class="tpgcs-banner">✓ <strong>' + tpgcsEscape(r.course_name) + '</strong> &mdash; ' + ses.length + ' session' + (ses.length===1?'':'s') + ' found</div>'
                 + '<div class="tpgcs-info">Synced to local DB: 0 inserted, ' + ses.length + ' updated</div>'
                 + '<div class="tpgcs-details-card" style="margin-top:18px">'
                 +   '<div class="tpgcs-details-title">COURSE RUN DETAILS</div>'
                 +   '<div class="tpgcs-details-grid">'
                 +     '<div><div class="tpgcs-detail-lbl">Course Reference</div><div class="tpgcs-detail-val">' + tpgcsEscape(r.course_code) + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Mode of Training</div><div class="tpgcs-detail-val">' + tpgcsEscape(r.mode_of_training || 'Classroom') + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Course Start</div><div class="tpgcs-detail-val">' + tpgcsFmtDate(r.start_date) + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Course End</div><div class="tpgcs-detail-val">' + tpgcsFmtDate(r.end_date) + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Venue</div><div class="tpgcs-detail-val">' + tpgcsEscape(r.venue || '—') + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Vacancy</div><div class="tpgcs-detail-val">' + tpgcsEscape(r.vacancy || 'Available') + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Admin Email</div><div class="tpgcs-detail-val">' + tpgcsEscape(r.admin_email || '—') + '</div></div>'
                 +     '<div><div class="tpgcs-detail-lbl">Registered</div><div class="tpgcs-detail-val">' + tpgcsEscape(String(r.registered || 0)) + '</div></div>'
                 +   '</div>'
                 + '</div>';

        if (!ses.length) {
            html += '<div class="tpgcs-empty-msg">No sessions scheduled for this course run yet.</div>';
        } else {
            var totalActive = ses.filter(function(s){ return s.status === 'Active'; }).length;
            html += '<div class="tpgcs-sessions-card">'
                 +   '<div class="tpgcs-sessions-head">'
                 +     '<h3 class="tpgcs-sessions-title">Sessions</h3>'
                 +     '<div class="tpgcs-sessions-count">' + ses.length + ' total · ' + totalActive + ' active</div>'
                 +   '</div>'
                 +   '<table class="tpgcs-sessions-table">'
                 +     '<thead><tr>'
                 +       '<th>#</th><th>Session ID</th><th>Date</th><th>Time</th><th>Mode</th>'
                 +       '<th>Attendance</th><th>Status</th><th>Action</th>'
                 +     '</tr></thead><tbody>';
            ses.forEach(function(s, i){
                var attClass = s.attendance_taken ? 'tpgcs-pill-taken' : 'tpgcs-pill-nottaken';
                var attLabel = s.attendance_taken ? 'Taken' : 'Not Taken';
                html += '<tr>'
                     +   '<td>' + (i+1) + '</td>'
                     +   '<td>' + tpgcsEscape(s.session_id) + '</td>'
                     +   '<td>' + tpgcsFmtDate(s.date) + '</td>'
                     +   '<td>' + tpgcsFmtTime(s.start_time) + ' &ndash; ' + tpgcsFmtTime(s.end_time) + '</td>'
                     +   '<td>' + tpgcsEscape(s.mode) + '</td>'
                     +   '<td><span class="tpgcs-pill ' + attClass + '">' + attLabel + '</span></td>'
                     +   '<td><span class="tpgcs-pill tpgcs-pill-active">' + tpgcsEscape(s.status) + '</span></td>'
                     +   '<td><button type="button" class="tpgcs-del" onclick="tpgcsDeleteOne(' + s.option_type_id + ',\'' + tpgcsEscape(r.course_code) + '\')">Delete</button></td>'
                     + '</tr>';
            });
            html += '</tbody></table>'
                 +   '<div class="tpgcs-foot">'
                 +     '<div class="tpgcs-foot-note">' + totalActive + ' active sessions will be deleted</div>'
                 +     '<button type="button" class="tpgcs-del-all" onclick=\'tpgcsDeleteAll("' + tpgcsEscape(r.course_code) + '", ' + JSON.stringify(ses).replace(/\'/g,'\\\'') + ')\'>Delete All ' + totalActive + ' Sessions</button>'
                 +   '</div>'
                 + '</div>';
        }
        box.innerHTML = html;
    }
})();
</script>
<?php endif; ?>

