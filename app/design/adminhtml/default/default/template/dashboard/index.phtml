.dash-kpi-card{background:#1f2937;border:1px solid var(--b1);border-radius:12px;padding:28px 24px;text-align:center}
.dash-kpi-num{font-size:42px;font-weight:700;color:#22d3ee;line-height:1.1;margin-bottom:8px}
.dash-kpi-lbl{font-size:14px;color:var(--t2);font-weight:500}
.dash-search-wrap{background:#1f2937;border:1px solid var(--b1);border-radius:12px;padding:24px}
.dash-search-label{font-size:13px;color:#94a3b8;margin-bottom:10px}
