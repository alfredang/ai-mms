<script type="text/javascript">
(function(){
    function applyRole(role) {
        var admin = document.getElementById('dashboard-admin-view');
        var learner = document.getElementById('dashboard-learner-view');
        var suffix = document.querySelector('.head-role-suffix');
        var isAdmin = (role === 'Super Admin' || role === 'Admin' || role === 'Training Provider' || role === 'Marketing');
        if (admin) admin.style.display = isAdmin ? '' : 'none';
        if (learner) learner.style.display = isAdmin ? 'none' : '';
        if (suffix) suffix.textContent = '— ' + role;
    }
    var role = 'Admin';
    try {
        var saved = localStorage.getItem('adminViewAs');
        if (saved) role = saved;
    } catch(e) {}
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function(){ applyRole(role); });
    } else {
        applyRole(role);
    }
    window.__applyDashboardRole = applyRole;
})();
</script>

