        <script type="text/javascript">
        (function(){
            window.TPGAT_PRODUCT_ID = <?php echo (int)$_atEditCourse['product_id'] ?>;
            window.TPGAT_TRAINER_IDS = <?php echo json_encode(array_values(array_map('intval', (array)$_atEditCourse['trainer_ids']))) ?>;
            window.TPGAT_SAVE_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/save')) ?>;
            window.TPGAT_TRAINER_MAP = <?php
                $_map = array();
                foreach ($_atTrainerOptions as $_o) { $_map[strtolower(trim($_o['value']))] = (int)$_o['option_id']; }
                echo json_encode($_map);
            ?>;
        })();

        function tpgatSwitchMode(mode){
            document.getElementById('tpgat-mode-list').classList.toggle('active', mode==='list');
            document.getElementById('tpgat-mode-manual').classList.toggle('active', mode==='manual');
            document.getElementById('tpgat-add-list').style.display   = mode==='list'   ? 'flex' : 'none';
            document.getElementById('tpgat-add-manual').style.display = mode==='manual' ? 'flex' : 'none';
        }

        function tpgatShowMsg(text, kind){
            var el = document.getElementById('tpgat-edit-msg');
            el.textContent = text;
            el.className = 'tpgat-msg ' + (kind === 'err' ? 'err' : 'ok');
            if (kind !== 'err') setTimeout(function(){ el.className = 'tpgat-msg'; }, 4000);
        }

        function tpgatPostTrainerIds(ids, onDone){
            var fd = new FormData();
            fd.append('course_id', window.TPGAT_PRODUCT_ID);
            fd.append('trainer_ids', ids.join(','));
            fd.append('form_key', (window.FORM_KEY || ''));
            fetch(window.TPGAT_SAVE_URL, { method: 'POST', body: fd, credentials: 'same-origin', redirect: 'manual' })
                .then(function(r){ onDone(true); })
                .catch(function(){ onDone(false); });
        }

        function tpgatAddFromList(){
            var input = document.getElementById('tpgat-list-input');
            var name  = (input.value || '').trim();
            if (!name) { tpgatShowMsg('Pick a trainer from the list first.', 'err'); return; }
            var key = name.toLowerCase();
            var optId = window.TPGAT_TRAINER_MAP[key];
            if (!optId) { tpgatShowMsg('"' + name + '" is not in the trainer list — switch to "Enter manually" to add a free-form name.', 'err'); return; }
            if (window.TPGAT_TRAINER_IDS.indexOf(optId) !== -1) { tpgatShowMsg(name + ' is already assigned.', 'err'); return; }
            var newIds = window.TPGAT_TRAINER_IDS.slice(); newIds.push(optId);
            tpgatPostTrainerIds(newIds, function(ok){
                if (!ok) { tpgatShowMsg('Save failed — try again.', 'err'); return; }
                tpgatShowMsg(name + ' added. Reloading…', 'ok');
                setTimeout(function(){ window.location.reload(); }, 600);
            });
        }

        function tpgatAddManual(){
            var input = document.getElementById('tpgat-manual-input');
            var name = (input.value || '').trim();
            if (!name) { tpgatShowMsg('Enter a trainer name first.', 'err'); return; }
            var key = name.toLowerCase();
            var optId = window.TPGAT_TRAINER_MAP[key];
            if (optId) {
                if (window.TPGAT_TRAINER_IDS.indexOf(optId) !== -1) { tpgatShowMsg(name + ' is already assigned.', 'err'); return; }
                var newIds = window.TPGAT_TRAINER_IDS.slice(); newIds.push(optId);
                tpgatPostTrainerIds(newIds, function(ok){
                    if (!ok) { tpgatShowMsg('Save failed — try again.', 'err'); return; }
                    tpgatShowMsg(name + ' added. Reloading…', 'ok');
                    setTimeout(function(){ window.location.reload(); }, 600);
                });
            } else {
                tpgatShowMsg('"' + name + '" is not in the structured trainer list yet. Use "Select from list" — bulk creation of new trainer options is a separate workflow.', 'err');
            }
        }

        function tpgatRemoveOne(btn){
            var row = btn.closest('.tpgat-trainer-row');
            var tid = parseInt(row.getAttribute('data-trainer-id'), 10);
            var name = row.getAttribute('data-trainer-name') || 'Trainer';
            if (!tid) { tpgatShowMsg(name + ' came from legacy text — remove via the course editor.', 'err'); return; }
            var newIds = window.TPGAT_TRAINER_IDS.filter(function(x){ return x !== tid; });
            if (!confirm('Remove ' + name + ' from this class?')) return;
            tpgatPostTrainerIds(newIds, function(ok){
                if (!ok) { tpgatShowMsg('Save failed — try again.', 'err'); return; }
                tpgatShowMsg(name + ' removed. Reloading…', 'ok');
                setTimeout(function(){ window.location.reload(); }, 600);
            });
        }

        function tpgatRemoveAll(){
            if (!window.TPGAT_TRAINER_IDS.length) return;
            if (!confirm('Remove ALL assigned trainers from this class?')) return;
            tpgatPostTrainerIds([], function(ok){
                if (!ok) { tpgatShowMsg('Save failed — try again.', 'err'); return; }
                tpgatShowMsg('All trainers removed. Reloading…', 'ok');
                setTimeout(function(){ window.location.reload(); }, 600);
            });
        }
        </script>
