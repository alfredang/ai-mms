<script type="text/javascript">
(function(){
    var TPGSA_LOOKUP_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/sessionAttendanceLookup')) ?>;
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}
    window.tpgsaClear = function(){
        ['tpgsa-course-code','tpgsa-session-id','tpgsa-run-id'].forEach(function(id){
            var el = document.getElementById(id); if (el) el.value = '';
        });
        var box = document.getElementById('tpgsa-result');
        if (box) { box.textContent=''; box.style.display='none'; }
    };
    window.tpgsaFetch = function(){
        var box = document.getElementById('tpgsa-result');
        var uen = val('tpgsa-uen');
        var code = val('tpgsa-course-code');
        var sid = val('tpgsa-session-id');
        var run = val('tpgsa-run-id');
        if (!run && !sid && !code) {
            alert('Enter at least Course Run ID, Session ID, or Course Code.');
            return;
        }
        box.style.display = 'block';
        box.textContent = 'Fetching attendance…';
        var qs = 'uen=' + encodeURIComponent(uen)
               + '&course_code=' + encodeURIComponent(code)
               + '&session_id=' + encodeURIComponent(sid)
               + '&run_id=' + encodeURIComponent(run);
        fetch(TPGSA_LOOKUP_URL + '?' + qs, { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { box.textContent = d.message || 'No attendance found.'; return; }
                box.textContent = JSON.stringify(d, null, 2);
            })
            .catch(function(err){ box.textContent = 'Network error: ' + err.message; });
    };
})();
</script>
