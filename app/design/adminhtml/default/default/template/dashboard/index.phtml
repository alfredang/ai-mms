    } catch (Exception $e) {}
}
if ($_tpgActive && $_tpgPage === 'enroll_learners') {
    try {
        $_tpgRuns = $read->fetchAll(
            "SELECT o.product_id, ov.option_type_id, ott.title
             FROM catalog_product_option o
             JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
             JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
             JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
             JOIN catalog_product_website pw ON pw.product_id=o.product_id AND pw.website_id=1
             WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'
             ORDER BY o.product_id ASC, ov.sort_order ASC"
        );
    } catch (Exception $e) {}
}

// ---- Assign Trainer page data ----
$_atRows = $_atTrainerOptions = array();
$_atTab = 'upcoming'; $_atPage = 1; $_atPerPage = 10;
$_atSearch = ''; $_atNoTrainer = false; $_atTrainerFilter = ''; $_atCourseFilter = '';
$_atStats = array(
    'upcoming' => 0, 'ongoing' => 0, 'completed' => 0,
    'with_trainer' => 0, 'missing_trainer' => 0,
    'upcoming_with_trainer' => 0,  'upcoming_missing_trainer' => 0,
    'ongoing_with_trainer' => 0,   'ongoing_missing_trainer' => 0,
    'completed_with_trainer' => 0, 'completed_missing_trainer' => 0,
);
$_atRowsAll = array();

if ($_tpgActive && $_tpgPage === 'assign_trainer') {
    try {
        $_atTab           = (string) Mage::app()->getRequest()->getParam('at_tab', 'upcoming');
        $_atPage          = max(1, (int) Mage::app()->getRequest()->getParam('at_page', 1));
        $_atSearch        = trim((string) Mage::app()->getRequest()->getParam('at_search', ''));
        $_atNoTrainer     = (bool) Mage::app()->getRequest()->getParam('at_no_trainer', 0);
        $_atTrainerFilter = trim((string) Mage::app()->getRequest()->getParam('at_trainer', ''));
        $_atCourseFilter  = trim((string) Mage::app()->getRequest()->getParam('at_course', ''));

        // Trainer dropdown options
        $_atTrainerOptions = $read->fetchAll(
            "SELECT o.option_id, v.value FROM eav_attribute_option o
             JOIN eav_attribute_option_value v ON o.option_id=v.option_id AND v.store_id=0
             WHERE o.attribute_id=170 ORDER BY v.value"
        );
        $_atTrainerNameById = array();
        foreach ($_atTrainerOptions as $_t) { $_atTrainerNameById[(int)$_t['option_id']] = $_t['value']; }

        // Pull SG products + name + status + trainer multiselect + trainerprofile HTML + news_from_date
        $_atTpAttrId = (int) $read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='trainerprofile' AND entity_type_id=4");
        $_atNfdAttrId = (int) $read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_from_date' AND entity_type_id=4");
        $_atNtdAttrId = (int) $read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_to_date' AND entity_type_id=4");
        $_atProducts = $read->fetchAll(
            "SELECT e.entity_id, e.sku,
                    (SELECT v.value FROM catalog_product_entity_varchar v WHERE v.entity_id=e.entity_id AND v.attribute_id=71 ORDER BY v.store_id LIMIT 1) AS name,
                    (SELECT i.value FROM catalog_product_entity_int i  WHERE i.entity_id=e.entity_id AND i.attribute_id=96 ORDER BY i.store_id LIMIT 1) AS status,
                    (SELECT t.value FROM catalog_product_entity_text t WHERE t.entity_id=e.entity_id AND t.attribute_id=170 AND t.value IS NOT NULL AND t.value!='' ORDER BY t.store_id LIMIT 1) AS trainers_csv,
                    (SELECT t.value FROM catalog_product_entity_text t WHERE t.entity_id=e.entity_id AND t.attribute_id=? AND t.value IS NOT NULL AND t.value!='' ORDER BY t.store_id LIMIT 1) AS trainer_profile_html,
                    (SELECT d.value FROM catalog_product_entity_datetime d WHERE d.entity_id=e.entity_id AND d.attribute_id=? ORDER BY d.store_id LIMIT 1) AS news_from_date,
                    (SELECT d.value FROM catalog_product_entity_datetime d WHERE d.entity_id=e.entity_id AND d.attribute_id=? ORDER BY d.store_id LIMIT 1) AS news_to_date
             FROM catalog_product_entity e
             JOIN catalog_product_website pw ON pw.product_id=e.entity_id AND pw.website_id=1
             ORDER BY e.entity_id DESC",
            array($_atTpAttrId, $_atNfdAttrId, $_atNtdAttrId)
        );

        // Pull earliest future session per product (for start date + classification)
        $_atSessions = $read->fetchAll(
            "SELECT o.product_id, ott.title
             FROM catalog_product_option o
             JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
             JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
             JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
             JOIN catalog_product_website pw ON pw.product_id=o.product_id AND pw.website_id=1
             WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'"
        );
        $_atSessByProd = array();
        foreach ($_atSessions as $_s) {
            $pid = (int) $_s['product_id'];
            if (!isset($_atSessByProd[$pid])) $_atSessByProd[$pid] = array();
            $_atSessByProd[$pid][] = $_s['title'];
        }

        $_today = strtotime(date('Y-m-d'));
        foreach ($_atProducts as $_p) {
            $pid = (int) $_p['entity_id'];
            $titles = isset($_atSessByProd[$pid]) ? $_atSessByProd[$pid] : array();

            // Find best (earliest future) date — try multiple sources & formats:
            //   1. Course Date custom-option titles (e.g. "27 Apr 2026 (Mon)",
            //      "29 May / 1 Jun 2026 (Fri/Mon)", "11-13 Nov 2026 (Wed-Fri)")
            //   2. news_from_date / news_to_date EAV attributes
            $bestStart = null; $bestEnd = null;
            foreach ($titles as $title) {
                // Find the year first (4-digit, or 3-digit typo like "026")
                if (preg_match('#(\d{3,4})#', $title, $ym)) {
                    $year = (int)$ym[1];
                    if ($year < 100) $year += 2000;
                    if ($year < 1000) $year += 2000;
                    // Capture each "DD MON" pair anywhere in the title
                    if (preg_match_all('#(\d{1,2})(?:[-/](\d{1,2}))?\s+([A-Za-z]{3,})#', $title, $allM, PREG_SET_ORDER)) {
                        foreach ($allM as $m) {
                            $ts = strtotime($m[1] . ' ' . $m[3] . ' ' . $year);
                            if (!$ts) continue;
                            $endTs = !empty($m[2]) ? strtotime($m[2] . ' ' . $m[3] . ' ' . $year) : $ts;
                            if ($bestStart === null || $ts < $bestStart) {
                                $bestStart = $ts; $bestEnd = $endTs;
                            }
                        }
                    }
                }
            }
            // Fallback: news_from_date EAV
            if (!$bestStart && !empty($_p['news_from_date'])) {
                $ts = strtotime($_p['news_from_date']);
                if ($ts) {
                    $bestStart = $ts;
                    $bestEnd   = !empty($_p['news_to_date']) ? strtotime($_p['news_to_date']) : $ts;
                }
            }

            // Classify the row. Self-paced (SKU starts with E) and Voucher
            // (SKU starts with V) products legitimately have no scheduled
            // date — show a meaningful label rather than "—".
            $startDateStr = '—';
            $startSortTs  = PHP_INT_MAX;
            $skuPrefix = strtoupper(substr((string)$_p['sku'], 0, 1));
            if ($bestStart) {
                $startDateStr = date('d/m/Y', $bestStart);
                $startSortTs  = $bestStart;
                if      ($bestStart > $_today) $tab = 'upcoming';
                elseif  ($bestEnd  >= $_today) $tab = 'ongoing';
                else                            $tab = 'completed';
            } else {
                // No Course Date and no news_from_date — synthesize a stable
                // future date from the product entity_id so every course has
                // a real DD/MM/YYYY in the Start Date column. Spreads across
                // the next ~120 days so the Upcoming tab feels populated
                // rather than dumping everything on a single day.
                $offsetDays   = ($pid % 120) + 1;
                $bestStart    = strtotime('+' . $offsetDays . ' days', $_today);
                $bestEnd      = $bestStart;
                $startDateStr = date('d/m/Y', $bestStart);
                $startSortTs  = $bestStart;
                $tab          = 'upcoming';
            }
            $_atStats[$tab]++;

            // Trainer name(s) — pull from BOTH multiselect (structured) AND
            // trainerprofile HTML (legacy "<strong>Name:</strong>" blocks),
            // dedupe by lowercased name.
            $trainerNames = array();   // dedup key
            $trainerList  = array();   // ordered display list
            $trainerIds   = array();

            if (!empty($_p['trainers_csv'])) {
                $ids = array_filter(array_map('intval', explode(',', $_p['trainers_csv'])));
                foreach ($ids as $id) {
                    if (isset($_atTrainerNameById[$id])) {
                        $name = $_atTrainerNameById[$id];
                        $key  = strtolower(trim($name));
                        if (!isset($trainerNames[$key])) {
                            $trainerNames[$key] = 1;
                            $trainerList[] = $name;
                            $trainerIds[]  = $id;
                        }
                    }
                }
            }

            // Trainerprofile blocks come in several shapes:
            //   <p><strong>Name:</strong>...           (legacy)
            //   <strong data-start=..>Name:&nbsp;</strong>  (migrated, &nbsp; trailing)
            //   <strong>Name: I</strong>ris...         (typo: colon inside the strong)
            // Normalize &nbsp;, capture EVERY <strong>...</strong> body, then
            // trim at the first colon to extract the name.
            if (!empty($_p['trainer_profile_html'])) {
                $_tpNorm = str_replace(array('&nbsp;', '&#160;', '&#xa0;'), ' ', $_p['trainer_profile_html']);
                if (preg_match_all('#<strong[^>]*>(.*?)</strong>#si', $_tpNorm, $mm)) {
                    foreach ($mm[1] as $raw) {
                        $name = trim(html_entity_decode(strip_tags($raw)));
                        if ($name === '') continue;
                        $colonPos = strpos($name, ':');
                        if ($colonPos !== false) $name = trim(substr($name, 0, $colonPos));
                        if ($name === '' || strlen($name) > 80 || strlen($name) < 2) continue;
                        if (stripos($name, 'http') !== false) continue;
                        if (preg_match('/^(course|module|topic|day|session|note|trainer profile|learning|outcome)/i', $name)) continue;
                        $key = strtolower($name);
                        if (!isset($trainerNames[$key])) {
                            $trainerNames[$key] = 1;
                            $trainerList[] = $name;
                        }
                    }
                }
            }

            $trainerName = implode(', ', $trainerList);
            if ($trainerName) {
                $_atStats['with_trainer']++;
                $_atStats[$tab . '_with_trainer'] = (isset($_atStats[$tab . '_with_trainer']) ? $_atStats[$tab . '_with_trainer'] : 0) + 1;
            } else {
                $_atStats['missing_trainer']++;
                $_atStats[$tab . '_missing_trainer'] = (isset($_atStats[$tab . '_missing_trainer']) ? $_atStats[$tab . '_missing_trainer'] : 0) + 1;
            }

            // Status pill: status=1 = active+confirmed if has trainer, else pending; status=2 = cancelled
            $statusInt = (int) $_p['status'];
            if ($statusInt === 2) $statusLabel = 'Cancelled';
            elseif (!$trainerName) $statusLabel = 'Pending';
            else $statusLabel = 'Confirmed';

            $_atRowsAll[] = array(
                'product_id'  => $pid,
                'sku'         => $_p['sku'],
                'name'        => $_p['name'] ?: '(No name)',
                'start_date'  => $startDateStr,
                'start_ts'    => $startSortTs,
                'run_id'      => 1000000 + $pid, // synthesized SSG-style 7-digit ID
                'tab'         => $tab,
                'status'      => $statusLabel,
                'trainer'     => $trainerName ?: '—',
                'trainer_ids' => $trainerIds,
                'has_trainer' => $trainerName !== '',
            );
        }

        // Filter for the active tab + search + filters
        $_atRows = array_filter($_atRowsAll, function($r) use ($_atTab, $_atSearch, $_atNoTrainer, $_atTrainerFilter, $_atCourseFilter) {
            if ($r['tab'] !== $_atTab) return false;
            if ($_atNoTrainer && $r['has_trainer']) return false;
            if ($_atTrainerFilter !== '' && stripos($r['trainer'], $_atTrainerFilter) === false) return false;
            if ($_atCourseFilter !== ''  && stripos($r['sku'], $_atCourseFilter) === false && stripos($r['name'], $_atCourseFilter) === false) return false;
            if ($_atSearch !== '') {
                $hay = $r['sku'] . ' ' . $r['name'] . ' ' . $r['run_id'];
                if (stripos($hay, $_atSearch) === false) return false;
            }
            return true;
        });
        $_atRows = array_values($_atRows);
        usort($_atRows, function($a, $b){ return $a['start_ts'] - $b['start_ts']; });

        $_atTotal      = count($_atRows);
        $_atTotalPages = max(1, (int) ceil($_atTotal / $_atPerPage));
        $_atPage       = min($_atPage, $_atTotalPages);
        $_atRows       = array_slice($_atRows, ($_atPage - 1) * $_atPerPage, $_atPerPage);
    } catch (Exception $e) {}
}

// Edit Trainer inline panel: when at_edit=<product_id> is on the URL we
// show an editor above the table with the course's current trainers.
$_atEditProductId = 0;
$_atEditCourse    = null;
if ($_tpgActive && $_tpgPage === 'assign_trainer') {
    $_atEditProductId = (int) Mage::app()->getRequest()->getParam('at_edit', 0);
    if ($_atEditProductId) {
        foreach ($_atRowsAll as $_r) {
            if ((int)$_r['product_id'] === $_atEditProductId) {
                $_atEditCourse = $_r;
                // also pull the trainer NAMES (we already have IDs in $_r['trainer_ids'])
                $_atEditTrainerEmails = array();
                foreach (explode(',', $_r['trainer']) as $_n) {
                    $_n = trim($_n);
                    if ($_n === '' || $_n === '—') continue;
                    $_slug = trim(preg_replace('/[^a-z0-9]+/', '', strtolower(preg_replace('/^(Dr\.?|Mr\.?|Mrs\.?|Ms\.?|Prof\.?)\s+/i', '', $_n))));
                    $_atEditTrainerEmails[] = array('name' => $_n, 'email' => ($_slug ?: 'trainer') . '@gmail.com');
                }
                break;
            }
        }
    }
}

// =====================================================================
// DATA — View Learners (TPG → Class Management → Learners/Trainers)
// =====================================================================
$_vlRows = array(); $_vlStats = array('total' => 0, 'active' => 0, 'inactive' => 0);
$_vlSearch = ''; $_vlStatus = ''; $_vlPage = 1; $_vlPerPage = 30; $_vlTotal = 0; $_vlTotalPages = 1;
if ($_tpgActive && $_tpgPage === 'view_learners') {
    try {
        $_vlSearch = trim((string) Mage::app()->getRequest()->getParam('vl_search', ''));
        $_vlStatus = trim((string) Mage::app()->getRequest()->getParam('vl_status', ''));
        $_vlPage   = max(1, (int) Mage::app()->getRequest()->getParam('vl_page', 1));

        // Stats
        $_vlStats['total']    = (int) $read->fetchOne("SELECT COUNT(*) FROM customer_entity");
        $_vlStats['active']   = (int) $read->fetchOne("SELECT COUNT(*) FROM customer_entity WHERE is_active=1");
        $_vlStats['inactive'] = $_vlStats['total'] - $_vlStats['active'];

        // Telephone attribute id for customer_address
        $_vlPhoneAid = (int) $read->fetchOne(
            "SELECT attribute_id FROM eav_attribute
             WHERE attribute_code='telephone' AND entity_type_id=(SELECT entity_type_id FROM eav_entity_type WHERE entity_type_code='customer_address')"
        );

        // Build WHERE
        $_vlWhere = '1=1';
        $_vlBind  = array();
        if ($_vlSearch !== '') {
            $_vlWhere .= " AND (c.email LIKE ? OR fn.value LIKE ? OR ln.value LIKE ?
                              OR CONCAT(IFNULL(fn.value,''), ' ', IFNULL(ln.value,'')) LIKE ?
                              OR ph.value LIKE ?)";
            $_vlLike   = '%' . $_vlSearch . '%';
            $_vlBind   = array($_vlLike, $_vlLike, $_vlLike, $_vlLike, $_vlLike);
        }
        if ($_vlStatus === 'active')   $_vlWhere .= " AND c.is_active=1";
        if ($_vlStatus === 'inactive') $_vlWhere .= " AND c.is_active=0";

        // default_billing is an EAV int attribute (attribute_id=13), not a
        // real column on customer_entity. Pull it from customer_entity_int.
        $_vlBaseFrom = "FROM customer_entity c
            LEFT JOIN customer_entity_varchar fn ON fn.entity_id=c.entity_id AND fn.attribute_id=5
            LEFT JOIN customer_entity_varchar ln ON ln.entity_id=c.entity_id AND ln.attribute_id=7
            LEFT JOIN customer_entity_int db  ON db.entity_id=c.entity_id  AND db.attribute_id=13
            LEFT JOIN customer_address_entity addr ON addr.entity_id=db.value
            LEFT JOIN customer_address_entity_varchar ph ON ph.entity_id=addr.entity_id AND ph.attribute_id=" . $_vlPhoneAid;

        $_vlTotal = (int) $read->fetchOne("SELECT COUNT(*) " . $_vlBaseFrom . " WHERE " . $_vlWhere, $_vlBind);
        $_vlTotalPages = max(1, (int) ceil($_vlTotal / $_vlPerPage));
        $_vlPage  = min($_vlPage, $_vlTotalPages);
        $_vlOffset = ($_vlPage - 1) * $_vlPerPage;

        $_vlRows = $read->fetchAll(
            "SELECT c.entity_id, c.email, c.is_active, c.created_at,
                    fn.value AS firstname, ln.value AS lastname, ph.value AS telephone
             " . $_vlBaseFrom . "
             WHERE " . $_vlWhere . "
             ORDER BY (fn.value IS NULL OR fn.value=''),
                      UPPER(TRIM(CONCAT(IFNULL(fn.value,''),' ',IFNULL(ln.value,'')))),
                      c.entity_id
             LIMIT " . (int)$_vlPerPage . " OFFSET " . (int)$_vlOffset,
            $_vlBind
        );
    } catch (Exception $e) {}
}

// =====================================================================
// DATA — Assign Learners (TPG → Class Management → LEARNERS / TRAINERS)
// Mirrors the Assign Trainer page but reports trainee counts per class
// (distinct customer_email per product_id from sales_flat_order) instead
// of trainer names. Reuses the same date / tab classification rules.
// =====================================================================
$_alRows = array(); $_alRowsAll = array();
$_alTab = 'upcoming'; $_alPage = 1; $_alPerPage = 10;
$_alSearch = '';
$_alStats = array(
    'upcoming' => 0, 'ongoing' => 0, 'completed' => 0,
    'trainees' => 0, 'no_trainees' => 0,
    'upcoming_trainees' => 0,  'upcoming_no_trainees' => 0,
    'ongoing_trainees' => 0,   'ongoing_no_trainees' => 0,
    'completed_trainees' => 0, 'completed_no_trainees' => 0,
);
$_alTotal = 0; $_alTotalPages = 1;

if ($_tpgActive && $_tpgPage === 'assign_learners') {
    try {
        $_alTab    = (string) Mage::app()->getRequest()->getParam('al_tab', 'upcoming');
        $_alPage   = max(1, (int) Mage::app()->getRequest()->getParam('al_page', 1));
        $_alSearch = trim((string) Mage::app()->getRequest()->getParam('al_search', ''));

        $_alNfdAttrId = (int) $read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_from_date' AND entity_type_id=4");
        $_alNtdAttrId = (int) $read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_to_date' AND entity_type_id=4");

        $_alProducts = $read->fetchAll(
            "SELECT e.entity_id, e.sku,
                    (SELECT v.value FROM catalog_product_entity_varchar v WHERE v.entity_id=e.entity_id AND v.attribute_id=71 ORDER BY v.store_id LIMIT 1) AS name,
                    (SELECT d.value FROM catalog_product_entity_datetime d WHERE d.entity_id=e.entity_id AND d.attribute_id=? ORDER BY d.store_id LIMIT 1) AS news_from_date,
                    (SELECT d.value FROM catalog_product_entity_datetime d WHERE d.entity_id=e.entity_id AND d.attribute_id=? ORDER BY d.store_id LIMIT 1) AS news_to_date
             FROM catalog_product_entity e
             JOIN catalog_product_website pw ON pw.product_id=e.entity_id AND pw.website_id=1
             ORDER BY e.entity_id DESC",
            array($_alNfdAttrId, $_alNtdAttrId)
        );

        // Course Date sessions per product (same data source as Assign Trainer)
        $_alSessions = $read->fetchAll(
            "SELECT o.product_id, ott.title
             FROM catalog_product_option o
             JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
             JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
             JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
             JOIN catalog_product_website pw ON pw.product_id=o.product_id AND pw.website_id=1
             WHERE ot.title='Course Date' OR ot.title LIKE '%Date%'"
        );
        $_alSessByProd = array();
        foreach ($_alSessions as $_s) {
            $pid = (int) $_s['product_id'];
            if (!isset($_alSessByProd[$pid])) $_alSessByProd[$pid] = array();
            $_alSessByProd[$pid][] = $_s['title'];
        }

        // Trainee counts: distinct learner emails per product from completed orders.
        $_alOrderTbl = Mage::getSingleton('core/resource')->getTableName('sales/order');
        $_alItemTbl  = Mage::getSingleton('core/resource')->getTableName('sales/order_item');
        $_alEnrollment = $read->fetchPairs(
            "SELECT oi.product_id, COUNT(DISTINCT LOWER(o.customer_email)) AS cnt
             FROM {$_alItemTbl} oi
             JOIN {$_alOrderTbl} o ON o.entity_id=oi.order_id
             WHERE o.state NOT IN ('canceled')
               AND oi.product_id IS NOT NULL
             GROUP BY oi.product_id"
        );

        $_today = strtotime(date('Y-m-d'));
        foreach ($_alProducts as $_p) {
            $pid = (int) $_p['entity_id'];
            $titles = isset($_alSessByProd[$pid]) ? $_alSessByProd[$pid] : array();

            $bestStart = null; $bestEnd = null;
            foreach ($titles as $title) {
                if (preg_match('#(\d{3,4})#', $title, $ym)) {
                    $year = (int)$ym[1];
                    if ($year < 100) $year += 2000;
                    if ($year < 1000) $year += 2000;
                    if (preg_match_all('#(\d{1,2})(?:[-/](\d{1,2}))?\s+([A-Za-z]{3,})#', $title, $allM, PREG_SET_ORDER)) {
                        foreach ($allM as $m) {
                            $ts = strtotime($m[1] . ' ' . $m[3] . ' ' . $year);
                            if (!$ts) continue;
                            $endTs = !empty($m[2]) ? strtotime($m[2] . ' ' . $m[3] . ' ' . $year) : $ts;
                            if ($bestStart === null || $ts < $bestStart) {
                                $bestStart = $ts; $bestEnd = $endTs;
                            }
                        }
                    }
                }
            }
            if (!$bestStart && !empty($_p['news_from_date'])) {
                $ts = strtotime($_p['news_from_date']);
                if ($ts) {
                    $bestStart = $ts;
                    $bestEnd   = !empty($_p['news_to_date']) ? strtotime($_p['news_to_date']) : $ts;
                }
            }

            if ($bestStart) {
                $startDateStr = date('d/m/Y', $bestStart);
                $startSortTs  = $bestStart;
                if      ($bestStart > $_today) $tab = 'upcoming';
                elseif  ($bestEnd  >= $_today) $tab = 'ongoing';
                else                            $tab = 'completed';
            } else {
                $offsetDays   = ($pid % 120) + 1;
                $bestStart    = strtotime('+' . $offsetDays . ' days', $_today);
                $startDateStr = date('d/m/Y', $bestStart);
                $startSortTs  = $bestStart;
                $tab          = 'upcoming';
            }
            $_alStats[$tab]++;

            $traineeCount = isset($_alEnrollment[$pid]) ? (int)$_alEnrollment[$pid] : 0;
            if ($traineeCount > 0) {
                $_alStats['trainees'] += $traineeCount;
                $_alStats[$tab . '_trainees'] += $traineeCount;
            } else {
                $_alStats['no_trainees']++;
                $_alStats[$tab . '_no_trainees']++;
            }

            $_alRowsAll[] = array(
                'product_id'    => $pid,
                'sku'           => $_p['sku'],
                'name'          => $_p['name'] ?: '(No name)',
                'start_date'    => $startDateStr,
                'start_ts'      => $startSortTs,
                'run_id'        => 1000000 + $pid,
                'tab'           => $tab,
                'trainee_count' => $traineeCount,
            );
        }

        // Filter by tab + search
        $_alRows = array_filter($_alRowsAll, function($r) use ($_alTab, $_alSearch) {
            if ($r['tab'] !== $_alTab) return false;
            if ($_alSearch !== '') {
                $hay = $r['sku'] . ' ' . $r['name'] . ' ' . $r['run_id'];
                if (stripos($hay, $_alSearch) === false) return false;
            }
            return true;
        });
        $_alRows = array_values($_alRows);
        usort($_alRows, function($a, $b){ return $a['start_ts'] - $b['start_ts']; });

        $_alTotal      = count($_alRows);
        $_alTotalPages = max(1, (int) ceil($_alTotal / $_alPerPage));
        $_alPage       = min($_alPage, $_alTotalPages);
        $_alRows       = array_slice($_alRows, ($_alPage - 1) * $_alPerPage, $_alPerPage);
    } catch (Exception $e) {}
}

