<script type="text/javascript">
window.__trnAddUrl   = <?php echo json_encode($trnAddUrl) ?>;
window.__trnEditUrl  = <?php echo json_encode($trnEditUrl) ?>;
window.__trnBulkUrl  = <?php echo json_encode($trnBulkUrl) ?>;
window.__trnFormKey  = <?php echo json_encode($_adminFormKey) ?>;

window.trnOpenAddModal = function() {
    var ov = document.getElementById('trnAddOverlay');
    if (ov) ov.style.display = 'flex';
};
window.trnCloseAddModal = function() {
    var ov = document.getElementById('trnAddOverlay');
    if (ov) ov.style.display = 'none';
    var msg = document.getElementById('trnAddMsg');
    if (msg) { msg.style.display = 'none'; msg.textContent = ''; }
};
// ---- Edit trainer modal ----
window._trnEditId = 0;
window.trnOpenEditModal = function(id, data) {
    window._trnEditId = id;
    var ov = document.getElementById('trnAddOverlay');
    if (!ov) return;
    // Re-use the Add modal — change title and button
    var title = ov.querySelector('h2');
    if (title) title.textContent = 'Edit Trainer';
    var btn = document.getElementById('trnAddBtn');
    if (btn) { btn.textContent = 'Save Changes'; btn.setAttribute('data-mode', 'edit'); }
    // Pre-fill fields
    var f = function(id, val) { var el = document.getElementById(id); if (el) el.value = val || ''; };
    f('trnEmail', data.email);
    f('trnName', data.name);
    f('trnTel', data.phone);
    f('trnLinkedin', data.linkedin);
    // Dropdowns
    var setSelect = function(id, val) { var el = document.getElementById(id); if (!el) return; for (var i=0; i<el.options.length; i++) { if (el.options[i].value === val) { el.selectedIndex = i; return; } } };
    setSelect('trnType', data.type);
    setSelect('trnStatus', data.status);
    setSelect('trnGender', data.gender);
    ov.style.display = 'flex';
};
window.trnCloseAddModal_orig = window.trnCloseAddModal;
window.trnCloseAddModal = function() {
    window._trnEditId = 0;
    var ov = document.getElementById('trnAddOverlay');
    if (ov) {
        var title = ov.querySelector('h2');
        if (title) title.textContent = 'Add New Trainer';
        var btn = document.getElementById('trnAddBtn');
        if (btn) { btn.textContent = 'Add Trainer'; btn.removeAttribute('data-mode'); }
    }
    if (typeof window.trnCloseAddModal_orig === 'function') window.trnCloseAddModal_orig();
    else { if (ov) ov.style.display = 'none'; }
};

// Override submit to handle both add and edit
window.trnSubmit_orig = window.trnSubmit;
window.trnSubmit = function(e) {
    e.preventDefault();
    var isEdit = window._trnEditId > 0;
    var msg = document.getElementById('trnAddMsg');
    var btn = document.getElementById('trnAddBtn');
    if (msg) { msg.style.display = 'none'; msg.textContent = ''; }
    btn.disabled = true; btn.textContent = isEdit ? 'Saving...' : 'Adding...';

    var fd = new FormData();
    if (isEdit) fd.append('trainer_id', window._trnEditId);
    fd.append('email',         document.getElementById('trnEmail').value);
    fd.append('full_name',     document.getElementById('trnName').value);
    fd.append('telephone',     document.getElementById('trnTel').value);
    fd.append('trainer_type',  document.getElementById('trnType').value);
    fd.append('status',        document.getElementById('trnStatus').value);
    fd.append('gender',        document.getElementById('trnGender').value);
    fd.append('linkedin_url',  document.getElementById('trnLinkedin').value);
    fd.append('form_key',      window.__trnFormKey);

    var url = isEdit ? window.__trnEditUrl : window.__trnAddUrl;
    fetch(url, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(data){
            btn.disabled = false; btn.textContent = isEdit ? 'Save Changes' : 'Add Trainer';
            if (data.success) {
                trnCloseAddModal();
                window.location.reload();
            } else {
                if (msg) { msg.style.display = ''; msg.textContent = data.message || 'Failed'; }
            }
        })
        .catch(function(err){
            btn.disabled = false; btn.textContent = isEdit ? 'Save Changes' : 'Add Trainer';
            if (msg) { msg.style.display = ''; msg.textContent = 'Network error: ' + err.message; }
        });
};

// ---- Bulk upload modal ----
window.trnOpenBulkModal = function() {
    var ov = document.getElementById('trnBulkOverlay');
    if (ov) ov.style.display = 'flex';
};
window.trnCloseBulkModal = function() {
    var ov = document.getElementById('trnBulkOverlay');
    if (ov) ov.style.display = 'none';
    var f  = document.getElementById('trnBulkFile');
    var t  = document.getElementById('trnDropText');
    var b  = document.getElementById('trnBulkBtn');
    var rs = document.getElementById('trnBulkResult');
    if (f) f.value = '';
    if (t) t.textContent = 'Drag & drop your file here, or click to browse';
    if (b) { b.disabled = true; b.style.opacity = .5; }
    if (rs) { rs.style.display = 'none'; rs.innerHTML = ''; }
};
(function(){
    var input = document.getElementById('trnBulkFile');
    var zone  = document.getElementById('trnDropZone');
    var text  = document.getElementById('trnDropText');
    var btn   = document.getElementById('trnBulkBtn');
    if (!input || !zone) return;

    function onPicked(file) {
        text.textContent = file.name;
        btn.disabled = false; btn.style.opacity = 1;
    }
    input.addEventListener('change', function(){
        if (input.files.length) onPicked(input.files[0]);
    });
    ['dragenter','dragover'].forEach(function(ev){
        zone.addEventListener(ev, function(e){ e.preventDefault(); zone.style.borderColor = '#22d3ee'; });
    });
    ['dragleave','drop'].forEach(function(ev){
        zone.addEventListener(ev, function(e){ e.preventDefault(); zone.style.borderColor = ''; });
    });
    zone.addEventListener('drop', function(e){
        if (e.dataTransfer && e.dataTransfer.files.length) {
            input.files = e.dataTransfer.files;
            onPicked(e.dataTransfer.files[0]);
        }
    });
})();
window.trnBulkSubmit = function() {
    var input = document.getElementById('trnBulkFile');
    var btn   = document.getElementById('trnBulkBtn');
    var rs    = document.getElementById('trnBulkResult');
    if (!input.files.length) return;

    btn.disabled = true; btn.textContent = 'Uploading...';
    rs.style.display = ''; rs.innerHTML = '<span style="color:#94a3b8;">Processing file…</span>';

    var fd = new FormData();
    fd.append('file', input.files[0]);
    fd.append('form_key', window.__trnFormKey);

    fetch(window.__trnBulkUrl, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(data){
            btn.disabled = false; btn.textContent = 'Upload Trainers';
            if (data.success) {
                var html = '<span style="color:#10b981;">Done. Created: ' + data.created + ', Updated: ' + data.updated + '.</span>';
                if (data.errors && data.errors.length) {
                    html += '<div style="color:#f59e0b;margin-top:6px;">' + data.errors.length + ' row(s) skipped:</div>';
                    html += '<ul style="color:#94a3b8;margin:4px 0 0 18px;font-size:11.5px;">';
                    data.errors.slice(0, 10).forEach(function(e){ html += '<li>Row ' + e.row + ': ' + e.message + '</li>'; });
                    if (data.errors.length > 10) html += '<li>… and ' + (data.errors.length - 10) + ' more</li>';
                    html += '</ul>';
                }
                rs.innerHTML = html;
                setTimeout(function(){ window.location.reload(); }, 1500);
            } else {
                var msg = (data.errors && data.errors.length) ? data.errors[0].message : 'Upload failed';
                rs.innerHTML = '<span style="color:#ef4444;">' + msg + '</span>';
            }
        })
        .catch(function(err){
            btn.disabled = false; btn.textContent = 'Upload Trainers';
            rs.innerHTML = '<span style="color:#ef4444;">Network error: ' + err.message + '</span>';
        });
};

// Original trnSubmit removed — unified version defined earlier handles both add + edit
</script>

<?php /* ===== Role switcher JS ===== */ ?>
<script type="text/javascript">
(function(){
    var COURSE_DETAIL_ACTIVE = <?php echo $_selectedCourse ? 'true' : 'false' ?>;
    function showPanel(role) {
        var panels = {
            'Admin':             'dash-panel-admin',
            'Super Admin':       'dash-panel-superadmin',
            'Marketing':         'dash-panel-superadmin',
            'Training Provider': 'dash-panel-trainingprovider',
            'Learner':           'dash-panel-learner',
            'Trainer':           'dash-panel-learner'
        };
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-trainingprovider','dash-panel-learner','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-course-detail'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        // If a course is selected, show course detail instead of the role panel
        if (COURSE_DETAIL_ACTIVE) {
            var detail = document.getElementById('dash-panel-course-detail');
            if (detail) detail.style.display = '';
            return;
        }
        var target = panels[role] || 'dash-panel-admin';
        var show = document.getElementById(target);
        if (show) show.style.display = '';

        var suffix = document.querySelector('.head-role-suffix');
        if (suffix) suffix.textContent = ' — ' + role;
    }

    // Trainer sub-view switcher (My Classes <-> Ed Tools)
    // Only effective when current role is Learner/Trainer; otherwise no-op.
    function showTrainerSubPanel(name) {
        var current = 'Admin';
        try { var s = localStorage.getItem('adminViewAs'); if (s) current = s; } catch(e) {}
        if (current !== 'Trainer' && current !== 'Learner') return;

        // Hide ALL panels first, then show only the requested sub-panel
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-trainingprovider','dash-panel-learner','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-trainers'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        var subMap = {
            'edtools':        'dash-panel-edtools',
            'problemsolving': 'dash-panel-problemsolving',
            'dataanalytics':  'dash-panel-dataanalytics',
            'finance':        'dash-panel-finance',
            'statistical':    'dash-panel-statistical',
            'doe':            'dash-panel-doe',
            'spc':            'dash-panel-spc',
            'sustainability': 'dash-panel-sustainability',
            'blockchain':     'dash-panel-blockchain',
            'genai':          'dash-panel-genai',
            'agentic':        'dash-panel-agentic',
            'virtual':        'dash-panel-virtual'
        };
        var target = subMap[name] || 'dash-panel-learner';
        var show = document.getElementById(target);
        if (show) show.style.display = '';
    }
    window.showTrainerSubPanel = showTrainerSubPanel;

    // Use server-side role (from session) as source of truth, fall back to localStorage.
    var serverRole = <?php echo json_encode((string)$_roleLabel) ?>;
    var role = serverRole || 'Admin';
    try {
        if (serverRole) localStorage.setItem('adminViewAs', serverRole);
        else { var s = localStorage.getItem('adminViewAs'); if (s) role = s; }
    } catch(e) {}

    // Admin/Super Admin sub-view switcher (Dashboard <-> View Trainers)
    function showAdminSubPanel(name) {
        var r = role;
        if (r !== 'Admin' && r !== 'Super Admin' && r !== 'Marketing') return;
        var panelMap = { trainers: 'dash-panel-trainers', dashboard: (r === 'Admin' ? 'dash-panel-admin' : 'dash-panel-superadmin') };
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-trainingprovider','dash-panel-learner','dash-panel-edtools','dash-panel-problemsolving','dash-panel-dataanalytics','dash-panel-finance','dash-panel-statistical','dash-panel-doe','dash-panel-spc','dash-panel-sustainability','dash-panel-blockchain','dash-panel-genai','dash-panel-agentic','dash-panel-virtual','dash-panel-trainers'];
        for (var i=0; i<all.length; i++) { var el = document.getElementById(all[i]); if (el) el.style.display = 'none'; }
        var t = document.getElementById(panelMap[name] || panelMap.dashboard);
        if (t) t.style.display = '';
    }
    window.showAdminSubPanel = showAdminSubPanel;

    function applyInitialPanel() {
        showPanel(role);
        // If URL hash requests a sub-panel, switch to it
        if (window.location.hash === '#trainers' && (role === 'Admin' || role === 'Super Admin' || role === 'Marketing')) {
            showAdminSubPanel('trainers');
        }
    }

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applyInitialPanel);
    } else {
        applyInitialPanel();
    }
    window.addEventListener('hashchange', applyInitialPanel);

    // Expose for header role switcher
    window.__applyDashboardRole = showPanel;
})();

// Admin panel filter functions
var _dashAdvOpen = false;
window.dashToggleAdv = function() {
    _dashAdvOpen = !_dashAdvOpen;
    var el = document.getElementById('dashAdvFilters');
    if (el) { if (_dashAdvOpen) el.classList.add('is-open'); else el.classList.remove('is-open'); }
};
window.dashClearFilters = function() {
    ['dashSearch','fRefCode','fType','fStatus','fDateFrom','fDateTo'].forEach(function(id){
        var el=document.getElementById(id); if(el) el.value='';
    });
    dashFilter();
};
window._dashPage = 1;
window._dashPerPage = 20;
window._dashMatchedRows = [];

window.dashFilter = function(resetPage) {
    if (resetPage !== false) window._dashPage = 1;
    var q    = (document.getElementById('dashSearch')||{value:''}).value.toLowerCase().trim();
    var ref  = (document.getElementById('fRefCode') ||{value:''}).value.toLowerCase().trim();
    var type = (document.getElementById('fType')    ||{value:''}).value.toLowerCase().trim();
    var stat = (document.getElementById('fStatus')  ||{value:''}).value.toLowerCase().trim();
    var df   = (document.getElementById('fDateFrom')||{value:''}).value;
    var dt   = (document.getElementById('fDateTo')  ||{value:''}).value;
    var rows = document.querySelectorAll('#dashTableBody tr');
    window._dashMatchedRows = [];
    for (var i=0; i<rows.length; i++) {
        var r=rows[i], match=true;
        var rt=(r.getAttribute('data-title')||''), rr=(r.getAttribute('data-ref')||'');
        if (q    && rt.indexOf(q)===-1 && rr.indexOf(q)===-1) match=false;
        if (ref  && rr.indexOf(ref)===-1) match=false;
        if (type && (r.getAttribute('data-type')||'').toLowerCase()!==type) match=false;
        if (stat && (r.getAttribute('data-status')||'').toLowerCase()!==stat) match=false;
        var rs=r.getAttribute('data-start')||'';
        if (df && rs && rs<df) match=false;
        if (dt && rs && rs>dt) match=false;
        r.style.display = 'none';
        if (match) window._dashMatchedRows.push(r);
    }
    window.dashRenderPage();
};

window.dashRenderPage = function() {
    var rowsArr = window._dashMatchedRows || [];
    var perPage = window._dashPerPage || 15;
    var total = rowsArr.length;
    var pages = Math.max(1, Math.ceil(total / perPage));
    if (window._dashPage > pages) window._dashPage = pages;
    if (window._dashPage < 1) window._dashPage = 1;

    for (var i=0; i<rowsArr.length; i++) rowsArr[i].style.display = 'none';
    var startIdx = (window._dashPage - 1) * perPage;
    var endIdx   = Math.min(startIdx + perPage, total);
    for (var j=startIdx; j<endIdx; j++) rowsArr[j].style.display = '';

    var nr = document.getElementById('dashNoResults');
    if (nr) nr.style.display = (total === 0) ? '' : 'none';

    var info = document.getElementById('dashPagerInfo');
    if (info) info.textContent = total === 0 ? 'No courses' : ('Showing ' + (startIdx+1) + ' to ' + endIdx + ' of ' + total + ' courses');

    window.dashRenderPager(pages);
};

window.dashRenderPager = function(pages) {
    var c = document.getElementById('dashPagerCtrls');
    if (!c) return;
    c.innerHTML = '';

    function btn(label, page, opts) {
        opts = opts || {};
        var b = document.createElement('button');
        b.className = 'dash-pg-btn' + (opts.active ? ' active' : '') + (opts.disabled ? ' disabled' : '');
        b.textContent = label;
        if (!opts.disabled && page) b.onclick = function(){ window._dashPage = page; window.dashRenderPage(); };
        c.appendChild(b);
    }
    function ellipsis() { var e = document.createElement('span'); e.className = 'dash-pg-ellipsis'; e.textContent = '...'; c.appendChild(e); }

    btn('Prev', window._dashPage - 1, { disabled: window._dashPage <= 1 });

    var maxNumeric = 5;
    var start = Math.max(1, window._dashPage - 2);
    var end   = Math.min(pages, start + maxNumeric - 1);
    if (end - start < maxNumeric - 1) start = Math.max(1, end - maxNumeric + 1);

    if (start > 1) { btn('1', 1); if (start > 2) ellipsis(); }
    for (var p = start; p <= end; p++) btn(String(p), p, { active: p === window._dashPage });
    if (end < pages) { if (end < pages - 1) ellipsis(); btn(String(pages), pages); }

    btn('Next', window._dashPage + 1, { disabled: window._dashPage >= pages });
};

(function(){
    var si=document.getElementById('dashSearch');
    if(si) si.addEventListener('input', function(){ window.dashFilter(); });
    if (typeof window.dashFilter === 'function') window.dashFilter();
})();

// ===== Trainers panel: search + pagination =====
window._trnPage = 1;
window._trnPerPage = 10;
window._trnMatched = [];

window.trnFilter = function() {
    window._trnPage = 1;
    var q = (document.getElementById('trnSearch')||{value:''}).value.toLowerCase().trim();
    var rows = document.querySelectorAll('#trnTableBody tr');
    window._trnMatched = [];
    for (var i=0; i<rows.length; i++) {
        var r = rows[i];
        var n = r.getAttribute('data-name') || '';
        var e = r.getAttribute('data-email') || '';
        r.style.display = 'none';
        if (!q || n.indexOf(q) !== -1 || e.indexOf(q) !== -1) window._trnMatched.push(r);
    }
    window.trnRender();
};

window.trnRender = function() {
    var rows = window._trnMatched;
    var pp = window._trnPerPage;
    var total = rows.length;
    var pages = Math.max(1, Math.ceil(total / pp));
    if (window._trnPage > pages) window._trnPage = pages;
    if (window._trnPage < 1) window._trnPage = 1;
    for (var i=0; i<rows.length; i++) rows[i].style.display = 'none';
    var s = (window._trnPage - 1) * pp;
    var e = Math.min(s + pp, total);
    for (var j=s; j<e; j++) rows[j].style.display = '';

    var info = document.getElementById('trnPagerInfo');
    if (info) info.textContent = total === 0 ? 'No trainers' : ('Showing ' + (s+1) + ' to ' + e + ' of ' + total + ' trainers');

    var c = document.getElementById('trnPagerCtrls');
    if (!c) return;
    c.innerHTML = '';
    function btn(lbl, page, opts) {
        opts = opts || {};
        var b = document.createElement('button');
        b.className = 'dash-pg-btn' + (opts.active ? ' active' : '') + (opts.disabled ? ' disabled' : '');
        b.textContent = lbl;
        if (!opts.disabled && page) b.onclick = function(){ window._trnPage = page; window.trnRender(); };
        c.appendChild(b);
    }
    function dots() { var x=document.createElement('span'); x.className='dash-pg-ellipsis'; x.textContent='...'; c.appendChild(x); }
    btn('Prev', window._trnPage-1, { disabled: window._trnPage<=1 });
    var maxNum = 5;
    var st = Math.max(1, window._trnPage-2);
    var ed = Math.min(pages, st+maxNum-1);
    if (ed-st < maxNum-1) st = Math.max(1, ed-maxNum+1);
    if (st > 1) { btn('1', 1); if (st > 2) dots(); }
    for (var p=st; p<=ed; p++) btn(String(p), p, { active: p === window._trnPage });
    if (ed < pages) { if (ed < pages-1) dots(); btn(String(pages), pages); }
    btn('Next', window._trnPage+1, { disabled: window._trnPage>=pages });
};

window.trnReset = function() {
    var s = document.getElementById('trnSearch'); if (s) s.value = '';
    window.trnFilter();
};

(function(){
    var si = document.getElementById('trnSearch');
    if (si) si.addEventListener('input', function(){ window.trnFilter(); });
    if (typeof window.trnFilter === 'function') window.trnFilter();
})();
</script>

