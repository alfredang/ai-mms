// DATA — Learner panel (My Classes)
// =====================================================================
$_learnerCourses = array();
$_learnerCurrent = 0; $_learnerUpcoming = 0; $_learnerPast = 0;
$_loggedInEmail = '';
try {
    $_loggedInUser = Mage::getSingleton('admin/session')->getUser();
    $_loggedInEmail = $_loggedInUser ? strtolower($_loggedInUser->getEmail()) : '';
} catch (Exception $e) {}

if ($_loggedInEmail) {
    $_now = date('Y-m-d');
    $_resource = Mage::getSingleton('core/resource');
    $_read = $_resource->getConnection('core_read');
    $_orderTable = $_resource->getTableName('sales/order');
    $_itemTable  = $_resource->getTableName('sales/order_item');
    $_prodTable  = $_resource->getTableName('catalog/product');
    $_eav_dt     = $_resource->getTableName('catalog_product_entity_datetime');
    $_eav_vc     = $_resource->getTableName('catalog_product_entity_varchar');

    // Get attribute IDs
    $_nameAttrId = (int) $_read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='name' AND entity_type_id=4");
    $_startAttrId = (int) $_read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_from_date' AND entity_type_id=4");
    $_endAttrId = (int) $_read->fetchOne("SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_to_date' AND entity_type_id=4");

    $_sql = "SELECT DISTINCT oi.product_id, oi.sku, oi.name as item_name,
                o.state as order_state,
                pn.value as product_name,
                sd.value as start_date,
                ed.value as end_date
             FROM {$_orderTable} o
             JOIN {$_itemTable} oi ON o.entity_id = oi.order_id
             LEFT JOIN {$_eav_vc} pn ON oi.product_id = pn.entity_id AND pn.attribute_id = {$_nameAttrId} AND pn.store_id = 0
             LEFT JOIN {$_eav_dt} sd ON oi.product_id = sd.entity_id AND sd.attribute_id = {$_startAttrId} AND sd.store_id = 0
             LEFT JOIN {$_eav_dt} ed ON oi.product_id = ed.entity_id AND ed.attribute_id = {$_endAttrId} AND ed.store_id = 0
             WHERE LOWER(o.customer_email) = ?
             AND o.state NOT IN ('canceled','closed')
             ORDER BY sd.value DESC";

    $_rows = $_read->fetchAll($_sql, array($_loggedInEmail));
    foreach ($_rows as $_r) {
        $_start = $_r['start_date'] ? date('Y-m-d', strtotime($_r['start_date'])) : null;
        $_end = $_r['end_date'] ? date('Y-m-d', strtotime($_r['end_date'])) : null;

        $_status = 'Confirmed';
        if (in_array($_r['order_state'], array('pending','holded','new'))) $_status = 'Pending';

        $_timeStatus = 'past';
        if ($_start && $_end) {
            if ($_now >= $_start && $_now <= $_end) { $_timeStatus = 'current'; $_learnerCurrent++; }
            elseif ($_now < $_start) { $_timeStatus = 'upcoming'; $_learnerUpcoming++; }
            else { $_learnerPast++; }
        } else { $_learnerPast++; }

        // Get product image: prefer course_image_url (external URL) → fallback to uploaded image
        $_imgUrl = '';
        try {
            $_prod = Mage::getModel('catalog/product')->load($_r['product_id']);
            $_courseImgUrl = trim((string) $_prod->getData('course_image_url'));
            if ($_courseImgUrl !== '') {
                $_imgUrl = $_courseImgUrl;
            } elseif ($_prod->getImage() && $_prod->getImage() !== 'no_selection') {
                $_imgUrl = (string) Mage::helper('catalog/image')->init($_prod, 'image')->resize(400, 250);
            }
        } catch (Exception $e) {}

        $_detailUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard', array('course_id' => $_r['product_id']));
        $_learnerCourses[] = array(
            'id'          => $_r['product_id'],
            'name'        => $_r['product_name'] ?: $_r['item_name'],
            'sku'         => $_r['sku'],
            'start_date'  => $_start ? date('j M Y', strtotime($_start)) : '—',
            'end_date'    => $_end ? date('j M Y', strtotime($_end)) : '—',
            'status'      => $_status,
            'time_status' => $_timeStatus,
            'image'       => $_imgUrl,
            'order_state' => $_r['order_state'],
            'detail_url'  => $_detailUrl,
        );
    }

    // Query billing history for this learner (one row per order item)
    $_billSql = "SELECT o.increment_id, o.created_at, o.grand_total, o.status, o.state,
                        oi.name as item_name, oi.sku as item_sku, oi.product_type,
                        (SELECT GROUP_CONCAT(inv.increment_id) FROM {$_resource->getTableName('sales/invoice')} inv WHERE inv.order_id = o.entity_id) as invoice_no
                 FROM {$_orderTable} o
                 JOIN {$_itemTable} oi ON o.entity_id = oi.order_id
                 WHERE LOWER(o.customer_email) = ?
                 ORDER BY o.created_at DESC";
    $_billRows = $_read->fetchAll($_billSql, array($_loggedInEmail));
    foreach ($_billRows as $_b) {
        $_isPaid = in_array($_b['state'], array('complete', 'processing'));
        // Extract course ref code (TGS-XXXXXXXXX) from item name or SKU
        $_refCode = '—';
        if (preg_match('/\b(TGS-\d+)\b/', $_b['item_name'], $_m)) {
            $_refCode = $_m[1];
        } elseif (preg_match('/\b(TGS-\d+)\b/', $_b['item_sku'], $_m)) {
            $_refCode = $_m[1];
        }
        // Generate a deterministic enrollment ID from order + item
        $_enrollId = substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 0, 8) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 8, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 12, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 16, 4) . '-'
                   . substr(md5($_b['increment_id'] . '-' . $_b['item_sku']), 20, 12);
        // Determine type from product_type
        $_type = '—';
        if ($_b['product_type'] === 'virtual') $_type = 'Virtual';
        elseif ($_b['product_type'] === 'simple') $_type = 'Physical';
        elseif ($_b['product_type'] === 'downloadable') $_type = 'Download';
        $_billingHistory[] = array(
            'course_title' => $_b['item_name'],
            'ref_code'     => $_refCode,
            'type'         => $_type,
            'invoice_no'   => $_b['invoice_no'] ?: '—',
            'enrollment_id'=> $_enrollId,
            'date'         => date('d M Y', strtotime($_b['created_at'])),
            'status'       => ucfirst($_b['status']),
            'is_paid'      => $_isPaid,
            'amount'       => (float)$_b['grand_total'],
        );
        $_billingTotal += (float)$_b['grand_total'];
        if ($_isPaid) $_billingPaid += (float)$_b['grand_total'];
        else $_billingPending += (float)$_b['grand_total'];
    }
}

// Selected course detail (if course_id param)
$_selectedCourseId = (int) Mage::app()->getRequest()->getParam('course_id');
$_selectedCourse = null;
if ($_selectedCourseId) {
    // First check learner courses
    foreach ($_learnerCourses as $_c) {
        if ((int)$_c['id'] === $_selectedCourseId) {
            $_selectedCourse = $_c;
            break;
        }
    }
    // If not found (e.g. Admin/Super Admin view), load product directly
    if (!$_selectedCourse) {
        try {
            $_prod = Mage::getModel('catalog/product')->load($_selectedCourseId);
            if ($_prod->getId()) {
                $_pName = $_prod->getName();
                $_pSku  = $_prod->getSku();
                $_pStart = $_prod->getData('news_from_date');
                $_pEnd   = $_prod->getData('news_to_date');
                $_pStatus = ((int)$_prod->getStatus() === 1) ? 'Confirmed' : 'Pending';
                $_pImg = '';
                $_courseImgUrl = trim((string) $_prod->getData('course_image_url'));
                if ($_courseImgUrl !== '') {
                    $_pImg = $_courseImgUrl;
                } elseif ($_prod->getImage() && $_prod->getImage() !== 'no_selection') {
                    try { $_pImg = (string) Mage::helper('catalog/image')->init($_prod, 'image')->resize(400, 250); } catch (Exception $e) {}
                }
                // Determine software/class type
                $_swAttr = $_prod->getAttributeText('software');
                $_selectedCourse = array(
                    'id'          => $_selectedCourseId,
                    'name'        => $_pName ?: '(No Name)',
                    'sku'         => $_pSku,
                    'start_date'  => $_pStart ? date('j M Y', strtotime($_pStart)) : '—',
                    'end_date'    => $_pEnd ? date('j M Y', strtotime($_pEnd)) : '—',
                    'status'      => $_pStatus,
                    'time_status' => 'current',
                    'image'       => $_pImg,
                    'order_state' => 'complete',
                    'detail_url'  => '',
                    'class_type'  => $_swAttr ?: '',
                );
            }
        } catch (Exception $e) {}
    }
}
$_backUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard');

// Edit mode for developer course detail
$_courseMode = Mage::app()->getRequest()->getParam('mode');
$_editMode = ($_courseMode === 'edit' || $_courseMode === 'editing') && $_selectedCourse && $activeRole === 'developer';
$_editingMode = ($_courseMode === 'editing') && $_selectedCourse && $activeRole === 'developer';
$_editCourseData = array();
if ($_editMode) {
    try {
        $_editProd = Mage::getModel('catalog/product')->load($_selectedCourseId);
        if ($_editProd->getId()) {
            $_editCourseData = array(
                'name'        => $_editProd->getName() ?: '',
                'sku'         => $_editProd->getSku() ?: '',
                'image'       => $_selectedCourse['image'],
                'image_url'   => trim((string)$_editProd->getData('course_image_url')),
                'description' => $_editProd->getData('description') ?: '',
                'short_desc'  => $_editProd->getData('short_description') ?: '',
                'start_date'  => $_editProd->getData('news_from_date') ? date('M d, Y', strtotime($_editProd->getData('news_from_date'))) : '',
                'end_date'    => $_editProd->getData('news_to_date') ? date('M d, Y', strtotime($_editProd->getData('news_to_date'))) : '',
                'course_type' => $_editProd->getAttributeText('software') ?: 'WSQ',
                'price'       => $_editProd->getPrice(),
            );
        }
    } catch (Exception $e) {}
}
