<script type="text/javascript">
(function(){
    var TPGSR_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/searchCourseRuns')) ?>;
    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    window.tpgsrSearch = function(){
        var code = document.getElementById('tpgsr-code').value.trim();
        if (!code) { alert('Enter a Course Code first.'); return; }
        var empty = document.getElementById('tpgsr-empty');
        var box   = document.getElementById('tpgsr-results');
        empty.style.display = 'none';
        box.style.display = 'block';
        box.innerHTML = '<div class="tpgsr-empty"><div class="tpgsr-empty-title">Loading…</div></div>';
        fetch(TPGSR_URL + '?code=' + encodeURIComponent(code), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) {
                    box.innerHTML = '<div class="tpgsr-empty"><div class="tpgsr-empty-title">Not found</div><div class="tpgsr-empty-desc">' + escapeHtml(d.message || 'No course matched that code.') + '</div></div>';
                    return;
                }
                if (!d.runs || !d.runs.length) {
                    box.innerHTML = '<div class="tpgsr-empty"><div class="tpgsr-empty-title">No course runs scheduled</div><div class="tpgsr-empty-desc">' + escapeHtml(d.course_name || code) + ' has no scheduled course runs yet.</div></div>';
                    return;
                }
                var html = '<div style="margin-bottom:16px;color:#cbd5e1;font-size:14px;">'
                         + '<strong>' + escapeHtml(d.course_code) + '</strong> — ' + escapeHtml(d.course_name)
                         + ' <span style="color:#94a3b8;margin-left:6px;">(' + d.runs.length + ' run' + (d.runs.length===1?'':'s') + ')</span>'
