                         + '<div class="tpgsr-table-wrap"><table class="tpgsr-table"><thead><tr>'
                         + '<th>Run ID</th><th>Course Run Label</th><th>Session</th><th>Enrolments</th><th>Trainers</th>'
                         + '</tr></thead><tbody>';
                d.runs.forEach(function(r){
                    html += '<tr>'
                         +    '<td><span class="tpgsr-runid-pill">' + escapeHtml(String(r.run_id)) + '</span></td>'
                         +    '<td>' + escapeHtml(r.course_run_label || '—') + '</td>'
                         +    '<td>' + escapeHtml(r.session_title || '—') + '</td>'
                         +    '<td>' + escapeHtml(String(r.enrolment_count || 0)) + '</td>'
                         +    '<td>' + escapeHtml(r.trainer_names || '—') + '</td>'
                         +  '</tr>';
                });
                html += '</tbody></table></div>';
                box.innerHTML = html;
            })
            .catch(function(err){
                box.innerHTML = '<div class="tpgsr-empty"><div class="tpgsr-empty-title">Network error</div><div class="tpgsr-empty-desc">' + escapeHtml(err.message) + '</div></div>';
            });
    };
})();
</script>
