<script type="text/javascript">
(function(){
    var drop = document.getElementById('tpgup-drop');
    var fileInput = document.getElementById('tpgup-file');
    var selected = document.getElementById('tpgup-selected');
    var submitBtn = document.getElementById('tpgup-submit-btn');

    function showFile(file){
        if (!file) {
            selected.style.display = 'none'; selected.textContent = '';
            submitBtn.disabled = true;
            return;
        }
        var sizeKb = (file.size/1024).toFixed(1);
        selected.style.display = '';
        selected.textContent = '✓ ' + file.name + ' (' + sizeKb + ' KB)';
        submitBtn.disabled = false;
    }

    fileInput.addEventListener('change', function(e){
        showFile(e.target.files && e.target.files[0]);
    });

    ['dragenter','dragover'].forEach(function(ev){
        drop.addEventListener(ev, function(e){ e.preventDefault(); e.stopPropagation(); drop.classList.add('dragover'); });
    });
    ['dragleave','drop'].forEach(function(ev){
        drop.addEventListener(ev, function(e){ e.preventDefault(); e.stopPropagation(); drop.classList.remove('dragover'); });
    });
    drop.addEventListener('drop', function(e){
        var files = e.dataTransfer && e.dataTransfer.files;
        if (files && files.length){
            // Assign to the input so a real form submit could carry it
            fileInput.files = files;
            showFile(files[0]);
        }
    });

    window.tpgupDownloadTemplate = function(){
        // CSV is universally accepted by Excel — opens in XLSX as a starter template.
        var csv = 'Course Reference Number,Course Run ID,Start Date,End Date,Mode of Training,Venue UEN,Venue Code,Trainer Name,Trainer Email\r\n'
                + 'TGS-2024052076,1234567,01/05/2026,01/05/2026,Classroom,201200696W,201200696W-01,Trainer Name,trainer@example.com\r\n';
        var blob = new Blob([csv], { type: 'text/csv;charset=utf-8;' });
        var url  = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url; a.download = 'course-run-template.csv';
        document.body.appendChild(a); a.click();
        setTimeout(function(){ document.body.removeChild(a); URL.revokeObjectURL(url); }, 100);
    };

    window.tpgupSubmit = function(){
        var f = fileInput.files && fileInput.files[0];
        if (!f) { alert('Choose a file first.'); return; }
