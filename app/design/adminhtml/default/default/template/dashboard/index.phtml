.dash-search-input{width:100%;background:#111827!important;border:1px solid var(--b1)!important;border-radius:8px;color:var(--t2)!important;font-size:14px;padding:10px 14px 10px 38px!important;box-sizing:border-box}
.dash-search-input:focus{border-color:#22d3ee!important}
.dash-btn-primary{background:#22d3ee!important;color:#111827!important;border:none!important;border-radius:8px;padding:10px 18px;font-size:14px;font-weight:600;cursor:pointer;white-space:nowrap}
.dash-btn-primary:hover{background:#06b6d4!important}
.dash-btn-ghost{background:transparent!important;color:var(--t2)!important;border:1px solid var(--b1)!important;border-radius:8px;padding:10px 16px;font-size:14px;cursor:pointer;white-space:nowrap}
.dash-btn-ghost:hover{border-color:var(--b2)!important;color:var(--t1)!important}
.dash-adv-filters{display:none;margin-top:16px;padding-top:16px;border-top:1px solid var(--b1);grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px}
.dash-adv-filters.is-open{display:grid}
.dash-adv-label{font-size:12px;color:#94a3b8;margin-bottom:4px}
