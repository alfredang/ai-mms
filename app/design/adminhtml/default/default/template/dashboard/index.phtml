function alSwitchTab(t){
    document.getElementById('al-tab-add' ).classList.toggle('active', t==='add');
    document.getElementById('al-tab-list').classList.toggle('active', t==='list');
    document.getElementById('al-pane-add' ).style.display = t==='add'  ? 'block' : 'none';
    document.getElementById('al-pane-list').style.display = t==='list' ? 'block' : 'none';
}
function alSwitchMode(m){
    document.getElementById('al-mode-list-btn'  ).classList.toggle('active', m==='list');
    document.getElementById('al-mode-manual-btn').classList.toggle('active', m==='manual');
    document.getElementById('al-row-list'  ).style.display = m==='list'   ? 'flex' : 'none';
    document.getElementById('al-row-manual').style.display = m==='manual' ? 'flex' : 'none';
}
function alShowMsg(text, kind){
    var el = document.getElementById('al-edit-msg');
    el.textContent = text;
    el.className = 'al-msg ' + (kind === 'err' ? 'err' : 'ok');
    if (kind !== 'err') setTimeout(function(){ el.className = 'al-msg'; }, 4000);
}
function alAddLearner(){
    var listMode = document.getElementById('al-mode-list-btn').classList.contains('active');
    var name = '', email = '';
    if (listMode) {
        var typed = (document.getElementById('al-list-input').value || '').trim();
        if (!typed) { alShowMsg('Pick a learner from the list first.', 'err'); return; }
        name  = typed;
        email = window.AL_LEARNER_MAP[typed.toLowerCase()] || '';
        if (!email && /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(typed)) { email = typed.toLowerCase(); name = typed; }
        if (!email) { alShowMsg('"' + typed + '" is not in the learner list — switch to "Enter manually" to add a new learner.', 'err'); return; }
    } else {
        name  = (document.getElementById('al-manual-name' ).value || '').trim();
        email = (document.getElementById('al-manual-email').value || '').trim().toLowerCase();
        if (!name || !email) { alShowMsg('Both name and email are required.', 'err'); return; }
        if (!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { alShowMsg('That does not look like a valid email.', 'err'); return; }
    }
    var fd = new FormData();
    fd.append('course_entity_id', window.AL_PRODUCT_ID);
    fd.append('course_ref',       window.AL_PRODUCT_SKU);
    fd.append('course_run_id',    window.AL_PRODUCT_RUNID);
    fd.append('learner_email',    email);
    fd.append('learner_fullname', name);
    fd.append('form_key', (window.FORM_KEY || ''));
    fetch(window.AL_ENROLL_URL, { method: 'POST', body: fd, credentials: 'same-origin', redirect: 'manual' })
        .then(function(){ alShowMsg(name + ' enrolled. Reloading…', 'ok'); setTimeout(function(){ window.location.reload(); }, 600); })
        .catch(function(){ alShowMsg('Enrolment failed — try again.', 'err'); });
}
function alRemoveLearner(btn){
    var row   = btn.closest('.al-learner-row');
    var email = row.getAttribute('data-email');
    var name  = row.getAttribute('data-name') || email;
    if (btn.getAttribute('data-external') === '1') {
        alShowMsg(name + ' came from a real customer order — remove via the order rather than here.', 'err');
        return;
    }
    if (!confirm('Remove ' + name + ' from this class?')) return;
    var fd = new FormData();
    fd.append('course_entity_id', window.AL_PRODUCT_ID);
    fd.append('learner_email', email);
    fd.append('form_key', (window.FORM_KEY || ''));
    fetch(window.AL_REMOVE_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
        .then(function(r){ return r.json(); })
        .then(function(j){
            if (j && j.success) { alShowMsg(name + ' removed. Reloading…', 'ok'); setTimeout(function(){ window.location.reload(); }, 600); }
            else { alShowMsg((j && j.message) || 'Remove failed.', 'err'); }
        })
        .catch(function(){ alShowMsg('Remove failed — try again.', 'err'); });
}
</script>
