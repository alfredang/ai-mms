    window.tpgcaTab = function(name){
        document.getElementById('tpgca-tab-qr').classList.toggle('active', name === 'qr');
        document.getElementById('tpgca-tab-list').classList.toggle('active', name === 'list');
        document.getElementById('tpgca-tab-qr-content').style.display = (name === 'qr') ? '' : 'none';
        document.getElementById('tpgca-tab-list-content').style.display = (name === 'list') ? '' : 'none';
    };
    window.tpgcaToggleNric = function(el){
        // Visual toggle only — actual NRIC values aren't stored in our DB.
        el.textContent = (el.textContent === 'Show') ? 'Hide' : 'Show';
    };
    window.tpgcaAddLearner = function(){
        alert('Add Learner — wire to enrolment form when ready.');
    };
    function escapeHtml(s) { s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    window.tpgcaSearch = function(){
        var run = document.getElementById('tpgca-run-id').value.trim();
        if (!run) { alert('Enter a Course Run ID first.'); return; }
        var sessTbody = document.getElementById('tpgca-session-tbody');
        var enrolTbody = document.getElementById('tpgca-enrol-tbody');
        var manualTbody = document.getElementById('tpgca-manual-tbody');
        sessTbody.innerHTML  = '<tr><td colspan="7"  class="tpgca-empty">Loading…</td></tr>';
        enrolTbody.innerHTML = '<tr><td colspan="14" class="tpgca-empty">Loading…</td></tr>';
        manualTbody.innerHTML= '<tr><td colspan="5"  class="tpgca-empty">Loading…</td></tr>';
        fetch(TPGCA_LOOKUP_URL + '?run_id=' + encodeURIComponent(run), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) {
                    sessTbody.innerHTML  = '<tr><td colspan="7" class="tpgca-empty">' + escapeHtml(d.message || 'Run not found.') + '</td></tr>';
                    enrolTbody.innerHTML = '<tr><td colspan="14" class="tpgca-empty">No enrolments.</td></tr>';
                    manualTbody.innerHTML= '<tr><td colspan="5" class="tpgca-empty">No learners.</td></tr>';
                    return;
                }
                // Session Attendance rows
                if (d.attendance && d.attendance.length) {
                    var html = '';
                    d.attendance.forEach(function(a, i){
                        html += '<tr>'
                              +  '<td>' + (i+1) + '</td>'
                              +  '<td>' + escapeHtml(a.name||'') + '</td>'
                              +  '<td>—</td>'
                              +  '<td>Trainee</td>'
                              +  '<td>' + escapeHtml(a.status||'') + '</td>'
                              +  '<td>Manual</td>'
                              +  '<td>—</td>'
                              + '</tr>';
                    });
                    sessTbody.innerHTML = html;
                } else {
                    sessTbody.innerHTML = '<tr><td colspan="7" class="tpgca-empty">No attendance records for this run.</td></tr>';
                }
                // Enrolments rows
                if (d.enrolments && d.enrolments.length) {
                    var html2 = '';
                    d.enrolments.forEach(function(e, i){
                        html2 += '<tr>'
                              +   '<td>' + (i+1) + '</td>'
                              +   '<td>' + escapeHtml(d.run.course_run_label || run) + '</td>'
                              +   '<td>' + escapeHtml(e.start_date||'—') + '</td>'
                              +   '<td>' + escapeHtml(e.end_date||'—') + '</td>'
                              +   '<td>' + escapeHtml(e.increment_id||'') + '</td>'
                              +   '<td>' + escapeHtml(e.name||'') + '</td>'
                              +   '<td>—</td>'
                              +   '<td>—</td>'
                              +   '<td>' + escapeHtml(e.email||'') + '</td>'
                              +   '<td>' + escapeHtml(e.sponsorship||'INDIVIDUAL') + '</td>'
                              +   '<td>' + escapeHtml(e.employer||'—') + '</td>'
                              +   '<td>' + escapeHtml(e.status||'Confirmed') + '</td>'
                              +   '<td>' + escapeHtml(e.enrol_date||'—') + '</td>'
                              +   '<td>' + escapeHtml(e.account||'—') + '</td>'
                              + '</tr>';
                    });
                    enrolTbody.innerHTML = html2;
                    // Manual table mirrors enrolments
                    var html3 = '';
                    d.enrolments.forEach(function(e, i){
                        html3 += '<tr>'
                              +   '<td>' + (i+1) + '</td>'
                              +   '<td>' + escapeHtml(e.name||'') + '</td>'
                              +   '<td>—</td>'
                              +   '<td>Unmarked</td>'
                              +   '<td></td>'
                              + '</tr>';
                    });
                    manualTbody.innerHTML = html3;
                } else {
                    enrolTbody.innerHTML  = '<tr><td colspan="14" class="tpgca-empty">No enrolments for this run.</td></tr>';
                    manualTbody.innerHTML = '<tr><td colspan="5" class="tpgca-empty">No learners enrolled.</td></tr>';
                }
            })
            .catch(function(err){
                sessTbody.innerHTML  = '<tr><td colspan="7" class="tpgca-empty">Network error: ' + escapeHtml(err.message) + '</td></tr>';
                enrolTbody.innerHTML = '<tr><td colspan="14" class="tpgca-empty">—</td></tr>';
                manualTbody.innerHTML= '<tr><td colspan="5" class="tpgca-empty">—</td></tr>';
            });
    };
})();
</script>
<?php endif; ?>

