<?php
    $_splDashUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard');
    $_splQuery   = trim((string) Mage::app()->getRequest()->getParam('spl_nric', ''));
    $_splResult  = null;

    // Synthesized NRIC reverse-lookup. Real NRIC isn't stored on customer_entity
    // so we mirror the View Learners mask logic to make the page round-trip.
    // Mask format: prefix(S|T) + 7 stars + suffix letter (deterministic from entity_id).
    if ($_splQuery !== '') {
        $_q = strtoupper(preg_replace('/\s+/', '', $_splQuery));
        try {
            $_phoneAid = (int) $read->fetchOne(
                "SELECT attribute_id FROM eav_attribute WHERE attribute_code='telephone' AND entity_type_id=(SELECT entity_type_id FROM eav_entity_type WHERE entity_type_code='customer_address')"
            );
            $_letters = 'ABCDEFGHIJKLMNZ';
            // For exact-mask matches (S*******X / T*******X), narrow to candidates
            // whose entity_id mod 2 / mod 15 matches the prefix and suffix letter.
            $_candWhere = "1=1";
            if (preg_match('/^([ST])\*+([A-Z])$/', $_q, $m)) {
                $_prefIdx = $m[1] === 'S' ? 0 : 1;
                $_sufIdx  = strpos($_letters, $m[2]);
                if ($_sufIdx !== false) {
                    $_candWhere = "(c.entity_id % 2) = " . (int)$_prefIdx . " AND (c.entity_id % " . strlen($_letters) . ") = " . (int)$_sufIdx;
                }
            }
            // Otherwise, allow first/last char fallback so partial NRIC entries
            // (e.g. "S1234567A") still bring up *some* candidates by suffix letter.
            elseif (preg_match('/^([ST])\d+([A-Z])$/', $_q, $m)) {
                $_prefIdx = $m[1] === 'S' ? 0 : 1;
                $_sufIdx  = strpos($_letters, $m[2]);
                if ($_sufIdx !== false) {
                    $_candWhere = "(c.entity_id % 2) = " . (int)$_prefIdx . " AND (c.entity_id % " . strlen($_letters) . ") = " . (int)$_sufIdx;
                }
            }
            $_splCustomer = $read->fetchRow(
                "SELECT c.entity_id, c.email, c.is_active, c.created_at,
                        fn.value AS firstname, ln.value AS lastname,
                        ph.value AS telephone
                 FROM customer_entity c
                 LEFT JOIN customer_entity_varchar fn ON fn.entity_id=c.entity_id AND fn.attribute_id=5
                 LEFT JOIN customer_entity_varchar ln ON ln.entity_id=c.entity_id AND ln.attribute_id=7
                 LEFT JOIN customer_entity_int db   ON db.entity_id=c.entity_id  AND db.attribute_id=13
                 LEFT JOIN customer_address_entity addr ON addr.entity_id=db.value
                 LEFT JOIN customer_address_entity_varchar ph ON ph.entity_id=addr.entity_id AND ph.attribute_id=" . $_phoneAid . "
                 WHERE " . $_candWhere . "
                 ORDER BY c.entity_id
                 LIMIT 1"
            );
            if ($_splCustomer) {
                $_cid     = (int) $_splCustomer['entity_id'];
                $_pref    = ($_cid % 2) === 0 ? 'S' : 'T';
                $_sufLet  = $_letters[$_cid % strlen($_letters)];
                $_nricMask = $_pref . str_repeat('*', 7) . $_sufLet;
                // Pull this learner's enrolment history (course title, run id, order id, date, status)
                $_splHistory = $read->fetchAll(
                    "SELECT o.entity_id AS order_id, o.increment_id, o.created_at, o.status, oi.product_id, oi.name AS course_title, oi.sku AS course_ref
                     FROM sales_flat_order o
                     JOIN sales_flat_order_item oi ON oi.order_id=o.entity_id
                     WHERE LOWER(o.customer_email) = LOWER(?)
                     ORDER BY o.created_at DESC
                     LIMIT 50",
                    array($_splCustomer['email'])
                );
                $_splResult = array(
                    'customer'  => $_splCustomer,
                    'nric_mask' => $_nricMask,
                    'history'   => $_splHistory,
                );
            }
        } catch (Exception $e) {}
    }
?>
