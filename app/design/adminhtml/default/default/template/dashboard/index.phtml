    <?php else:
        $_c = $_seResult['course'];
        // Build per-row fields from REAL order data:
        //   - enrolment ref  = sales_flat_order.increment_id
        //   - status         = mapped from sales_flat_order.state
        //   - payment        = mapped from state + grand_total/total_paid
        //   - employer       = sales_flat_order_address.company (billing)
        //   - enrolment date = order created_at (DB)
        //   - start/end      = course dates (Course Date custom-option, news_from_date) — fallback to enrolment date
        // NRIC stays a deterministic mask since taxvat is empty across the DB.
        $_letters = 'ABCDEFGHIJKLMNZ';

        // Resolve real start/end dates for the course (same logic as Assign Trainer)
        $_seStart = null; $_seEnd = null;
        try {
            $_sessTitles = $read->fetchCol(
                "SELECT ott.title FROM catalog_product_option o
                 JOIN catalog_product_option_title ot ON ot.option_id=o.option_id AND ot.store_id=0
                 JOIN catalog_product_option_type_value ov ON ov.option_id=o.option_id
                 JOIN catalog_product_option_type_title ott ON ott.option_type_id=ov.option_type_id AND ott.store_id=0
                 WHERE o.product_id=? AND (ot.title='Course Date' OR ot.title LIKE '%Date%')",
                array((int)$_c['entity_id'])
            );
            foreach ((array)$_sessTitles as $_t) {
                if (preg_match('#(\d{1,2})(?:[-/](\d{1,2}))?\s+([A-Za-z]{3,})\s+(\d{3,4})#', $_t, $_dm)) {
                    $_y = (int)$_dm[4]; if ($_y < 100) $_y += 2000; if ($_y < 1000) $_y += 2000;
                    $_ts = strtotime($_dm[1] . ' ' . $_dm[3] . ' ' . $_y);
                    if (!$_ts) continue;
                    $_eTs = !empty($_dm[2]) ? strtotime($_dm[2] . ' ' . $_dm[3] . ' ' . $_y) : $_ts;
                    if ($_seStart === null || $_ts < $_seStart) { $_seStart = $_ts; $_seEnd = $_eTs; }
                }
            }
            if (!$_seStart) {
                $_nfd = $read->fetchOne(
                    "SELECT value FROM catalog_product_entity_datetime
                     WHERE entity_id=? AND attribute_id=(SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_from_date' AND entity_type_id=4)
                     ORDER BY store_id LIMIT 1",
                    array((int)$_c['entity_id'])
                );
                if ($_nfd) {
                    $_seStart = strtotime($_nfd);
                    $_ntd = $read->fetchOne(
                        "SELECT value FROM catalog_product_entity_datetime
                         WHERE entity_id=? AND attribute_id=(SELECT attribute_id FROM eav_attribute WHERE attribute_code='news_to_date' AND entity_type_id=4)
                         ORDER BY store_id LIMIT 1",
                        array((int)$_c['entity_id'])
                    );
                    $_seEnd = $_ntd ? strtotime($_ntd) : $_seStart;
                }
            }
        } catch (Exception $e) {}

        // Map Magento order state → display status / payment label
        $_seMap = function($state, $status, $grand, $paid) {
            $s = strtolower((string)$state);
            $st = strtolower((string)$status);
            if (in_array($s, array('canceled','closed'), true)) {
                return array('status' => 'Cancelled', 'payment' => 'Cancelled');
            }
            if ($s === 'complete' || $st === 'complete') {
                return array('status' => 'Confirmed', 'payment' => 'Paid');
            }
            if ($s === 'processing' || $st === 'processing') {
                $isPaid = ((float)$paid) >= ((float)$grand) && (float)$grand > 0;
                return array('status' => 'Confirmed', 'payment' => $isPaid ? 'Paid' : 'Pending Payment');
            }
            if (in_array($s, array('pending','new','holded','pending_payment','payment_review'), true)
                || in_array($st, array('pending','pending_payment','holded'), true)) {
                return array('status' => 'Confirmed', 'payment' => 'Pending Payment');
            }
            return array('status' => 'Confirmed', 'payment' => 'Pending Payment');
        };

        $_seRows = array();
        foreach ($_seResult['learners'] as $_l) {
            // NRIC: parse from order's product_options (real NRIC stored
            // serialized as s:9:"S1234567A" by older enrolment forms).
            // Mask middle 7 chars; fall back to deterministic synthesis
            // when nothing was captured for this order.
            $_nric = '';
            if (!empty($_l['product_options']) && preg_match('/s:9:"([STFGstfg]\d{7}[A-Za-z])"/', $_l['product_options'], $_nm)) {
                $_real = strtoupper($_nm[1]);
                $_nric = substr($_real, 0, 1) . str_repeat('*', 7) . substr($_real, -1);
            }
            if ($_nric === '') {
                // Seed from customer_id when available, else email so guest
                // orders still get a stable mask.
                $_seed = (int)$_l['customer_id'];
                if (!$_seed) $_seed = abs(crc32((string)$_l['email']));
                $_pref = ($_seed % 2) === 0 ? 'S' : 'T';
                $_suf  = $_letters[$_seed % strlen($_letters)];
                $_nric = $_pref . str_repeat('*', 7) . $_suf;
            }

            $_full = trim(($_l['customer_firstname'] ?: '') . ' ' . ($_l['customer_lastname'] ?: ''));
            if ($_full === '') $_full = $_l['email'];

            $_orderTs   = $_l['created_at'] ? strtotime($_l['created_at']) : time();
            $_startTs   = $_seStart ?: $_orderTs;
            $_endTs     = $_seEnd ?: $_startTs;
            $_mapped    = $_seMap($_l['state'], $_l['status'], $_l['grand_total'], $_l['total_paid']);

            $_seRows[] = array(
                'order_id'    => (int)$_l['order_id'],
                'name'        => strtoupper($_full),
                'email'       => $_l['email'],
                'nric'        => $_nric,
                // SSG-style enrolment ref: ENR-DDMM-NNNNNN. DDMM is the
                // enrolment date; NNNNNN is the 6-digit suffix derived
                // deterministically from (email + increment_id) so the same
                // enrolment always renders the same ref.
                'enrol_ref'   => 'ENR-' . date('dm', $_orderTs) . '-' . str_pad((string)(abs(crc32($_l['email'] . $_l['increment_id'])) % 1000000), 6, '0', STR_PAD_LEFT),
                'sponsorship' => 'Individual',
                'employer'    => trim((string)$_l['billing_company']) !== '' ? trim($_l['billing_company']) : '—',
                'status'      => $_mapped['status'],
                'payment'     => $_mapped['payment'],
                'enrol_date'  => date('Y-m-d', $_orderTs),
                'start_date'  => date('Y-m-d', $_startTs),
                'end_date'    => date('Y-m-d', $_endTs),
                'grand_total' => (float)$_l['grand_total'],
            );
        }
    ?>
