.dcf-row-input{min-width:0}
.dcf-row-scope{color:#64748b;font-size:11px;text-transform:uppercase;letter-spacing:.5px;padding-top:13px;text-align:right;font-weight:500}
.dcf-row-help{color:#64748b;font-size:12px;margin-top:6px;line-height:1.5}
