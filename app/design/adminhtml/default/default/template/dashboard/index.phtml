<script type="text/javascript">
(function(){
    var TPGER_LOOKUP_URL = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/runLookup')) ?>;
    var TPGER_SAVE_URL   = <?php echo json_encode(Mage::helper('adminhtml')->getUrl('adminhtml/coursesave/editCourseRun')) ?>;
    var TPGER_TRAINERS   = <?php echo json_encode($_tpgerTrainers) ?>;
    window.__tpgerCurrentRunId = null;
    window.__tpgerTrainerCount = 0;

    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}

    window.tpgerAddTrainer = function(){
        var i = (++window.__tpgerTrainerCount);
        var opts = '<option value="">— Select a trainer —</option>';
        TPGER_TRAINERS.forEach(function(t){
            opts += '<option value="' + escapeHtml(t.option_id) + '">' + escapeHtml(t.value) + '</option>';
        });
        var html =
            '<div class="tpger-trainer-form" data-trainer-form="' + i + '">'
          +   '<div class="tpger-trainer-form-title">TRAINER ' + i + '</div>'
          +   '<div class="tpger-field" style="margin-bottom:14px">'
          +     '<label class="tpger-label">Select Trainer</label>'
          +     '<select class="tpger-select" name="trainer_select_' + i + '">' + opts + '</select>'
          +   '</div>'
          +   '<div class="tpger-field">'
          +     '<label class="tpger-label">NRIC/FIN</label>'
          +     '<input type="text" class="tpger-input" name="trainer_nric_' + i + '" placeholder="e.g. S1234567A" autocomplete="off" />'
          +   '</div>'
          + '</div>';
        document.getElementById('tpger-trainer-forms').insertAdjacentHTML('beforeend', html);
    };

    function renderAssignedTrainers(list){
        var box = document.getElementById('tpger-assigned-trainers');
        if (!list || !list.length) { box.innerHTML = '<div class="tpger-help">No trainer currently assigned.</div>'; return; }
        var html = '';
        list.forEach(function(t, i){
            html += '<div class="tpger-trainer-card">'
                 +    '<div class="tpger-trainer-num">Trainer ' + (i+1) + '</div>'
                 +    '<div class="tpger-trainer-row">'
                 +      '<div class="tpger-trainer-cell"><div class="tpger-tlbl">ID NUMBER</div><div class="tpger-tval">' + escapeHtml(t.id_number_masked) + '</div></div>'
                 +      '<div class="tpger-trainer-cell"><div class="tpger-tlbl">NAME</div><div class="tpger-tval">' + escapeHtml(t.name) + '</div></div>'
                 +      '<div class="tpger-trainer-cell"><div class="tpger-tlbl">EMAIL</div><div class="tpger-tval">' + escapeHtml(t.email) + '</div></div>'
                 +    '</div>'
                 +  '</div>';
        });
        box.innerHTML = html;
    }

    window.tpgerFetch = function(){
        var input = document.getElementById('tpger-run-id');
        var box   = document.getElementById('tpger-result');
        var banner= document.getElementById('tpger-banner');
        var form  = document.getElementById('tpger-edit-form');
        var runId = input.value.trim();
        if (!runId) { alert('Enter a Course Run ID first.'); input.focus(); return; }
        box.style.display = 'block';
        box.textContent = 'Fetching run ' + runId + '…';
        form.style.display = 'none';
        banner.style.display = 'none';
        fetch(TPGER_LOOKUP_URL + '?run_id=' + encodeURIComponent(runId), { credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { box.textContent = d.message || 'Course Run not found.'; return; }
                var r = d.run || {};
                window.__tpgerCurrentRunId = r.run_id;
                box.style.display = 'none';
                banner.style.display = 'block';
                banner.innerHTML = '✓ Data loaded for <strong>' + escapeHtml(r.course_name) + '</strong> &mdash; edit the fields below and click Save.';

                document.getElementById('tpger-course-code').value  = r.course_code || '';
                document.getElementById('tpger-course-name').value  = r.course_name || '';
                document.getElementById('tpger-reg-open').value     = r.registration_open_date  || '';
                document.getElementById('tpger-reg-close').value    = r.registration_close_date || '';
                document.getElementById('tpger-start-date').value   = r.start_date || '';
                document.getElementById('tpger-end-date').value     = r.end_date   || '';
                document.getElementById('tpger-admin-email').value  = r.course_admin_email || '';
                if (r.vacancy)  document.getElementById('tpger-vacancy').value = r.vacancy;
                // Mode: derive 1-4 from full label
                var modeKey = (r.mode_of_training_full || '').match(/^(\d)/);
                if (modeKey) document.getElementById('tpger-mode').value = modeKey[1];

                renderAssignedTrainers(r.assigned_trainers || (r.assigned_trainer ? [r.assigned_trainer] : []));

                // Reset trainer forms and add the first empty form
                document.getElementById('tpger-trainer-forms').innerHTML = '';
                window.__tpgerTrainerCount = 0;
                tpgerAddTrainer();

                form.style.display = 'block';
                window.scrollTo({ top: form.offsetTop - 80, behavior: 'smooth' });
            })
            .catch(function(err){ box.textContent = 'Network error: ' + err.message; });
    };
    window.tpgerCancel = function(){
        document.getElementById('tpger-edit-form').style.display = 'none';
        document.getElementById('tpger-banner').style.display = 'none';
        document.getElementById('tpger-run-id').value = '';
        window.__tpgerCurrentRunId = null;
    };
    window.tpgerSave = function(){
        if (!window.__tpgerCurrentRunId) { alert('No run loaded. Fetch a Course Run first.'); return; }
        var fd = new FormData();
        fd.append('form_key', '<?php echo Mage::getSingleton('core/session')->getFormKey() ?>');
        fd.append('run_id', window.__tpgerCurrentRunId);
        // session_title kept for backward compatibility with the existing endpoint
        fd.append('session_title', val('tpger-course-name') + ' (' + (val('tpger-start-date') || 'updated') + ')');
        fetch(TPGER_SAVE_URL, { method: 'POST', body: fd, credentials: 'same-origin' })
            .then(function(r){ return r.json(); })
            .then(function(d){
                if (!d.success) { alert(d.message || 'Save failed.'); return; }
                alert('Saved successfully.');
            })
            .catch(function(err){ alert('Network error: ' + err.message); });
    };
})();
</script>
<?php endif; ?>

