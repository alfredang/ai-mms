 *   #dash-panel-learner          → View As: Learner / Trainer
 *   #dash-panel-trainingprovider → View As: Training Provider  (training analytics)
 */

$resource = Mage::getSingleton('core/resource');
$read     = $resource->getConnection('core_read');
$today    = date('Y-m-d H:i:s');

$_roleHelper = null;
try { $_roleHelper = Mage::helper('mmd_rolemanager'); } catch (Exception $e) {} catch (Error $e) {}
try {
    $activeRole = Mage::helper('mmd_rolemanager')->getActiveRoleCode();
} catch (Exception $e) { $activeRole = 'admin'; } catch (Error $e) { $activeRole = 'admin'; }
$_roleLabel = $_roleHelper ? $_roleHelper->getRoleLabel($activeRole) : ucwords(str_replace('_', ' ', $activeRole));
$_roleIcon  = $_roleHelper ? $_roleHelper->getRoleIcon($activeRole) : '';

// TPG Management sub-pages (Admin only)
$_tpgPage = (string) Mage::app()->getRequest()->getParam('tpg_page', '');
$_tpgActive = ($activeRole === 'admin' && $_tpgPage !== '');
$_tpgCourses = array();
$_tpgTrainers = array();
$_tpgRuns = array();
if ($_tpgActive && ($_tpgPage === 'create_class' || $_tpgPage === 'enroll_learners')) {
    try {
        $_tpgCourses = $read->fetchAll("SELECT e.entity_id, e.sku, (SELECT value FROM catalog_product_entity_varchar v WHERE v.entity_id=e.entity_id AND v.attribute_id=71 ORDER BY v.store_id LIMIT 1) AS name FROM catalog_product_entity e JOIN catalog_product_website pw ON pw.product_id=e.entity_id AND pw.website_id=1 ORDER BY e.sku ASC");
    } catch (Exception $e) {}
}
if ($_tpgActive && $_tpgPage === 'create_class') {
