<?php if ($_tpgActive && $_tpgPage === 'view_enrolment'): ?>
<?php
    $_veDashUrl = Mage::helper('adminhtml')->getUrl('adminhtml/dashboard');
    $_veQuery   = trim((string) Mage::app()->getRequest()->getParam('ve_id', ''));
    $_veResult  = null;
    if ($_veQuery !== '') {
        try {
            // Reverse-lookup the synthesized ENR-DDMM-NNNNNN reference. The
            // ref is computed as: 'ENR-' . date('dm', created_at) . '-' .
            // pad6(crc32(email . increment_id) mod 1_000_000). DDMM narrows
            // the candidate orders to a single day so we don't scan the
            // entire sales table for every search.
            if (preg_match('/^ENR-(\d{4})-(\d{6})$/i', strtoupper($_veQuery), $_veM)) {
                $_veDDMM = $_veM[1]; $_veSuf = $_veM[2];
                $_dd = (int) substr($_veDDMM, 0, 2);
                $_mm = (int) substr($_veDDMM, 2, 2);
                if ($_dd >= 1 && $_dd <= 31 && $_mm >= 1 && $_mm <= 12) {
                    // Search orders whose created_at month-day matches DDMM.
                    // We don't know the year, so candidates span every year.
                    $_veCandidates = $read->fetchAll(
                        "SELECT o.entity_id, o.increment_id, LOWER(o.customer_email) AS email,
                                o.customer_firstname, o.customer_lastname, o.customer_id,
                                o.created_at, o.state, o.status, o.grand_total, o.total_paid,
                                ba.company AS billing_company,
                                oi.product_id, oi.sku AS item_sku, oi.product_options
                         FROM sales_flat_order o
                         JOIN sales_flat_order_item oi ON oi.order_id = o.entity_id
                         LEFT JOIN sales_flat_order_address ba ON ba.parent_id=o.entity_id AND ba.address_type='billing'
                         WHERE DAY(o.created_at) = ? AND MONTH(o.created_at) = ?
                         LIMIT 5000",
                        array($_dd, $_mm)
                    );
                    foreach ($_veCandidates as $_cand) {
                        $_synth = str_pad((string)(abs(crc32($_cand['email'] . $_cand['increment_id'])) % 1000000), 6, '0', STR_PAD_LEFT);
                        if ($_synth === $_veSuf) {
                            $_veResult = $_cand;
                            break;
                        }
                    }
                }
            }
            // Fallback: allow direct lookup by raw Magento increment_id too,
            // so a user pasting a real order # also works.
            if (!$_veResult && preg_match('/^\d{6,}$/', $_veQuery)) {
                $_veResult = $read->fetchRow(
                    "SELECT o.entity_id, o.increment_id, LOWER(o.customer_email) AS email,
                            o.customer_firstname, o.customer_lastname, o.customer_id,
                            o.created_at, o.state, o.status, o.grand_total, o.total_paid,
                            ba.company AS billing_company,
                            oi.product_id, oi.sku AS item_sku, oi.product_options
                     FROM sales_flat_order o
                     JOIN sales_flat_order_item oi ON oi.order_id = o.entity_id
                     LEFT JOIN sales_flat_order_address ba ON ba.parent_id=o.entity_id AND ba.address_type='billing'
                     WHERE o.increment_id = ?
                     LIMIT 1",
                    array($_veQuery)
                );
            }
        } catch (Exception $e) {}
    }
