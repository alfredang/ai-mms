/* Editing form — same layout as read-only view, just with input fields */
.dcf-wrap{max-width:1400px;margin:0 auto}
.dcf-header{display:flex;align-items:flex-start;justify-content:space-between;margin-bottom:18px;flex-wrap:wrap;gap:16px}
.dcf-title{font-size:24px;font-weight:700;color:#fff;flex:1;margin:0;line-height:1.3}
.dcf-title-sub{display:inline-block;background:rgba(34,211,238,.12);border:1px solid rgba(34,211,238,.25);color:#22d3ee;font-size:12px;font-weight:700;padding:4px 10px;border-radius:6px;margin-top:8px;letter-spacing:.3px}
.dcf-actions{display:flex;gap:10px;flex-wrap:wrap;flex-shrink:0}
button.dcf-btn,a.dcf-btn{display:inline-flex !important;align-items:center !important;gap:6px !important;border-radius:8px !important;padding:10px 20px !important;font-size:13px !important;font-weight:600 !important;cursor:pointer !important;box-shadow:none !important;text-shadow:none !important;text-transform:none !important;line-height:normal !important;height:auto !important;text-decoration:none !important;background-image:none !important;border:none !important}
button.dcf-btn-cancel{background:#334155 !important;color:#e2e8f0 !important;border:1px solid #475569 !important}
button.dcf-btn-edit{background:#334155 !important;color:#e2e8f0 !important;border:1px solid #475569 !important}
button.dcf-btn-save-cont{background:#475569 !important;color:#fff !important}
button.dcf-btn-save{background:#2563eb !important;color:#fff !important}
/* Meta info bar (same as read-only) */
.dcf-meta-bar{display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:12px;background:#1e293b;border:1px solid #334155;border-radius:12px;padding:18px 22px;margin-bottom:20px}
.dcf-meta-item{display:flex;flex-direction:column;gap:4px}
.dcf-meta-lbl{font-size:11px;font-weight:600;color:#94a3b8;text-transform:uppercase;letter-spacing:.5px}
.dcf-meta-input{font-size:15px;font-weight:700;color:#f1f5f9;background:#283548;border:1px solid #384a60;border-radius:6px;padding:6px 10px;outline:none;font-family:inherit;width:100%;box-sizing:border-box}
.dcf-meta-input:focus{border-color:#60a5fa}
/* Magento-style tabbed layout — rail lives in the fixed left sidebar
   (.dcf-edit-sidebar above), so the form area is single-column. */
.dcf-tab-content{min-width:0}
.dcf-tab-panel{display:none}
.dcf-tab-panel.active{display:block}
/* Internal two-col layout (image+title vs content) preserved for Course Details */
.dcf-two-col{display:grid;grid-template-columns:minmax(0,360px) minmax(0,1fr);gap:20px;align-items:flex-start}
.dcf-col-left{min-width:0}
.dcf-col-right{min-width:0}
/* Existing card-style section — kept for the Course Details tab and other
   project-specific blocks that use the old vertical-label form layout. */
.dcf-section{background:#1e293b;border:1px solid #334155;border-radius:12px;padding:20px 24px;margin-bottom:16px}
.dcf-section-title{font-size:16px;font-weight:700;color:#fff;margin:0 0 14px;padding-bottom:12px;border-bottom:1px solid #334155;display:flex;align-items:center;gap:8px}
/* Magento-style section: header bar + body. Used for the new Magento-aligned
   tabs (General, Prices, Meta, Inventory, etc.). */
.dcf-mag{background:#1e293b;border:1px solid #334155;border-radius:10px;margin-bottom:16px;overflow:hidden}
.dcf-mag-bar{background:linear-gradient(to bottom,#334155,#2a374a);color:#f1f5f9;padding:13px 22px;font-size:15px;font-weight:700;border-bottom:1px solid #1e293b;display:flex;align-items:center;justify-content:space-between;gap:8px}
.dcf-mag-bar .dcf-mag-action{background:#0e7490;color:#fff;border:none;padding:6px 14px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer}
.dcf-mag-body{padding:18px 24px}
/* Magento-style 3-column row: label | input | scope tag */
.dcf-row{display:grid;grid-template-columns:220px minmax(0,1fr) 110px;gap:18px;align-items:flex-start;padding:12px 0;border-bottom:1px solid rgba(51,65,85,.4)}
.dcf-row:last-child{border-bottom:none}
.dcf-row-label{font-size:13.5px;color:#cbd5e1;line-height:1.4;padding-top:11px}
