<script type="text/javascript">
(function(){
    function showPanel(role) {
        var panels = {
            'Admin':             'dash-panel-admin',
            'Super Admin':       'dash-panel-superadmin',
            'Marketing':         'dash-panel-superadmin',
            'Training Provider': 'dash-panel-trainingprovider',
            'Learner':           'dash-panel-learner',
            'Trainer':           'dash-panel-learner'
        };
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-trainingprovider','dash-panel-learner','dash-panel-edtools'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        var target = panels[role] || 'dash-panel-admin';
        var show = document.getElementById(target);
        if (show) show.style.display = '';

        var suffix = document.querySelector('.head-role-suffix');
        if (suffix) suffix.textContent = ' — ' + role;
    }

    // Trainer sub-view switcher (My Classes <-> Ed Tools)
    // Only effective when current role is Learner/Trainer; otherwise no-op.
    function showTrainerSubPanel(name) {
        var current = '<?php echo htmlspecialchars($_roleLabel) ?>' || 'Admin';
        if (current !== 'Trainer' && current !== 'Learner') return;

        // Hide ALL panels first, then show only the requested sub-panel
        var all = ['dash-panel-admin','dash-panel-superadmin','dash-panel-trainingprovider','dash-panel-learner','dash-panel-edtools'];
        for (var i=0; i<all.length; i++) {
            var el = document.getElementById(all[i]);
            if (el) el.style.display = 'none';
        }
        var target = (name === 'edtools') ? 'dash-panel-edtools' : 'dash-panel-learner';
        var show = document.getElementById(target);
        if (show) show.style.display = '';
    }
    window.showTrainerSubPanel = showTrainerSubPanel;

    // Use server-side role (from session) as source of truth.
    // The View As dropdown does a server-side switch and page reload, so the
    // server role label is always up-to-date after a switch.
    var role = '<?php echo htmlspecialchars($_roleLabel) ?>' || 'Admin';
    try { localStorage.setItem('adminViewAs', role); } catch(e) {}

    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function(){ showPanel(role); });
    } else {
        showPanel(role);
    }

    // Expose for header role switcher
    window.__applyDashboardRole = showPanel;
})();

// Admin panel filter functions
var _dashAdvOpen = false;
window.dashToggleAdv = function() {
    _dashAdvOpen = !_dashAdvOpen;
    var el = document.getElementById('dashAdvFilters');
    if (el) { if (_dashAdvOpen) el.classList.add('is-open'); else el.classList.remove('is-open'); }
};
window.dashClearFilters = function() {
    ['dashSearch','fRefCode','fType','fStatus','fDateFrom','fDateTo'].forEach(function(id){
        var el=document.getElementById(id); if(el) el.value='';
    });
    dashFilter();
};
window.dashFilter = function() {
    var q    = (document.getElementById('dashSearch')||{value:''}).value.toLowerCase().trim();
    var ref  = (document.getElementById('fRefCode') ||{value:''}).value.toLowerCase().trim();
    var type = (document.getElementById('fType')    ||{value:''}).value.toLowerCase().trim();
    var stat = (document.getElementById('fStatus')  ||{value:''}).value.toLowerCase().trim();
    var df   = (document.getElementById('fDateFrom')||{value:''}).value;
    var dt   = (document.getElementById('fDateTo')  ||{value:''}).value;
    var rows = document.querySelectorAll('#dashTableBody tr');
    var vis  = 0;
    for (var i=0; i<rows.length; i++) {
        var r=rows[i], show=true;
        var rt=(r.getAttribute('data-title')||''), rr=(r.getAttribute('data-ref')||'');
        if (q    && rt.indexOf(q)===-1 && rr.indexOf(q)===-1) show=false;
        if (ref  && rr.indexOf(ref)===-1) show=false;
        if (type && (r.getAttribute('data-type')||'').toLowerCase()!==type) show=false;
        if (stat && (r.getAttribute('data-status')||'').toLowerCase()!==stat) show=false;
        var rs=r.getAttribute('data-start')||'';
        if (df && rs && rs<df) show=false;
        if (dt && rs && rs>dt) show=false;
        r.style.display = show ? '' : 'none';
        if (show) vis++;
    }
    var nr=document.getElementById('dashNoResults'); if(nr) nr.style.display=(vis===0)?'':'none';
    var vc=document.getElementById('dashVisCount');  if(vc) vc.textContent=vis;
};
(function(){
    var si=document.getElementById('dashSearch');
    if(si) si.addEventListener('input', dashFilter);
})();
</script>

