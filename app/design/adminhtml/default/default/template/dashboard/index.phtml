                btn.disabled = false; btn.textContent = 'Start E-Attendance';
                if (!d.success) { alert(d.message || 'Failed'); return; }
                document.getElementById('eattCode').textContent = d.code;
                document.getElementById('eattUrl').value = d.url;
                var qr = document.getElementById('eattQR');
                qr.innerHTML = '<img alt="QR" src="https://api.qrserver.com/v1/create-qr-code/?size=140x140&data=' + encodeURIComponent(d.url) + '" style="width:140px;height:140px;" />';
