    // Synthesize a SG-style masked NRIC (S*******X) per learner. Real NRIC
    // is not stored, so we derive a stable trailing letter from entity_id
    // — purely visual, avoids leaking PII.
    $_vlMaskNric = function($eid) {
        $prefixes = array('S','T');
        $letters  = 'ABCDEFGHIJKLMNZ';
        $p = $prefixes[$eid % 2];
        $l = $letters[$eid % strlen($letters)];
        return $p . str_repeat('*', 7) . $l;
    };
