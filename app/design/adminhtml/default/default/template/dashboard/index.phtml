            <div style="display:flex;gap:10px">
                <button type="button" class="tpgbu-clear" onclick="tpgbuClearRows()">Clear All</button>
                <button type="button" class="tpgbu-submit" onclick="tpgbuSubmit()">
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                    Submit Bulk Update
                </button>
            </div>
        </div>
        <div class="tpgbu-table-wrap">
            <table class="tpgbu-table" id="tpgbu-table">
                <thead id="tpgbu-thead"></thead>
                <tbody id="tpgbu-tbody"></tbody>
            </table>
        </div>
    </div>

    <div class="tpg-footer-brand">Powered by <strong>Tertiary Infotech Academy Pte Ltd</strong> &copy; <?php echo date('Y') ?></div>
</div>
<script type="text/javascript">
(function(){
    window.__tpgbuRows    = [];
    window.__tpgbuHeaders = [];
    function escapeHtml(s){ s = s||''; return String(s).replace(/[&<>"']/g, function(c){ return {'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]; }); }

    function render(){
        var card = document.getElementById('tpgbu-rows-card');
        var thead = document.getElementById('tpgbu-thead');
        var tbody = document.getElementById('tpgbu-tbody');
        var count = document.getElementById('tpgbu-row-count');
        if (!window.__tpgbuRows.length) {
            card.style.display = 'none';
            return;
        }
        card.style.display = '';
        count.textContent = window.__tpgbuRows.length;

        var hh = '<tr>';
        window.__tpgbuHeaders.forEach(function(h){ hh += '<th>' + escapeHtml(h) + '</th>'; });
        hh += '</tr>';
        thead.innerHTML = hh;

        var bb = '';
        window.__tpgbuRows.forEach(function(row){
            bb += '<tr>';
            window.__tpgbuHeaders.forEach(function(h, i){
                bb += '<td>' + escapeHtml(row[i] || '') + '</td>';
            });
            bb += '</tr>';
        });
        tbody.innerHTML = bb;
    }

    window.tpgbuHandlePaste = function(){
        var ta = document.getElementById('tpgbu-paste');
        var raw = ta.value;
        if (!raw.trim()) return;
        // Google Sheet copy = TSV (tab-separated). Split on \n then \t.
        var lines = raw.split(/\r?\n/).filter(function(l){ return l.trim() !== ''; });
        if (!lines.length) { ta.value = ''; return; }
        var rows = lines.map(function(l){ return l.split('\t'); });

        // First paste sets headers; subsequent pastes append data rows only.
        if (!window.__tpgbuHeaders.length) {
            // Detect: if the first row looks like headers (contains non-numeric tokens),
            // treat it as headers, else generate Col 1, Col 2, ...
            var first = rows[0];
            var looksLikeHeader = first.some(function(c){ return /[A-Za-z]/.test(c); });
            if (looksLikeHeader) {
                window.__tpgbuHeaders = first;
                rows = rows.slice(1);
            } else {
                window.__tpgbuHeaders = first.map(function(_, i){ return 'Col ' + (i+1); });
            }
        }
        // Append rows; pad to header length
        rows.forEach(function(r){
            while (r.length < window.__tpgbuHeaders.length) r.push('');
            window.__tpgbuRows.push(r);
        });
        ta.value = '';  // clear paste box per spec
        render();
    };

    window.tpgbuClearRows = function(){
        window.__tpgbuRows = [];
        window.__tpgbuHeaders = [];
        render();
    };

    window.tpgbuSubmit = function(){
        if (!window.__tpgbuRows.length) { alert('No rows to submit.'); return; }
        var payload = { headers: window.__tpgbuHeaders, rows: window.__tpgbuRows };
        alert('Bulk update payload prepared with ' + window.__tpgbuRows.length + ' row(s). Backend integration pending.\n\n' + JSON.stringify(payload, null, 2).slice(0, 800) + (JSON.stringify(payload).length > 800 ? '\n\n...(truncated)' : ''));
    };
})();
</script>
<?php endif; ?>

