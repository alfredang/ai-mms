$tpToday = date('Y-m-d H:i:s');

// KPI 1: Total Learners Enrolled (distinct emails, non-canceled)
$tpTotalLearners = (int)$read->fetchOne("SELECT COUNT(DISTINCT customer_email) FROM sales_flat_order WHERE state NOT IN ('canceled','holded')");

// KPI 2: Total Grants Applied (sum of grand_total for processing/pending/complete)
$tpGrantsApplied = (float)$read->fetchOne("SELECT COALESCE(SUM(grand_total),0) FROM sales_flat_order WHERE state IN ('processing','pending','complete')");

// KPI 3: Total Claims Disbursed (sum of grand_total for complete orders)
$tpClaimsDisbursed = (float)$read->fetchOne("SELECT COALESCE(SUM(grand_total),0) FROM sales_flat_order WHERE state='complete'");

// KPI 4-6: Forecasts — average of last 3 full months * 3
$tpForecastRows = $read->fetchAll("
    SELECT DATE_FORMAT(created_at,'%Y-%m') AS ym,
           COUNT(DISTINCT customer_email) AS learners,
           COALESCE(SUM(CASE WHEN state IN ('processing','pending','complete') THEN grand_total ELSE 0 END),0) AS grants,
           COALESCE(SUM(CASE WHEN state='complete' THEN grand_total ELSE 0 END),0) AS claims
    FROM sales_flat_order
    WHERE created_at >= DATE_FORMAT(DATE_SUB(NOW(), INTERVAL 3 MONTH),'%Y-%m-01')
      AND created_at <  DATE_FORMAT(NOW(),'%Y-%m-01')
    GROUP BY ym ORDER BY ym DESC LIMIT 3
");
$tpFcLearners = 0; $tpFcGrants = 0; $tpFcClaims = 0;
if (count($tpForecastRows) > 0) {
    foreach ($tpForecastRows as $fr) { $tpFcLearners += $fr['learners']; $tpFcGrants += $fr['grants']; $tpFcClaims += $fr['claims']; }
    $n = count($tpForecastRows);
    $tpFcLearners = round($tpFcLearners / $n * 3);
    $tpFcGrants   = round($tpFcGrants   / $n * 3, 2);
    $tpFcClaims   = round($tpFcClaims   / $n * 3, 2);
}

