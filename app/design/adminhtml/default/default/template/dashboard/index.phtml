(function(){
    function val(id){var el=document.getElementById(id);return el?el.value.trim():'';}
    window.tpguaActionChange = function(){
        // Void action: only Reference Number + Action are required.
        // Hide the assessment-detail fields to make that obvious.
        var isVoid = (document.getElementById('tpgua-action').value === 'Void');
        ['tpgua-result-wrap','tpgua-name-wrap','tpgua-date-wrap','tpgua-skill-wrap'].forEach(function(id){
            var el = document.getElementById(id);
            if (el) el.style.display = isVoid ? 'none' : '';
        });
    };
    window.tpguaClear = function(){
        ['tpgua-ref','tpgua-name','tpgua-date','tpgua-skill'].forEach(function(id){
            var el = document.getElementById(id); if (el) el.value = '';
        });
        document.getElementById('tpgua-action').value = 'Update';
        document.getElementById('tpgua-result').value = 'Pass';
        tpguaActionChange();
        var box = document.getElementById('tpgua-result-box');
        if (box) { box.textContent=''; box.style.display='none'; }
    };
    window.tpguaSubmit = function(){
        var ref    = val('tpgua-ref');
        var action = val('tpgua-action');
        if (!ref) { alert('Assessment Reference Number is required.'); return; }
        if (!action) { alert('Action is required.'); return; }

        var payload;
        if (action === 'Void') {
            payload = { assessment: { referenceNumber: ref, action: 'Void' } };
        } else {
            var missing = [];
            if (!val('tpgua-name'))  missing.push('Trainee Full Name');
            if (!val('tpgua-date'))  missing.push('Assessment Date');
            if (!val('tpgua-skill')) missing.push('Skill Code');
            if (missing.length) { alert('Please fill: ' + missing.join(', ')); return; }
            payload = {
                assessment: {
                    referenceNumber: ref,
                    action: 'Update',
                    result:         val('tpgua-result'),
                    trainee:        { fullName: val('tpgua-name') },
                    assessmentDate: val('tpgua-date'),
                    skillCode:      val('tpgua-skill'),
                }
            };
        }
        var box = document.getElementById('tpgua-result-box');
        box.style.display = 'block';
        box.textContent = 'Update payload prepared (backend integration pending):\n\n' + JSON.stringify(payload, null, 2);
    };
})();
</script>
