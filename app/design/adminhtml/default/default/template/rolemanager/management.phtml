<script type="text/javascript">
var RM_SAVE_URL = '<?php echo $saveUrl ?>';
var RM_TOGGLE_URL = '<?php echo $toggleUrl ?>';
var RM_DELETE_URL = '<?php echo $deleteUrl ?>';
var RM_FORM_KEY = '<?php echo $formKey ?>';

function rmApplyToggleStyle(btn, selected) {
    var c = btn.getAttribute('data-color');
    if (selected) {
        btn.classList.add('selected');
        btn.style.background = c;
        btn.style.color = '#fff';
        btn.style.borderColor = c;
    } else {
        btn.classList.remove('selected');
        btn.style.background = 'transparent';
        btn.style.color = c;
        btn.style.borderColor = c;
    }
}
function rmToggleRole(btn) {
    rmApplyToggleStyle(btn, !btn.classList.contains('selected'));
}

function rmFilter() {
    var q = document.getElementById('rm-search').value.toLowerCase();
    var rf = document.getElementById('rm-role-filter').value;
    var sf = document.getElementById('rm-status-filter').value;
    var rows = document.querySelectorAll('.rm-row');
    for (var i = 0; i < rows.length; i++) {
        var r = rows[i];
        var matchQ = !q || r.getAttribute('data-name').indexOf(q) >= 0 || r.getAttribute('data-email').indexOf(q) >= 0;
        var matchR = !rf || (r.getAttribute('data-roles') || '').indexOf(rf) >= 0;
        var matchS = sf === '' || r.getAttribute('data-active') === sf;
        r.style.display = (matchQ && matchR && matchS) ? '' : 'none';
    }
}

function rmEdit(uid) {
    var row = document.querySelector('.rm-row[data-uid="' + uid + '"]');
    if (!row) return;
    document.getElementById('rm-edit-uid').value = uid;
    document.getElementById('rm-edit-firstname').value = row.getAttribute('data-firstname');
    document.getElementById('rm-edit-lastname').value = row.getAttribute('data-lastname');
    document.getElementById('rm-edit-email').value = row.getAttribute('data-email');
    document.getElementById('rm-edit-status').value = row.getAttribute('data-active');
    var userRoles = (row.getAttribute('data-roles') || '').split(',');
    var toggles = document.querySelectorAll('.rm-role-toggle');
    for (var i = 0; i < toggles.length; i++) {
        var sel = userRoles.indexOf(toggles[i].getAttribute('data-role')) >= 0;
        rmApplyToggleStyle(toggles[i], sel);
    }
    document.getElementById('rm-modal').classList.add('active');
}

function rmCloseModal() { document.getElementById('rm-modal').classList.remove('active'); }

function rmSave() {
    var uid = document.getElementById('rm-edit-uid').value;
    var roles = [];
    document.querySelectorAll('.rm-role-toggle.selected').forEach(function(t) { roles.push(t.getAttribute('data-role')); });
    var body = 'user_id=' + uid
        + '&firstname=' + encodeURIComponent(document.getElementById('rm-edit-firstname').value)
        + '&lastname=' + encodeURIComponent(document.getElementById('rm-edit-lastname').value)
        + '&is_active=' + document.getElementById('rm-edit-status').value
        + '&form_key=' + RM_FORM_KEY;
    for (var i = 0; i < roles.length; i++) body += '&roles[]=' + encodeURIComponent(roles[i]);

    var xhr = new XMLHttpRequest();
    xhr.open('POST', RM_SAVE_URL);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() { rmCloseModal(); window.location.reload(); };
    xhr.send(body);
}

function rmToggle(uid) {
    if (!confirm('Are you sure you want to change this user\'s status?')) return;
    var xhr = new XMLHttpRequest();
    xhr.open('POST', RM_TOGGLE_URL);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() { window.location.reload(); };
    xhr.send('user_id=' + uid + '&form_key=' + RM_FORM_KEY);
}

function rmDelete(uid) {
    if (!confirm('Permanently delete this user? This action cannot be undone.')) return;
    var xhr = new XMLHttpRequest();
    xhr.open('POST', RM_DELETE_URL);
    xhr.setRequestHeader('Content-Type', 'application/x-www-form-urlencoded');
    xhr.onload = function() { window.location.reload(); };
    xhr.send('user_id=' + uid + '&form_key=' + RM_FORM_KEY);
}
</script>
