<script type="text/javascript">
window.seoCount = function(el, counterId, min, max) {
    var c = document.getElementById(counterId);
    if (!c) return;
    var len = el.value.length;
    var cls = 'seo-counter';
    if (len === 0) cls = 'seo-counter';
    else if (len < min) cls = 'seo-counter warn';
    else if (len > max) cls = 'seo-counter warn';
    else cls = 'seo-counter ok';
    c.className = cls;
    c.textContent = len + ' / ' + min + '-' + max + ' chars';
    seoUpdatePreview();
};
window.seoUpdatePreview = function() {
    var t = document.getElementById('metaTitle');
    var d = document.getElementById('metaDesc');
    var u = document.getElementById('urlSlug');
    var st = document.getElementById('serpTitle');
    var sd = document.getElementById('serpDesc');
    var su = document.getElementById('serpUrl');
    if (t && st) st.textContent = t.value || 'Your meta title will appear here…';
    if (d && sd) sd.textContent = d.value || 'Your meta description will appear here. Write something compelling to attract clicks from search results.';
    if (u && su) su.textContent = 'www.tertiarycourses.com.sg › ' + (u.value || 'course-url');
};
window.seoOnCoursePick = function(sel) {
    // Prototype: in future, fetch existing SEO data via AJAX and populate fields
    if (!sel.value) return;
    var title = sel.options[sel.selectedIndex].text;
    document.getElementById('metaTitle').value = title + ' | Tertiary Infotech Academy';
    document.getElementById('urlSlug').value = title.toLowerCase().replace(/[^a-z0-9]+/g,'-').replace(/^-|-$/g,'').slice(0, 80);
    seoCount(document.getElementById('metaTitle'), 'metaTitleCount', 50, 60);
};
window.seoSave = function() { alert('SEO metadata saved. (Prototype — persistence coming soon)'); };
window.seoAuditRun = function() { alert('Running SEO audit across all courses. (Prototype — full audit coming soon)'); };

// Attach preview updates
document.addEventListener('DOMContentLoaded', function(){
    ['metaTitle','metaDesc','urlSlug'].forEach(function(id){
        var el = document.getElementById(id);
        if (el) el.addEventListener('input', seoUpdatePreview);
    });
});
</script>
