            <button type="button" class="btn-cancel" onclick="toggleEdit()">Cancel</button>
        </div>
    </form>
</div>

<script type="text/javascript">
function toggleEdit() {
    var bio = document.getElementById('bio-section');
    var edit = document.getElementById('edit-section');
    if (edit.classList.contains('active')) {
        edit.classList.remove('active');
        bio.style.display = '';
    } else {
        edit.classList.add('active');
        bio.style.display = 'none';
    }
}
</script>
