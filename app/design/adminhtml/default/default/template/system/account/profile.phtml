        <input type="hidden" name="username" id="hidden-username" value="<?php echo $email ?>" />

        <div class="edit-grid">
            <div class="edit-field">
                <label for="pf-firstname">First Name *</label>
                <input type="text" id="pf-firstname" name="firstname" value="<?php echo $firstName ?>" required />
            </div>
            <div class="edit-field">
                <label for="pf-lastname">Last Name *</label>
                <input type="text" id="pf-lastname" name="lastname" value="<?php echo $lastName ?>" required />
            </div>
            <div class="edit-field full-width">
                <label for="pf-email">Email *</label>
                <input type="email" id="pf-email" name="email" value="<?php echo $email ?>" required onchange="document.getElementById('hidden-username').value=this.value" />
            </div>
            <div class="edit-field full-width" style="border-top:1px solid #334155;padding-top:16px;margin-top:8px;">
