<?php
/** @var MMD_Adminhtml_Block_System_Account_Edit $this */
$user = $this->getUser();
$roles = $this->getUserRoles();
$firstName = $this->escapeHtml($user->getFirstname());
$lastName = $this->escapeHtml($user->getLastname());
$fullName = $firstName . ' ' . $lastName;
$email = $this->escapeHtml($user->getEmail());
$initials = strtoupper(substr($firstName, 0, 1) . substr($lastName, 0, 1));
$roleLabels = array();
foreach ($roles as $rc) { $roleLabels[] = $this->getRoleLabel($rc); }
$roleSubtitle = implode(' & ', $roleLabels);
$formKey = Mage::getSingleton('core/session')->getFormKey();
$minPwLen = $this->getMinPasswordLength();

$roleColors = array(
    'learner'           => '#22c55e',
    'trainer'           => '#f59e0b',
    'admin'             => '#3b82f6',
    'marketing'         => '#a855f7',
    'training_provider' => '#06b6d4',
    'developer'         => '#ef4444',
    'finance'           => '#64748b',
);
?>
