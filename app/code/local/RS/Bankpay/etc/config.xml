<?xml version="1.0"?>
<config>
    <modules>
        <RS_Bankpay>
            <version>1.2</version>
        </RS_Bankpay>
    </modules>
	<frontend>
	 <routers>
            <bankpay>
                <use>standard</use>
                <args>
                    <module>RS_Bankpay</module>
                    <frontName>rs_payment</frontName>
                </args>
            </bankpay>
        </routers>      	
    </frontend>
    <global>
        <models>
            <bankpay>
                <class>RS_Bankpay_Model</class>
            </bankpay>
        </models>        
        <blocks>
            <bankpay>
                <class>RS_Bankpay_Block</class>
            </bankpay>
        </blocks>
        <helpers>
            <bankpay>
                <class>RS_Bankpay_Helper</class>
            </bankpay>
        </helpers>        
    </global>
	<default>
        <payment>
            <bankpay>
                <active>0</active>
                <model>bankpay/bankpay</model>
                <order_status>1</order_status>
                <title>Bank Pay</title>
                <allowspecific>0</allowspecific>
                <form_block_type>0</form_block_type>
            </bankpay>
        </payment>
    </default>
    
    <default>
        <payment>
            <bankpay>
                <title>WSQ and CITREP+</title>
                <active>1</active>
                <show_bank_accounts_in_pdf>1</show_bank_accounts_in_pdf>
                <show_customtext_in_pdf>1</show_customtext_in_pdf>
				<enabledorder>1</enabledorder>
				<recipient_email>sale@example.com</recipient_email>
            </bankpay>
        </payment>
    </default>
</config>
