<config>
  <modules>
    <MMD_Adminhtml>
      <version>1.1.1</version>
    </MMD_Adminhtml>
  </modules>
    <admin>
        <routers>
            <mmd>
                <use>admin</use>
                <args>
                    <module>MMD_Adminhtml</module>
                    <frontName>mmd</frontName>
                </args>
            </mmd>
            <adminhtml>
                <args>
                    <modules>
                        <MMD_Adminhtml before="Mage_Adminhtml">MMD_Adminhtml</MMD_Adminhtml>
                    </modules>
                </args>
            </adminhtml>
        </routers>
    </admin>
    <adminhtml>
        <menu>
            <system>
                <children>
                    <mmd translate="title" module="mmd">
                        <title>Get Support</title>
                        <sort_order>11</sort_order>
                        <action>adminhtml/system_config/edit/section/mmd</action>
                    </mmd>
                </children>
            </system>
        </menu>
        <acl>
            <resources>
                <all>
                    <title>Allow Everything</title>
                </all>
                <admin>
                    <children>
                        <system>
                            <children>
                                <config>
                                    <children>
                                        <mmd translate="title" module="mmd">
                                            <title>MMD &gt; Extensions &amp; Support</title>
                                            <children>
                                                <extensions translate="title">
                                                    <title>Extensions Information</title>
                                                    <sort_order>1</sort_order>
                                                </extensions>
                                                <support translate="title">
                                                    <title>Get Support</title>
                                                    <sort_order>2</sort_order>
                                                </support>
                                            </children>
                                        </mmd>
                                    </children>
                                </config>
                            </children>
                        </system>
                    </children>
                </admin>
            </resources>
        </acl>
        <translate>
            <modules>
                <MMD_Adminhtml>
                    <files>
                        <default>MMD_Adminhtml.csv</default>
                    </files>
                </MMD_Adminhtml>
            </modules>
        </translate>
    </adminhtml>
    <global>
        <blocks>
            <mmd>
                <class>MMD_Adminhtml_Block</class>
            </mmd>
            <adminhtml>
                <rewrite>
                    <system_config_edit>MMD_Adminhtml_Block_System_Config_Edit</system_config_edit>
                    <system_account_edit>MMD_Adminhtml_Block_System_Account_Edit</system_account_edit>
                </rewrite>
            </adminhtml>
        </blocks>
        <models>
            <mmd>
                <class>MMD_Adminhtml_Model</class>
            </mmd>
        </models>
        <resources>
            <mmd_setup>
                <setup>
                    <module>MMD_Adminhtml</module>
                </setup>
                <connection>
                    <use>core_setup</use>
                </connection>
            </mmd_setup>
            <mmd_write>
                <connection>
                    <use>core_write</use>
                </connection>
            </mmd_write>
            <mmd_read>
                <connection>
                    <use>core_read</use>
                </connection>
            </mmd_read>
        </resources>
        <helpers>
            <mmd>
                <class>MMD_Adminhtml_Helper</class>
            </mmd>
        </helpers>
        <template>
            <email>
                <mmd_support_email_template>
                    <label>MMD Support</label>
                    <file>mmd_support.html</file>
                    <type>text</type>
                </mmd_support_email_template>
            </email>
        </template>
    </global>
	
    <default>
        <mmd>
            <support>
                <email><![CDATA[c3VwcG9ydEBtYWdld29yeC5jb20=]]>
                </email>
                <name>MMD Support</name>
                <template>mmd_support_email_template</template>
            </support>
        </mmd>
    </default>
</config>
