<config>
    <tabs>
        <mmd translate="label" module="mmdsys">
            <label>MMD modules settings</label>
            <sort_order>150</sort_order>
        </mmd>
    </tabs>
    <sections>
        <mmdsys translate="label" module="mmdsys">
            <class>separator-top</class>
            <label>Store Specific Settings</label>
            <tab>mmd</tab>
            <frontend_type>text</frontend_type>
            <sort_order>100</sort_order>
            <show_in_default>1</show_in_default>
            <show_in_website>0</show_in_website>
            <show_in_store>0</show_in_store>
            <groups>
                <settings translate="label" module="mmdsys">
                    <label>Modules Manager Settings</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>150</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <fields>
                        <use_dynamic_patches translate="label" module="mmdsys">
                            <label>Use the dynamic templates</label>
                            <frontend_type>select</frontend_type>
                            <source_model>adminhtml/system_config_source_yesno</source_model>
                            <sort_order>10</sort_order>
                            <show_in_default>1</show_in_default>
                            <show_in_website>0</show_in_website>
                            <show_in_store>0</show_in_store>
                        </use_dynamic_patches>
                    </fields>
                </settings>

                <modules translate="label comment" module="mmdsys">
                    <label>Enable/Disable Modules Functionality</label>
                    <frontend_type>text</frontend_type>
                    <sort_order>200</sort_order>
                    <show_in_default>1</show_in_default>
                    <show_in_website>0</show_in_website>
                    <show_in_store>0</show_in_store>
                    <comment>This section allows you to enable/disable module for stores depending on MMD license rules restrictions</comment>
                </modules>
            </groups>
        </mmdsys>
    </sections>
</config>